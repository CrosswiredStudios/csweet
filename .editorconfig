root = true

[*]
indent_size = 4
tab_width = 4
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
csharp_prefer_braces = true:suggestion
csharp_preserve_single_line_statements = false:suggestion

[*.{json,md,yml,yaml}]
indent_size = 2

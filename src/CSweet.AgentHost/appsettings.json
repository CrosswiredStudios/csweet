{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CSweet": {
    "AgentBroker": {
      "Agents": {
        "com.csweet.api-gateway": {
          "Enabled": true,
          "AllowedBusinessIds": [
            "default"
          ],
          "Capabilities": [],
          "Subscriptions": [
            "com.csweet.assistant.response.chunk.v1",
            "com.csweet.assistant.response.created.v1"
          ],
          "Publications": [
            "com.csweet.user.message.received.v1"
          ],
          "Permissions": [
            "installation.route"
          ]
        }
      }
    }
  }
}

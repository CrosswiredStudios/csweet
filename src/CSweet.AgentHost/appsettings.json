{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CSweet": {
    "AgentBroker": {
      "Agents": {
        "com.csweet.api-gateway": {
          "Enabled": true,
          "AllowedBusinessIds": [
            "default"
          ],
          "Capabilities": [],
          "RequestedCapabilities": [
            "agent.configuration.describe.v1",
            "agent.configuration.update.v1"
          ],
          "Subscriptions": [
            "com.csweet.assistant.response.chunk.v1",
            "com.csweet.assistant.response.created.v1"
          ],
          "Publications": [
            "com.csweet.user.message.received.v1"
          ],
          "Permissions": [
            "installation.route"
          ]
        },
        "com.csweet.communication-gateway": {
          "Enabled": true,
          "AllowedBusinessIds": [
            "default"
          ],
          "Capabilities": [
            "communication.message.ingest.v1"
          ],
          "RequestedCapabilities": [
            "communication.send.v1",
            "communication.workspace.apply.v1",
            "communication.identity.assign.v1",
            "communication.link-code.register.v1"
          ],
          "Subscriptions": [],
          "Publications": [],
          "Permissions": [
            "installation.route"
          ]
        }
      }
    }
  }
}

@inherits LayoutComponentBase
@inject IAuthenticationApiClient AuthenticationApi
@inject AuthSessionStore AuthSession
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="setup-layout-shell">
    <header class="setup-layout-header">
        <div class="setup-layout-brand" aria-label="C-Sweet setup">
            <img src="images/icon_dark.svg" alt="" />
            <span class="setup-layout-brand-name">C-Sweet</span>
            <span class="setup-layout-brand-context">Quick setup</span>
        </div>
        <div class="setup-layout-account">
            @if (!string.IsNullOrWhiteSpace(AuthSession.Current?.Email))
            {
                <MudText Typo="Typo.caption">@AuthSession.Current.Email</MudText>
            }
            <MudButton Variant="Variant.Text"
                       Class="setup-sign-out"
                       StartIcon="@Icons.Material.Filled.Logout"
                       OnClick="LogoutAsync">
                Sign out
            </MudButton>
        </div>
    </header>

    <main class="setup-layout-content">
        @Body
    </main>
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#18233F",
            Secondary = "#9BE7C2",
            SecondaryContrastText = "#18233F",
            Tertiary = "#9BE7C2",
            Background = "#FFFCF7",
            Surface = "#FFFFFF",
            TextPrimary = "#18233F",
            TextSecondary = "#68738A",
            Success = "#23845C",
            Warning = "#F2B84B",
            Error = "#E85D75"
        }
    };

    private async Task LogoutAsync()
    {
        await AuthenticationApi.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}

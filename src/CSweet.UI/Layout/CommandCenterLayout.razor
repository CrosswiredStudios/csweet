@inherits LayoutComponentBase
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="command-master-layout">
    <aside class="command-master-rail">
        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">CS</MudAvatar>
        <nav class="command-master-nav" aria-label="Command center navigation">
            <MudTooltip Text="Businesses">
                <MudIconButton Icon="@Icons.Material.Filled.BusinessCenter" Href="/organizations" Color="Color.Inherit" />
            </MudTooltip>
            @if (EmployeesHref is not null)
            {
                <MudTooltip Text="Employees">
                    <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Href="@EmployeesHref" Color="Color.Inherit" />
                </MudTooltip>
            }
            <MudTooltip Text="Configuration">
                <MudIconButton Icon="@Icons.Material.Filled.Tune" Href="/configuration" Color="Color.Inherit" />
            </MudTooltip>
            <MudTooltip Text="Setup">
                <MudIconButton Icon="@Icons.Material.Filled.Settings" Href="/setup" Color="Color.Inherit" />
            </MudTooltip>
        </nav>
    </aside>

    <MudMainContent Class="command-master-main">
        <MudAppBar Elevation="0" Dense="true" Color="Color.Surface" Class="command-master-appbar">
            <MudText Typo="Typo.subtitle1" Class="command-master-title">Command Center</MudText>
            <MudSpacer />
            <BusinessSwitcher />
        </MudAppBar>

        <MudContainer MaxWidth="MaxWidth.False" Class="command-master-content">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private string? EmployeesHref
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0];
            var segments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
            return segments.Length >= 2 &&
                string.Equals(segments[0], "organizations", StringComparison.OrdinalIgnoreCase) &&
                Guid.TryParse(segments[1], out var organizationId)
                    ? $"/organizations/{organizationId}/employees"
                    : null;
        }
    }

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#245B66",
            Secondary = "#7A6434",
            Tertiary = "#426B49",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#18212B",
            DrawerBackground = "#12252B",
            DrawerText = "#DDE7EA",
            DrawerIcon = "#AFC2C8",
            Background = "#F6F8FA",
            Surface = "#FFFFFF",
            TextPrimary = "#18212B",
            TextSecondary = "#52606D",
            Success = "#2F7D4D",
            Warning = "#B97800",
            Error = "#B3261E"
        }
    };
}

@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<AppRealtimeCoordinator />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Color="Color.Surface" Class="app-bar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <div class="app-mobile-brand">
            <img src="images/icon.svg" alt="" />
            <MudText Typo="Typo.h6" Class="app-title">C-Sweet</MudText>
        </div>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               Class="app-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="content">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#18233F",
            Secondary = "#9BE7C2",
            SecondaryContrastText = "#18233F",
            Tertiary = "#9BE7C2",
            AppbarBackground = "#FFFCF7",
            AppbarText = "#18233F",
            DrawerBackground = "#0B2E53",
            DrawerText = "#FFFFFF",
            DrawerIcon = "#FFFFFF",
            Background = "#FFFCF7",
            Surface = "#FFFFFF",
            TextPrimary = "#18233F",
            TextSecondary = "#68738A",
            Success = "#23845C",
            Warning = "#F2B84B",
            Error = "#E85D75"
        },
        LayoutProperties = new LayoutProperties
        {
            DrawerWidthLeft = "260px"
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

}

@inherits LayoutComponentBase
@inject IAuthenticationApiClient AuthenticationApi
@inject AuthSessionStore AuthSession
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Color="Color.Surface" Class="app-bar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="app-title">C-Sweet</MudText>
        <MudSpacer />
        <div class="app-bar-actions">
            <BusinessSwitcher />
            <MudButton Href="/setup" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Tune">Setup</MudButton>
            <MudText Typo="Typo.caption">@AuthSession.Current?.Email</MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="LogoutAsync" StartIcon="@Icons.Material.Filled.Logout">Sign out</MudButton>
        </div>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               Class="app-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="content">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#245B66",
            Secondary = "#7A6434",
            Tertiary = "#426B49",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#18212B",
            DrawerBackground = "#12252B",
            DrawerText = "#DDE7EA",
            DrawerIcon = "#AFC2C8",
            Background = "#F6F8FA",
            Surface = "#FFFFFF",
            TextPrimary = "#18212B",
            TextSecondary = "#52606D",
            Success = "#2F7D4D",
            Warning = "#B97800",
            Error = "#B3261E"
        },
        LayoutProperties = new LayoutProperties
        {
            DrawerWidthLeft = "260px"
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task LogoutAsync()
    {
        await AuthenticationApi.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}

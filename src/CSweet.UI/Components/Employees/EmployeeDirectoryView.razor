<section class="employee-directory-view" role="tabpanel" aria-label="Employee directory">
    <MudTextField T="string" Value="Filter.Search" ValueChanged="ChangeSearchAsync" Placeholder="Search employees by name, role, or agent..." Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.Search" Class="employee-directory-search" />
    <div class="employee-directory-filters">
        <MudSelect T="string" Label="Role" Value="Filter.Role" ValueChanged="ChangeRoleAsync" Variant="Variant.Outlined" Margin="Margin.Dense">
            <MudSelectItem T="string" Value="@("all")">All</MudSelectItem>
            <MudSelectItem T="string" Value="@("unassigned")">Unassigned</MudSelectItem>
            @foreach (var role in Roles.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase))
            {
                <MudSelectItem T="string" Value="@role.Id.ToString()">@role.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="EmployeeTypeFilter" Label="Type" Value="Filter.Type" ValueChanged="ChangeTypeAsync" Variant="Variant.Outlined" Margin="Margin.Dense">
            <MudSelectItem T="EmployeeTypeFilter" Value="EmployeeTypeFilter.All">All</MudSelectItem>
            <MudSelectItem T="EmployeeTypeFilter" Value="EmployeeTypeFilter.Human">Human</MudSelectItem>
            <MudSelectItem T="EmployeeTypeFilter" Value="EmployeeTypeFilter.Agent">Agent</MudSelectItem>
        </MudSelect>
        <MudSelect T="EmployeeRuntimeStatus?" Label="Status" Value="Filter.Status" ValueChanged="ChangeStatusAsync" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
            <MudSelectItem T="EmployeeRuntimeStatus?" Value="@((EmployeeRuntimeStatus?)EmployeeRuntimeStatus.Online)">Online</MudSelectItem>
            <MudSelectItem T="EmployeeRuntimeStatus?" Value="@((EmployeeRuntimeStatus?)EmployeeRuntimeStatus.Transitional)">Transitioning</MudSelectItem>
            <MudSelectItem T="EmployeeRuntimeStatus?" Value="@((EmployeeRuntimeStatus?)EmployeeRuntimeStatus.Offline)">Offline</MudSelectItem>
            <MudSelectItem T="EmployeeRuntimeStatus?" Value="@((EmployeeRuntimeStatus?)EmployeeRuntimeStatus.Failed)">Failed</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.RestartAlt" Disabled="@Filter.IsClear" OnClick="ClearAsync">Clear filters</MudButton>
    </div>
    <div class="employee-directory-count">@ResultLabel</div>
    @if (FilteredEmployees.Count == 0)
    {
        <MudPaper Elevation="0" Class="employee-directory-no-results">
            <MudText Typo="Typo.h6">No matching employees</MudText>
            <MudText Color="Color.Secondary">Try changing or clearing the directory filters.</MudText>
        </MudPaper>
    }
    else
    {
        <div class="employee-directory-desktop">
            <EmployeeDirectoryTable Employees="FilteredEmployees" SelectedId="SelectedId" EmployeeSelected="EmployeeSelected" ActionRequested="ActionRequested" />
        </div>
        <div class="employee-directory-mobile">
            @foreach (var employee in FilteredEmployees)
            {
                <EmployeeDirectoryCard Employee="employee" SelectedId="SelectedId" EmployeeSelected="EmployeeSelected" ActionRequested="ActionRequested" />
            }
        </div>
    }
</section>

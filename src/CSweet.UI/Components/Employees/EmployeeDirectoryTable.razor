<div class="employee-directory-table-wrap">
    <table class="employee-directory-table">
        <thead>
            <tr><th>Employee</th><th>Type</th><th>Status</th><th>Manager</th><th>Subordinates</th><th><span class="sr-only">Actions</span></th></tr>
        </thead>
        <tbody>
            @foreach (var employee in Employees)
            {
                <tr class="@(employee.Id == SelectedId ? "selected" : null)">
                    <td>
                        <button type="button" class="employee-table-identity" @onclick="@(() => SelectAsync(employee.Id))">
                            <EmployeeAvatar Employee="employee" />
                            <span><strong>@employee.Name</strong><small>@employee.RoleLabel</small></span>
                        </button>
                    </td>
                    <td><EmployeeTypeBadge IsAgent="employee.IsAgent" /></td>
                    <td><EmployeeStatusBadge Status="employee.Status" /></td>
                    <td>@(employee.ManagerName ?? "—")</td>
                    <td>@employee.DirectReportCount</td>
                    <td><EmployeeActionMenu Employee="employee" ActionRequested="ActionRequested" /></td>
                </tr>
            }
        </tbody>
    </table>
</div>

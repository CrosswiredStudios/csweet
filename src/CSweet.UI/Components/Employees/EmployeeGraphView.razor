<section class="employee-graph-view" role="tabpanel" aria-label="Employee reporting graph">
    <div class="employee-graph-toolbar">
        <MudSelect T="int" Label="Degrees" Value="Degrees" ValueChanged="ChangeDegreesAsync" Variant="Variant.Outlined" Margin="Margin.Dense" Class="employee-degree-select">
            <MudSelectItem T="int" Value="1">1 degree</MudSelectItem>
            <MudSelectItem T="int" Value="2">2 degrees</MudSelectItem>
            <MudSelectItem T="int" Value="3">3 degrees</MudSelectItem>
        </MudSelect>
        <MudTooltip Text="Controls how many reporting relationships are shown around the selected employee.">
            <MudIconButton Icon="@Icons.Material.Outlined.Info" Color="Color.Primary" aria-label="About graph degrees" />
        </MudTooltip>
    </div>

    <div class="employee-graph-workspace">
        <div class="employee-graph-canvas" tabindex="0" aria-label="Reporting graph. Use the Directory view for a tabular alternative.">
            <svg viewBox="@ViewBox" role="img" aria-label="Employee reporting relationships">
                @foreach (var edge in Graph.Edges)
                {
                    <path class="employee-graph-connector" d="@EdgePath(edge)" />
                }
                @foreach (var node in Graph.Nodes)
                {
                    <foreignObject @key="node.Employee.Id" x="@(node.X - 105)" y="@(node.Y - 52)" width="210" height="104">
                        <EmployeeGraphNode Employee="node.Employee" Selected="@(node.Employee.Id == SelectedId)" SelectedChanged="SelectAsync" />
                    </foreignObject>
                }
            </svg>
        </div>
        <EmployeeDetailsPanel Employee="SelectedEmployee" Employees="Employees" EmployeeSelected="SelectAsync" ActionRequested="ActionRequested" />
    </div>

    <footer class="employee-graph-legend" aria-label="Graph legend">
        <span><i class="human"></i>Human</span>
        <span><i class="agent"></i>Agent</span>
        <span><i class="online"></i>Online</span>
        <span><i class="transitioning"></i>Transitioning</span>
        <span><i class="offline"></i>Offline</span>
        <span><i class="failed"></i>Failed</span>
        <span class="employee-graph-hint"><MudIcon Icon="@Icons.Material.Outlined.TouchApp" /> Select an employee to refocus the graph.</span>
    </footer>
</section>

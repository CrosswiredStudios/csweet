@implements IDisposable
@inject IBusinessContext BusinessContext

<div class="business-switcher">
    @if (BusinessContext.IsLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Tertiary" Class="business-switcher-progress" />
        <MudText Typo="Typo.caption">Loading businesses...</MudText>
    }
    else if (!string.IsNullOrWhiteSpace(BusinessContext.ErrorMessage))
    {
        <MudText Typo="Typo.caption" Class="business-switcher-error">@BusinessContext.ErrorMessage</MudText>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small" OnClick="RefreshAsync">Retry</MudButton>
    }
    else if (BusinessContext.Businesses.Count == 0)
    {
        <MudButton Href="/?create=true" Variant="Variant.Outlined" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.AddBusiness" FullWidth="true">
            Create a business
        </MudButton>
    }
    else
    {
        <MudSelect T="Guid?"
                   Label="Focused business"
                   Value="BusinessContext.SelectedBusiness?.Id"
                   ValueChanged="SwitchBusinessAsync"
                   Dense="true"
                   Margin="Margin.Dense"
                   Variant="Variant.Outlined"
                   Class="business-switcher-select">
            @foreach (var business in BusinessContext.Businesses)
            {
                <MudSelectItem T="Guid?" Value="business.Id">@business.Name</MudSelectItem>
            }
        </MudSelect>
    }
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        BusinessContext.Changed += OnContextChanged;
        await BusinessContext.InitializeAsync();
    }

    private Task SwitchBusinessAsync(Guid? businessId) =>
        businessId is null ? Task.CompletedTask : BusinessContext.SelectAsync(businessId.Value);

    private Task RefreshAsync() => BusinessContext.RefreshAsync();

    private void OnContextChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => BusinessContext.Changed -= OnContextChanged;
}

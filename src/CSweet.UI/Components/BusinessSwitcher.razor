@using CSweet.Contracts.Core
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation

@if (_organizations.Count > 0)
{
    <div class="business-switcher">
        <MudSelect T="string"
                   Label="Business"
                   Value="_selectedOrganizationId"
                   ValueChanged="SwitchBusinessAsync"
                   Dense="true"
                   Margin="Margin.Dense"
                   Variant="Variant.Outlined"
                   Class="business-switcher-select">
            @foreach (var organization in _organizations)
            {
                <MudSelectItem T="string" Value="@organization.Id.ToString()">@organization.Name</MudSelectItem>
            }
        </MudSelect>
    </div>
}

@code {
    private IReadOnlyList<OrganizationResponse> _organizations = [];
    private string _selectedOrganizationId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        await LoadOrganizationsAsync();
        SelectOrganizationFromRoute();
    }

    private async Task LoadOrganizationsAsync()
    {
        try
        {
            _organizations = await Http.GetFromJsonAsync<IReadOnlyList<OrganizationResponse>>("api/organizations") ?? [];
        }
        catch
        {
            _organizations = [];
        }
    }

    private async Task SwitchBusinessAsync(string? value)
    {
        if (!Guid.TryParse(value, out var organizationId))
        {
            return;
        }

        _selectedOrganizationId = organizationId.ToString();
        await Task.Yield();
        Navigation.NavigateTo($"/organizations/{organizationId}/command-center");
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        SelectOrganizationFromRoute();
        _ = InvokeAsync(StateHasChanged);
    }

    private void SelectOrganizationFromRoute()
    {
        var routeOrganizationId = GetOrganizationIdFromCurrentRoute();
        if (routeOrganizationId is not null && _organizations.Any(x => x.Id == routeOrganizationId.Value))
        {
            _selectedOrganizationId = routeOrganizationId.Value.ToString();
            return;
        }

        _selectedOrganizationId = _organizations.FirstOrDefault()?.Id.ToString() ?? string.Empty;
    }

    private Guid? GetOrganizationIdFromCurrentRoute()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var pathOnly = relativePath.Split('?', '#')[0];
        var segments = pathOnly.Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (segments.Length >= 2 &&
            string.Equals(segments[0], "organizations", StringComparison.OrdinalIgnoreCase) &&
            Guid.TryParse(segments[1], out var organizationId))
        {
            return organizationId;
        }

        return null;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}

@inject NavigationManager Navigation

<nav class="settings-navigation" aria-label="Settings sections">
    <MudButton Href="/settings/llm-providers" Variant="@LlmVariant" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.AutoAwesome">
        LLM Providers
    </MudButton>
    <MudButton Href="/settings/agents" Variant="@AgentsVariant" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.SmartToy">
        Agents
    </MudButton>
    <MudButton Href="/settings/plugins" Variant="@PluginsVariant" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Extension">
        Plugins
    </MudButton>
    <MudButton Href="/settings/security" Variant="@SecurityVariant" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Security">
        Security
    </MudButton>
    <MudButton Href="/settings/communications" Variant="@CommunicationsVariant" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Forum">
        Communications
    </MudButton>
</nav>

@code {
    private Variant LlmVariant => VariantFor("/settings/llm-providers");
    private Variant AgentsVariant => VariantFor("/settings/agents");
    private Variant PluginsVariant => VariantFor("/settings/plugins");
    private Variant SecurityVariant => VariantFor("/settings/security");
    private Variant CommunicationsVariant => VariantFor("/settings/communications");

    private Variant VariantFor(string path)
    {
        var current = "/" + Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/').Split('?', '#')[0];
        return current.StartsWith(path, StringComparison.OrdinalIgnoreCase) ? Variant.Filled : Variant.Text;
    }
}

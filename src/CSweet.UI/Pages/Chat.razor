@page "/organizations/{OrganizationId:guid}/chat/{AgentUserId:guid}"
@layout CommandCenterLayout
@using CSweet.Contracts.Agents
@using CSweet.Contracts.Core
@implements IDisposable
@inject HttpClient Http
@inject IChatApiClient ChatApi
@inject IAgentApiClient AgentApi

<PageTitle>Chat - C-Sweet</PageTitle>

<div class="command-center-shell chat-page">
    <MudPaper Elevation="0" Class="page-header chat-page-header">
        <div>
            <div class="chat-agent-status"><span aria-hidden="true"></span> Agent conversation</div>
            <MudText Typo="Typo.h3">@(_agent?.DisplayName ?? "Agent")</MudText>
            <MudText Color="Color.Secondary">@(_conversation?.Title ?? "Live assistant chat")</MudText>
        </div>
        <MudButton Href="@($"/organizations/{OrganizationId}/employees")"
                   Variant="Variant.Outlined"
                   Color="Color.Primary"
                   Class="chat-back-button"
                   StartIcon="@Icons.Material.Filled.ArrowBack">
            Employees
        </MudButton>
    </MudPaper>

    @if (_loading)
    {
        <MudPaper Elevation="1" Class="surface-panel chat-loading-panel">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Color="Color.Secondary" role="status" aria-live="polite">@LoadingMessage</MudText>
            @if (_runtimeReadiness is not null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">@LoadingDetail</MudText>
                @if (!string.IsNullOrWhiteSpace(_runtimeReadiness.Reason))
                {
                    <MudText Typo="Typo.caption">@_runtimeReadiness.Reason</MudText>
                }
            }
        </MudPaper>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="chat-alert">@_errorMessage</MudAlert>
            @if (_conversation is null)
            {
                <MudStack Row="true" Spacing="2" Class="mb-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RetryStartupAsync" StartIcon="@Icons.Material.Filled.Refresh">
                        Retry startup
                    </MudButton>
                    <MudButton Href="@($"/organizations/{OrganizationId}/employees")" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Terminal">
                        Employee console
                    </MudButton>
                </MudStack>
            }
        }

        <div class="chat-workspace">
        <MudPaper Elevation="1" Class="surface-panel chat-history" aria-label="Conversation history">
            <div class="chat-history-header">
                <MudText Typo="Typo.subtitle2">Conversations</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               Size="Size.Small"
                               aria-label="New conversation"
                               Disabled="_streaming"
                               OnClick="NewConversationAsync" />
            </div>
            @if (_conversations.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No previous conversations.</MudText>
            }
            else
            {
                @foreach (var conversation in _conversations)
                {
                    <button type="button"
                            class="chat-history-item @(conversation.Id == _conversation?.Id ? "chat-history-item-active" : null)"
                            disabled="@_streaming"
                            @onclick="@(() => SelectConversationAsync(conversation))">
                        <span>@ConversationTitle(conversation)</span>
                        <small>@conversation.UpdatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</small>
                    </button>
                }
            }
        </MudPaper>

        <div class="chat-main">
        <MudPaper Elevation="1" Class="surface-panel chat-transcript" role="log" aria-live="polite" aria-busy="@_streaming">
            @if (_messages.Count == 0 && !_streaming)
            {
                <div class="chat-empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.Chat" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">Start the conversation</MudText>
                    <MudText Color="Color.Secondary">Send a message when you are ready.</MudText>
                </div>
            }

            @foreach (var message in _messages)
            {
                <div class="chat-row @(message.Role == UserRole ? "chat-row-user" : "chat-row-assistant")">
                    @if (message.Role != UserRole)
                    {
                        <div class="chat-agent-avatar" aria-hidden="true">@AgentInitial</div>
                    }
                    <div class="chat-bubble @(message.Role == UserRole ? "chat-bubble-user" : "chat-bubble-assistant")">
                        <ChatMarkdown Content="@message.Content" />
                    </div>
                </div>
            }

            @if (_streaming)
            {
                <div class="chat-row chat-row-assistant">
                    <div class="chat-agent-avatar" aria-hidden="true">@AgentInitial</div>
                    <div class="chat-bubble chat-bubble-assistant">
                        @if (string.IsNullOrEmpty(_streamingText))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Personal Assistant is thinking...</MudText>
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <ChatMarkdown Content="@_streamingText" />
                        }
                    </div>
                </div>
            }
        </MudPaper>

        <MudPaper Elevation="1" Class="surface-panel chat-input">
            <MudTextField @bind-Value="_draft"
                          Placeholder="Message your assistant..."
                          Variant="Variant.Outlined"
                          Lines="2"
                          Immediate="true"
                          OnKeyDown="OnKeyDownAsync"
                          Disabled="_streaming"
                          Class="chat-input-field" />
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="SendAsync"
                       Disabled="@(_streaming || string.IsNullOrWhiteSpace(_draft) || _conversation is null)"
                       EndIcon="@Icons.Material.Filled.Send">
                Send
            </MudButton>
        </MudPaper>
        </div>
        </div>
    }
</div>

@code {
    private const int UserRole = 0;
    private const int AssistantRole = 1;

    [Parameter]
    public Guid OrganizationId { get; set; }

    [Parameter]
    public Guid AgentUserId { get; set; }

    private readonly List<ConversationMessageResponse> _messages = [];
    private readonly List<ConversationResponse> _conversations = [];
    private readonly CancellationTokenSource _disposeCts = new();
    private OrganizationUserResponse? _agent;
    private ConversationResponse? _conversation;
    private AgentRuntimeReadinessResponse? _runtimeReadiness;
    private string _draft = string.Empty;
    private string _streamingText = string.Empty;
    private bool _loading = true;
    private bool _streaming;
    private string? _errorMessage;

    private string AgentInitial => string.IsNullOrWhiteSpace(_agent?.DisplayName)
        ? "A"
        : _agent.DisplayName[..1].ToUpperInvariant();

    private string LoadingMessage => _runtimeReadiness?.Stage switch
    {
        AgentRuntimeReadinessStages.Queued => "Agent runtime queued...",
        AgentRuntimeReadinessStages.StartingContainer => "Starting agent container...",
        AgentRuntimeReadinessStages.WaitingForBroker => "Connecting agent to C-Sweet...",
        AgentRuntimeReadinessStages.Stopping => "Cleaning up the previous runtime...",
        AgentRuntimeReadinessStages.Ready => "Opening conversation...",
        _ => "Preparing your employee..."
    };

    private string LoadingDetail
    {
        get
        {
            if (_runtimeReadiness is null)
            {
                return string.Empty;
            }

            var beganAt = _runtimeReadiness.StartedAt ?? _runtimeReadiness.QueuedAt;
            var elapsed = beganAt is null
                ? string.Empty
                : $" · {Math.Max(0, (int)(DateTimeOffset.UtcNow - beganAt.Value).TotalSeconds)}s elapsed";
            var runtimeId = _runtimeReadiness.RuntimeInstanceId?.ToString("N")[..8] ?? "pending";
            return $"Status: {_runtimeReadiness.RuntimeStatus ?? _runtimeReadiness.Stage} · Runtime {runtimeId}{elapsed}";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _errorMessage = null;
        _runtimeReadiness = null;
        _conversation = null;
        _messages.Clear();
        _conversations.Clear();

        try
        {
            _agent = await Http.GetFromJsonAsync<OrganizationUserResponse>(
                $"api/core/organizations/{OrganizationId}/users/{AgentUserId}",
                _disposeCts.Token);

            if (_agent?.AgentInstallationId is not Guid installationId)
            {
                throw new InvalidOperationException("This agent employee is not linked to an installation.");
            }

            using var startupCts = CancellationTokenSource.CreateLinkedTokenSource(_disposeCts.Token);
            startupCts.CancelAfter(TimeSpan.FromSeconds(90));
            _runtimeReadiness = await AgentApi.EnsureRuntimeAsync(installationId, startupCts.Token);
            while (!_runtimeReadiness.IsReady)
            {
                if (_runtimeReadiness.IsTerminal)
                {
                    throw new InvalidOperationException(
                        _runtimeReadiness.Reason ?? "The agent runtime could not be started.");
                }

                await Task.Delay(TimeSpan.FromSeconds(1), startupCts.Token);
                _runtimeReadiness = await AgentApi.GetRuntimeStatusAsync(installationId, startupCts.Token);
                StateHasChanged();
            }

            await RefreshConversationsAsync(_disposeCts.Token);
            if (_conversations.Count == 0)
            {
                await NewConversationAsync();
            }
            else
            {
                await SelectConversationAsync(_conversations[0]);
            }
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "The agent runtime did not become ready in time. Return to Employees and review its status before retrying.";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Task RetryStartupAsync() => OnParametersSetAsync();

    private async Task NewConversationAsync()
    {
        if (_streaming)
        {
            return;
        }

        _conversation = await ChatApi.StartConversationAsync(
            OrganizationId,
            AgentUserId,
            _disposeCts.Token);
        _messages.Clear();
        _conversations.Insert(0, _conversation);
        _errorMessage = null;
    }

    private async Task SelectConversationAsync(ConversationResponse conversation)
    {
        if (_streaming || conversation.Id == _conversation?.Id)
        {
            return;
        }

        _conversation = conversation;
        _messages.Clear();
        _messages.AddRange(await ChatApi.GetMessagesAsync(
            OrganizationId,
            conversation.Id,
            _disposeCts.Token));
        _errorMessage = null;
    }

    private async Task RefreshConversationsAsync(CancellationToken cancellationToken)
    {
        var conversations = await ChatApi.GetConversationsAsync(
            OrganizationId,
            AgentUserId,
            cancellationToken);
        _conversations.Clear();
        _conversations.AddRange(conversations);
    }

    private static string ConversationTitle(ConversationResponse conversation) =>
        string.IsNullOrWhiteSpace(conversation.Title) ? "New conversation" : conversation.Title;

    private async Task OnKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey)
        {
            await SendAsync();
        }
    }

    private async Task SendAsync()
    {
        if (_streaming || _conversation is null || string.IsNullOrWhiteSpace(_draft))
        {
            return;
        }

        var text = _draft.Trim();
        _draft = string.Empty;
        _errorMessage = null;

        _messages.Add(new ConversationMessageResponse(
            Guid.NewGuid(),
            _conversation.Id,
            UserRole,
            text,
            DateTimeOffset.UtcNow));

        _streaming = true;
        _streamingText = string.Empty;
        StateHasChanged();

        try
        {
            await foreach (var delta in ChatApi.SendMessageAsync(
                OrganizationId,
                _conversation.Id,
                text,
                _disposeCts.Token))
            {
                _streamingText += delta;
                await InvokeAsync(StateHasChanged);
            }

            if (!string.IsNullOrWhiteSpace(_streamingText))
            {
                var conversationId = _conversation.Id;
                _messages.Add(new ConversationMessageResponse(
                    Guid.NewGuid(),
                    conversationId,
                    AssistantRole,
                    _streamingText,
                    DateTimeOffset.UtcNow));

                await RefreshConversationsAsync(_disposeCts.Token);
                _conversation = _conversations.FirstOrDefault(x => x.Id == conversationId) ?? _conversation;
            }
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            _errorMessage = $"The assistant could not respond: {ex.Message}";
        }
        finally
        {
            _streaming = false;
            _streamingText = string.Empty;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _disposeCts.Cancel();
        _disposeCts.Dispose();
    }
}

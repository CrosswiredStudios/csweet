@page "/recover-root"
@layout AnonymousLayout
@using System.ComponentModel.DataAnnotations
@using CSweet.Contracts.Auth
@inject IAuthenticationApiClient AuthenticationApi

<PageTitle>Recover root administrator - C-Sweet</PageTitle>

<MudPaper Elevation="0" Class="auth-card">
    <MudText Typo="Typo.h4">Recover the root account</MudText>
    <MudText Color="Color.Secondary">Use one of the offline codes saved during initial registration. A successful recovery consumes that code and signs out existing sessions.</MudText>
    <EditForm Model="_model" OnValidSubmit="RecoverAsync" Class="auth-form">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <MudTextField Label="Root email" InputType="InputType.Email" @bind-Value="_model.Email" For="@(() => _model.Email)" Variant="Variant.Outlined" Required="true" />
        <MudTextField Label="Recovery code" @bind-Value="_model.RecoveryCode" For="@(() => _model.RecoveryCode)" Variant="Variant.Outlined" Required="true" />
        <MudTextField Label="New password" InputType="InputType.Password" @bind-Value="_model.Password" For="@(() => _model.Password)" Variant="Variant.Outlined" Required="true" />
        <MudTextField Label="Confirm password" InputType="InputType.Password" @bind-Value="_model.ConfirmPassword" For="@(() => _model.ConfirmPassword)" Variant="Variant.Outlined" Required="true" />
        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <MudAlert Severity="@(_success ? Severity.Success : Severity.Error)" Variant="Variant.Outlined">@_message</MudAlert>
        }
        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="_busy">@(_busy ? "Recovering..." : "Reset root password")</MudButton>
        <MudButton Href="/login" Variant="Variant.Text" FullWidth="true">Back to sign in</MudButton>
    </EditForm>
</MudPaper>

@code {
    private readonly RecoveryModel _model = new();
    private bool _busy;
    private bool _success;
    private string? _message;

    private async Task RecoverAsync()
    {
        _busy = true;
        var result = await AuthenticationApi.RecoverRootAsync(new RecoverRootRequest(_model.Email, _model.RecoveryCode, _model.Password, _model.ConfirmPassword));
        _success = result.Succeeded;
        _message = result.Message;
        _busy = false;
    }

    private sealed class RecoveryModel
    {
        [Required, EmailAddress] public string Email { get; set; } = string.Empty;
        [Required] public string RecoveryCode { get; set; } = string.Empty;
        [Required] public string Password { get; set; } = string.Empty;
        [Required] public string ConfirmPassword { get; set; } = string.Empty;
    }
}

@page "/"
@inject HttpClient Http

<PageTitle>Enterprise - C-Sweet</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="page-stack enterprise-page">
    <header class="enterprise-header">
        <div>
            <MudText Typo="Typo.overline">Enterprise</MudText>
            <MudText Typo="Typo.h2">All your businesses, one clear view.</MudText>
            <MudText Typo="Typo.h6" Color="Color.Secondary">
                Choose where to focus, or manage the businesses that make up your enterprise.
            </MudText>
        </div>
        <img class="enterprise-logo" src="images/icon.svg" alt="" />
    </header>

    <Organizations CreateRequested="@CreateRequested" />

    <MudPaper Elevation="1" Class="surface-panel enterprise-status">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="3">
            <div>
                <MudText Typo="Typo.subtitle1">Platform status</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">API connectivity</MudText>
            </div>
            <MudChip T="string" Color="@ApiStatusColor" Variant="Variant.Filled">@ApiStatusLabel</MudChip>
        </MudStack>
        @if (_apiStatus == false)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-4">
                The API service cannot be reached. Check that the backend is running and try again.
            </MudAlert>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "create")]
    public bool CreateRequested { get; set; }

    private bool? _apiStatus;
    private string ApiStatusLabel => _apiStatus switch { true => "Connected", false => "Disconnected", _ => "Checking..." };
    private Color ApiStatusColor => _apiStatus switch { true => Color.Success, false => Color.Error, _ => Color.Default };

    protected override async Task OnInitializedAsync()
    {
        try { _apiStatus = (await Http.GetAsync("api/health")).IsSuccessStatusCode; }
        catch { _apiStatus = false; }
    }
}

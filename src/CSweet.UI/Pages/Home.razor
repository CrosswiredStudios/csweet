@page "/"
@inject HttpClient Http

<PageTitle>C-Sweet</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="page-stack">
    <MudStack Spacing="4" AlignItems="AlignItems.Center" Class="home-hero">
        <MudText Typo="Typo.h2" Align="Align.Center">C-Sweet</MudText>
        <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Secondary">
            Executive Operating System for Small Businesses
        </MudText>

        <MudPaper Elevation="1" Class="surface-panel home-status">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="3">
                <div>
                    <MudText Typo="Typo.subtitle1">Environment Status</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">API Connectivity</MudText>
                </div>
                <MudChip T="string" Color="@ApiStatusColor" Variant="Variant.Filled">@ApiStatusLabel</MudChip>
            </MudStack>
        </MudPaper>

        @if (_apiStatus == false)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                Unable to reach the API service. Ensure the backend is running and accessible.
            </MudAlert>
        }

        <MudButton Href="/configuration"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Settings">
            Configuration
        </MudButton>
    </MudStack>
</MudContainer>

@code {
    private bool? _apiStatus;

    private string ApiStatusLabel => _apiStatus switch
    {
        true => "Connected",
        false => "Disconnected",
        _ => "Checking..."
    };

    private Color ApiStatusColor => _apiStatus switch
    {
        true => Color.Success,
        false => Color.Error,
        _ => Color.Default
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/health");
            _apiStatus = response.IsSuccessStatusCode;
        }
        catch
        {
            _apiStatus = false;
        }
    }
}

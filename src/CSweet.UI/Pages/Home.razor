@page "/"
@inject HttpClient Http

<PageTitle>C-Sweet</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4 mb-3">C-Sweet</h1>
            <p class="lead text-muted mb-4">Executive Operating System for Small Businesses</p>

            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Environment Status</h5>
                    <p class="mb-0">
                        <strong>API Connectivity:</strong>
                        @if (_apiStatus == null)
                        {
                            <span class="badge bg-secondary">Checking...</span>
                        }
                        else if (_apiStatus.Value)
                        {
                            <span class="badge bg-success">Connected</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Disconnected</span>
                        }
                    </p>
                </div>
            </div>

            @if (_apiStatus == false)
            {
                <div class="alert alert-warning" role="alert">
                    Unable to reach the API service. Ensure the backend is running and accessible.
                </div>
            }

            <a href="/setup" class="btn btn-primary btn-lg">Setup Wizard</a>
        </div>
    </div>
</div>

@code {
    private bool? _apiStatus;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/health");
            _apiStatus = response.IsSuccessStatusCode;
        }
        catch
        {
            _apiStatus = false;
        }
    }
}

@page "/not-found"
@layout MainLayout

<MudContainer MaxWidth="MaxWidth.Small" Class="page-stack">
    <MudPaper Elevation="1" Class="surface-panel">
        <MudStack Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h4">Not Found</MudText>
            <MudText Color="Color.Secondary">Sorry, the content you are looking for does not exist.</MudText>
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Home">
                Home
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

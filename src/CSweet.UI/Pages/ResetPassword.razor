@page "/reset-password"
@layout AnonymousLayout
@using System.ComponentModel.DataAnnotations
@using CSweet.Contracts.Auth
@inject IAuthenticationApiClient AuthenticationApi
@inject NavigationManager Navigation

<PageTitle>Reset password - C-Sweet</PageTitle>

<MudPaper Elevation="0" Class="auth-card">
    <MudText Typo="Typo.h4">Choose a new password</MudText>
    <EditForm Model="_model" OnValidSubmit="ResetAsync" Class="auth-form">
        <DataAnnotationsValidator />
        <MudTextField Label="New password" InputType="InputType.Password" @bind-Value="_model.Password" For="@(() => _model.Password)" Variant="Variant.Outlined" Required="true" />
        <MudTextField Label="Confirm new password" InputType="InputType.Password" @bind-Value="_model.ConfirmPassword" For="@(() => _model.ConfirmPassword)" Variant="Variant.Outlined" Required="true" />
        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_message</MudAlert>
        }
        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">Reset password</MudButton>
    </EditForm>
</MudPaper>

@code {
    [SupplyParameterFromQuery] public Guid UserId { get; set; }
    [SupplyParameterFromQuery] public string? Code { get; set; }
    private readonly ResetModel _model = new();
    private string? _message;
    private async Task ResetAsync()
    {
        if (UserId == Guid.Empty || string.IsNullOrWhiteSpace(Code))
        {
            _message = "The password reset link is invalid or expired.";
            return;
        }
        var result = await AuthenticationApi.ResetPasswordAsync(new ResetPasswordRequest(UserId, Code, _model.Password, _model.ConfirmPassword));
        if (result.Succeeded) Navigation.NavigateTo("/login");
        else _message = string.Join(" ", result.ValidationErrors?.SelectMany(x => x.Value) ?? [result.Message]);
    }
    private sealed class ResetModel
    {
        [Required] public string Password { get; set; } = string.Empty;
        [Required] public string ConfirmPassword { get; set; } = string.Empty;
    }
}

@page "/agents"
@using System.Text.Json
@using CSweet.Contracts.Agents
@using CSweet.Contracts.Llm
@using CSweet.Contracts.Setup
@inject IAgentApiClient AgentApi
@inject ILlmProviderApiClient LlmProviderApi
@inject IAgentRuntimeSettingsApiClient AgentRuntimeSettingsApi

<PageTitle>Agents - C-Sweet</PageTitle>

<div class="setup-shell agents-page">
    <MudPaper Elevation="0" Class="page-header">
        <div>
            <MudText Typo="Typo.overline" Color="Color.Primary">Agent management</MudText>
            <MudText Typo="Typo.h3">Agents</MudText>
            <MudText Color="Color.Secondary">Review installed agents and edit only the settings exposed by each running agent.</MudText>
        </div>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isBusy" OnClick="OpenImportDialog" StartIcon="@Icons.Material.Filled.Add">
                Import Agent
            </MudButton>
            <MudTooltip Text="Refresh agents">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Secondary" Disabled="@_isBusy" OnClick="LoadAsync" />
            </MudTooltip>
        </MudStack>
    </MudPaper>

    @if (_usageSummary is not null)
    {
        <section class="usage-summary-grid" aria-label="Agent token usage">
            @UsageCard("Last 24 Hours", _usageSummary.Last24Hours)
            @UsageCard("Last 7 Days", _usageSummary.Last7Days)
            @UsageCard("Last 30 Days", _usageSummary.Last30Days)
        </section>
    }

    @if (_isLoading)
    {
        <MudPaper Elevation="1" Class="surface-panel surface-panel-narrow agents-loading-panel">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Color="Color.Secondary">Loading agents...</MudText>
        </MudPaper>
    }
    else if (!string.IsNullOrWhiteSpace(_pageError))
    {
        <MudPaper Elevation="1" Class="surface-panel surface-panel-narrow">
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_pageError</MudAlert>
            <MudStack Row="true" Class="setup-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync">Retry</MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <section class="agent-installations-section" aria-label="Unified agent fleet">
            <div class="configuration-section-header">
                <div>
                    <MudText Typo="Typo.h6">Agent Fleet</MudText>
                    <MudText Color="Color.Secondary">First-party agents and imported installations in one operational view.</MudText>
                </div>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@(_installations.Count + _agents.Count)</MudChip>
            </div>

            @if (!string.IsNullOrWhiteSpace(_installationActionMessage))
            {
                <MudAlert Severity="@(_installationActionSucceeded ? Severity.Success : Severity.Error)" Variant="Variant.Outlined">
                    @_installationActionMessage
                </MudAlert>
            }

            @if (_installations.Count == 0 && _agents.Count == 0)
            {
                <MudText Color="Color.Secondary">No agents have been installed.</MudText>
            }
            else
            {
                <div class="agent-installations-grid">
                    @foreach (var agent in _agents)
                    {
                        <MudPaper Elevation="1" Class="agent-installation-card">
                            <div class="configuration-section-header">
                                <div>
                                    <MudText Typo="Typo.subtitle1">@agent.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@agent.Id · @agent.PublisherName</MudText>
                                </div>
                                <MudStack Row="true" Spacing="1">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Installed</MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">First-party</MudChip>
                                </MudStack>
                            </div>
                            <dl class="configuration-details agents-details">
                                <div><dt>Version</dt><dd>@agent.Version</dd></div>
                                <div><dt>Runtime</dt><dd>@agent.RuntimeType</dd></div>
                                <div><dt>Capabilities</dt><dd>@agent.Capabilities.Count</dd></div>
                                <div><dt>Configuration</dt><dd>Broker-managed</dd></div>
                            </dl>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => SelectAgentAsync(agent))">Configure</MudButton>
                        </MudPaper>
                    }
                    @foreach (var installation in _installations)
                    {
                        <MudPaper Elevation="1" Class="agent-installation-card">
                            <div class="configuration-section-header">
                                <div>
                                    <MudText Typo="Typo.subtitle1">@installation.AgentName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@installation.AgentId · @installation.BusinessId</MudText>
                                </div>
                                <MudStack Row="true" Spacing="1" Class="agent-status-chips">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Installed</MudChip>
                                    @if (installation.Build is not null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="@BuildStatusColor(installation.Build.Status)" Variant="Variant.Filled">@BuildStatusLabel(installation.Build.Status)</MudChip>
                                    }
                                    @if (IsRuntimeActive(installation.LatestRuntime?.Status))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">Running</MudChip>
                                    }
                                    else if (installation.IsEnabled && installation.Schedule.IsEnabled)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Scheduled</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Filled">Disabled</MudChip>
                                    }
                                </MudStack>
                            </div>
                            <dl class="configuration-details agents-details">
                                <div><dt>Activation</dt><dd>@installation.Schedule.ActivationMode</dd></div>
                                <div><dt>Frequency</dt><dd>@FormatFrequency(installation.Schedule.TickFrequencySeconds)</dd></div>
                                <div><dt>Next tick</dt><dd>@FormatNextTick(installation.Schedule.NextTickAt)</dd></div>
                                <div><dt>Last run</dt><dd>@FormatLastRun(installation.LatestRuntime)</dd></div>
                                <div><dt>Runtime limit</dt><dd>@installation.Schedule.MaxRuntimeSeconds s</dd></div>
                                <div><dt>Memory</dt><dd>@installation.MemoryMb MB</dd></div>
                                <div><dt>CPU</dt><dd>@installation.CpuPercent%</dd></div>
                            </dl>
                            <MudStack Row="true" Class="setup-actions">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.EditCalendar" Disabled="@_isManagingInstallation" OnClick="@(() => OpenScheduleDialog(installation))">
                                    Edit Schedule
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PlayArrow" Disabled="@(_isManagingInstallation || !installation.IsEnabled || !installation.Schedule.IsEnabled)" OnClick="@(() => RunNowAsync(installation))">
                                    Run Now
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.History" Disabled="@(_isManagingInstallation || installation.LatestRuntime is null)" OnClick="@(() => OpenRunsDialogAsync(installation))">View Runs</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Description" Disabled="@(_isManagingInstallation || installation.Build?.HasLog != true)" OnClick="@(() => OpenBuildLogDialogAsync(installation))">View Build Log</MudButton>
                                @if (installation.IsEnabled)
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.Block" Disabled="@_isManagingInstallation" OnClick="@(() => DisableInstallationAsync(installation))">Disable</MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Success" StartIcon="@Icons.Material.Filled.CheckCircle" Disabled="@_isManagingInstallation" OnClick="@(() => EnableInstallationAsync(installation))">Enable</MudButton>
                                }
                            </MudStack>
                        </MudPaper>
                    }
                </div>
            }
        </section>

        <section class="agents-grid">
            <MudPaper Elevation="1" Class="surface-panel agents-list-panel">
                <div class="configuration-section-header">
                    <div>
                        <MudText Typo="Typo.h6">First-party Configuration</MudText>
                        <MudText Color="Color.Secondary">Select a first-party agent to edit its exposed configuration schema.</MudText>
                    </div>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@_agents.Count</MudChip>
                </div>

                @if (_agents.Count == 0)
                {
                    <MudText Color="Color.Secondary">No installed agent manifests were found.</MudText>
                }
                else
                {
                    <div class="agents-list">
                        @foreach (var agent in _agents)
                        {
                            <MudButton Class="@AgentButtonClass(agent)"
                                       Variant="Variant.Text"
                                       Disabled="@_isBusy"
                                       OnClick="@(() => SelectAgentAsync(agent))">
                                <div class="agent-list-item-content">
                                    <div>
                                        <MudText Typo="Typo.subtitle1">@agent.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@agent.PublisherName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatUsageCaption(AgentUsage(agent.Id)?.Usage)</MudText>
                                    </div>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@($"v{agent.Version}")</MudChip>
                                </div>
                            </MudButton>
                        }
                    </div>
                }
            </MudPaper>

            <MudPaper Elevation="1" Class="surface-panel agents-editor-panel">
                @if (_selectedAgent is null)
                {
                    <div class="agents-empty-editor">
                        <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Large" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Select an agent</MudText>
                        <MudText Color="Color.Secondary">Configuration fields are requested from the running agent binary when you open it.</MudText>
                    </div>
                }
                else
                {
                    <div class="configuration-section-header">
                        <div>
                            <MudText Typo="Typo.h6">@_selectedAgent.Name</MudText>
                            <MudText Color="Color.Secondary">@_selectedAgent.Id</MudText>
                        </div>
                        <MudChip T="string" Color="@SchemaChipColor" Variant="Variant.Filled">@SchemaChipLabel</MudChip>
                    </div>

                    <dl class="configuration-details agents-details">
                        <div>
                            <dt>Publisher</dt>
                            <dd>@_selectedAgent.PublisherName</dd>
                        </div>
                        <div>
                            <dt>Runtime</dt>
                            <dd>@_selectedAgent.RuntimeType</dd>
                        </div>
                        <div>
                            <dt>Capabilities</dt>
                            <dd>@_selectedAgent.Capabilities.Count</dd>
                        </div>
                        <div>
                            <dt>Permissions</dt>
                            <dd>@_selectedAgent.RequestedPermissions.Count</dd>
                        </div>
                        <div>
                            <dt>30d input</dt>
                            <dd>@FormatTokens(SelectedAgentUsage?.Usage.InputTokens ?? 0)</dd>
                        </div>
                        <div>
                            <dt>30d output</dt>
                            <dd>@FormatTokens(SelectedAgentUsage?.Usage.OutputTokens ?? 0)</dd>
                        </div>
                        <div>
                            <dt>30d requests</dt>
                            <dd>@((SelectedAgentUsage?.Usage.RequestCount ?? 0).ToString("N0"))</dd>
                        </div>
                    </dl>

                    @if (_isLoadingConfiguration)
                    {
                        <div class="agents-loading-panel mt-4">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Color="Color.Secondary">Asking agent for supported settings...</MudText>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_configurationError))
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mt-4">@_configurationError</MudAlert>
                        <MudStack Row="true" Class="setup-actions">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@_isBusy" OnClick="@(() => LoadConfigurationAsync(_selectedAgent))">
                                Try again
                            </MudButton>
                        </MudStack>
                    }
                    else if (_schema is not null)
                    {
                        <MudText Color="Color.Secondary" Class="mt-4">Schema @_schema.SchemaVersion exposed by @_schema.AgentVersion.</MudText>

                        <div class="agent-config-form">
                            @foreach (var field in _schema.Fields)
                            {
                                <div class="agent-config-field">
                                    @switch (field.Type)
                                    {
                                        case AgentConfigurationFieldTypes.Boolean:
                                            <MudCheckBox T="bool"
                                                         Label="@field.Label"
                                                         Value="@GetBooleanValue(field.Key)"
                                                         ValueChanged="@((bool value) => SetFormValue(field.Key, value))" />
                                            break;

                                        case AgentConfigurationFieldTypes.Number:
                                            <MudNumericField T="decimal?"
                                                             Label="@field.Label"
                                                             Value="@GetNumberValue(field.Key)"
                                                             ValueChanged="@((decimal? value) => SetFormValue(field.Key, value))"
                                                             Min="@field.Minimum"
                                                             Max="@field.Maximum"
                                                             Step="@(field.Step ?? 1)"
                                                             Variant="Variant.Outlined" />
                                            break;

                                        case AgentConfigurationFieldTypes.Select:
                                            <MudSelect T="string"
                                                       Label="@field.Label"
                                                       Value="@GetStringValue(field.Key)"
                                                       ValueChanged="@((string value) => SetFormValue(field.Key, value))"
                                                       Variant="Variant.Outlined">
                                                @foreach (var option in field.Options ?? [])
                                                {
                                                    <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
                                                }
                                            </MudSelect>
                                            break;

                                        case AgentConfigurationFieldTypes.LlmProvider:
                                            <MudSelect T="string"
                                                       Label="@field.Label"
                                                       Value="@GetStringValue(field.Key)"
                                                       ValueChanged="@((string value) => SetProviderValue(field.Key, value))"
                                                       Variant="Variant.Outlined">
                                                <MudSelectItem T="string" Value="@string.Empty">Select a provider</MudSelectItem>
                                                @foreach (var profile in _providerProfiles.Where(profile => profile.IsEnabled))
                                                {
                                                    <MudSelectItem T="string" Value="@profile.Id.ToString()">@profile.Name</MudSelectItem>
                                                }
                                            </MudSelect>
                                            break;

                                        case AgentConfigurationFieldTypes.LlmModel:
                                            <MudSelect T="string"
                                                       Label="@field.Label"
                                                       Value="@GetStringValue(field.Key)"
                                                       ValueChanged="@((string value) => SetFormValue(field.Key, value))"
                                                       Disabled="@IsModelPickerDisabled(field)"
                                                       Variant="Variant.Outlined">
                                                <MudSelectItem T="string" Value="@string.Empty">@ModelPlaceholder(field)</MudSelectItem>
                                                @if (SelectedModelMissing(field))
                                                {
                                                    <MudSelectItem T="string" Value="@GetStringValue(field.Key)">@GetStringValue(field.Key)</MudSelectItem>
                                                }
                                                @foreach (var model in ModelOptions(field))
                                                {
                                                    <MudSelectItem T="string" Value="@model">@model</MudSelectItem>
                                                }
                                            </MudSelect>
                                            break;

                                        case AgentConfigurationFieldTypes.Secret:
                                            <MudTextField Label="@field.Label"
                                                          Value="@GetStringValue(field.Key)"
                                                          ValueChanged="@((string value) => SetFormValue(field.Key, value))"
                                                          InputType="InputType.Password"
                                                          autocomplete="off"
                                                          Placeholder="@field.Placeholder"
                                                          Variant="Variant.Outlined" />
                                            break;

                                        case AgentConfigurationFieldTypes.TextArea:
                                            <MudTextField Label="@field.Label"
                                                          Value="@GetStringValue(field.Key)"
                                                          ValueChanged="@((string value) => SetFormValue(field.Key, value))"
                                                          Lines="4"
                                                          Placeholder="@field.Placeholder"
                                                          Variant="Variant.Outlined" />
                                            break;

                                        default:
                                            <MudTextField Label="@field.Label"
                                                          Value="@GetStringValue(field.Key)"
                                                          ValueChanged="@((string value) => SetFormValue(field.Key, value))"
                                                          Placeholder="@field.Placeholder"
                                                          Variant="Variant.Outlined" />
                                            break;
                                    }

                                    @if (!string.IsNullOrWhiteSpace(field.Description))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@field.Description</MudText>
                                    }
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_actionMessage))
                        {
                            <MudAlert Severity="@ActionMessageSeverity" Variant="Variant.Outlined" Class="mt-4">@_actionMessage</MudAlert>
                        }

                        <MudStack Row="true" Class="setup-actions">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@_isBusy"
                                       OnClick="SaveConfigurationAsync">
                                @(_isBusy ? "Saving..." : "Save Settings")
                            </MudButton>
                        </MudStack>
                    }
                }
            </MudPaper>
        </section>
    }
</div>

<MudDialog @bind-Visible="_importDialogOpen" Options="_importDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Import Agent</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField Label="Public GitHub repository URL"
                          @bind-Value="_importRepositoryUrl"
                          Placeholder="https://github.com/owner/repository"
                          Variant="Variant.Outlined"
                          Disabled="@(_isPreviewingImport || _isInstallingImport || _importPreview is not null)"
                          Immediate="true" />
            <MudTextField Label="Branch, tag, or commit (optional)"
                          @bind-Value="_importRef"
                          Placeholder="Default branch"
                          Variant="Variant.Outlined"
                          Disabled="@(_isPreviewingImport || _isInstallingImport || _importPreview is not null)" />

            @if (!string.IsNullOrWhiteSpace(_importError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_importError</MudAlert>
            }

            @if (_importPreview is not null)
            {
                <div class="agent-import-summary">
                    <dl class="configuration-details agents-details">
                        <div><dt>Name</dt><dd>@_importPreview.AgentName</dd></div>
                        <div><dt>Agent ID</dt><dd>@_importPreview.AgentId</dd></div>
                        <div><dt>Version</dt><dd>@_importPreview.AgentVersion</dd></div>
                        <div><dt>Publisher</dt><dd>@_importPreview.PublisherName (@_importPreview.PublisherId)</dd></div>
                        <div><dt>Runtime</dt><dd>@_importPreview.RuntimeType</dd></div>
                        <div><dt>Project</dt><dd>@DisplayImportValue(_importPreview.ProjectPath)</dd></div>
                        <div><dt>Framework</dt><dd>@DisplayImportValue(_importPreview.TargetFramework)</dd></div>
                        <div><dt>Activation</dt><dd>@DisplayImportValue(_importPreview.DefaultActivationMode)</dd></div>
                        <div><dt>Commit</dt><dd class="agent-import-hash">@_importPreview.CommitSha</dd></div>
                        <div><dt>Manifest digest</dt><dd class="agent-import-hash">@_importPreview.ManifestDigest</dd></div>
                    </dl>

                    @ImportValueSection("Capabilities", _importPreview.Capabilities)
                    @ImportValueSection("Subscriptions", _importPreview.RequestedSubscriptions)
                    @ImportValueSection("Publications", _importPreview.RequestedPublications)
                    @ImportValueSection("Requested permissions", _importPreview.RequestedPermissions)
                    @ImportValueSection("Requested network access", _importPreview.RequestedNetworkAccess)

                    @if (_importPreview.Warnings.Count > 0)
                    {
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">Warnings</MudText>
                            @foreach (var warning in _importPreview.Warnings)
                            {
                                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">@warning.Message</MudAlert>
                            }
                        </MudStack>
                    }

                    <MudDivider />
                    <MudText Typo="Typo.subtitle1">Approval and Schedule</MudText>
                    <div class="setup-form-grid">
                        <MudTextField Label="Business ID" @bind-Value="_installBusinessId" Variant="Variant.Outlined" Disabled="@_isInstallingImport" />
                        <MudSelect T="string" Label="Activation mode" @bind-Value="_installActivationMode" Variant="Variant.Outlined" Disabled="@_isInstallingImport">
                            <MudSelectItem T="string" Value="@("AlwaysOn")">Always On</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Periodic")">Periodic</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Manual")">Manual</MudSelectItem>
                        </MudSelect>
                        <MudNumericField T="int" Label="Tick frequency (seconds)" @bind-Value="_installTickFrequencySeconds" Min="@(_runtimeSettings?.MinimumTickFrequencySeconds ?? 60)" Variant="Variant.Outlined" Disabled="@_isInstallingImport" />
                        <MudSelect T="string" Label="Overlap policy" @bind-Value="_installOverlapPolicy" Variant="Variant.Outlined" Disabled="@_isInstallingImport">
                            <MudSelectItem T="string" Value="@("Skip")">Skip</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Queue")">Queue</MudSelectItem>
                            <MudSelectItem T="string" Value="@("CancelPrevious")">Cancel Previous</MudSelectItem>
                        </MudSelect>
                        <MudNumericField T="int" Label="Max runtime (seconds)" @bind-Value="_installMaxRuntimeSeconds" Min="1" Max="@(_runtimeSettings?.DefaultMaxRuntimeSeconds ?? int.MaxValue)" Variant="Variant.Outlined" Disabled="@_isInstallingImport" />
                        <MudNumericField T="int" Label="Memory (MB)" @bind-Value="_installMemoryMb" Min="1" Max="@(_runtimeSettings?.MaximumContainerMemoryMb ?? int.MaxValue)" Variant="Variant.Outlined" Disabled="@_isInstallingImport" />
                        <MudNumericField T="int" Label="CPU (%)" @bind-Value="_installCpuPercent" Min="1" Max="@(_runtimeSettings?.MaximumContainerCpuPercent ?? int.MaxValue)" Variant="Variant.Outlined" Disabled="@_isInstallingImport" />
                    </div>

                    @ApprovalSection("Capabilities", _importPreview.Capabilities, _approvedCapabilities)
                    @ApprovalSection("Subscriptions", _importPreview.RequestedSubscriptions, _approvedSubscriptions)
                    @ApprovalSection("Publications", _importPreview.RequestedPublications, _approvedPublications)
                    @ApprovalSection("Permissions", _importPreview.RequestedPermissions, _approvedPermissions)
                    @ApprovalSection("Network access", _importPreview.RequestedNetworkAccess, _approvedNetworkAccess)
                </div>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Secondary" Disabled="@(_isPreviewingImport || _isInstallingImport)" OnClick="CloseImportDialog">
            Close
        </MudButton>
        @if (_importPreview is null)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(_isPreviewingImport || string.IsNullOrWhiteSpace(_importRepositoryUrl))"
                       OnClick="PreviewImportAsync">
                @(_isPreviewingImport ? "Previewing..." : "Preview Manifest")
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Text" Color="Color.Secondary" Disabled="@_isInstallingImport" OnClick="ResetImportPreview">
                Back
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isInstallingImport" OnClick="InstallImportAsync" StartIcon="@Icons.Material.Filled.VerifiedUser">
                @(_isInstallingImport ? "Installing..." : "Approve and Install")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_scheduleDialogOpen" Options="_scheduleDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Schedule</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Color="Color.Secondary">@_scheduleInstallation?.AgentName</MudText>
            <MudSelect T="string" Label="Activation mode" @bind-Value="_scheduleActivationMode" Variant="Variant.Outlined" Disabled="@_isManagingInstallation">
                <MudSelectItem T="string" Value="@("AlwaysOn")">Always On</MudSelectItem>
                <MudSelectItem T="string" Value="@("Periodic")">Periodic</MudSelectItem>
                <MudSelectItem T="string" Value="@("Manual")">Manual</MudSelectItem>
            </MudSelect>
            <MudNumericField T="int" Label="Tick frequency (seconds)" @bind-Value="_scheduleTickFrequencySeconds" Min="@(_runtimeSettings?.MinimumTickFrequencySeconds ?? 60)" Variant="Variant.Outlined" Disabled="@_isManagingInstallation" />
            <MudSelect T="string" Label="Overlap policy" @bind-Value="_scheduleOverlapPolicy" Variant="Variant.Outlined" Disabled="@_isManagingInstallation">
                <MudSelectItem T="string" Value="@("Skip")">Skip</MudSelectItem>
                <MudSelectItem T="string" Value="@("Queue")">Queue</MudSelectItem>
                <MudSelectItem T="string" Value="@("CancelPrevious")">Cancel Previous</MudSelectItem>
            </MudSelect>
            <MudNumericField T="int" Label="Max runtime (seconds)" @bind-Value="_scheduleMaxRuntimeSeconds" Min="1" Max="@(_runtimeSettings?.DefaultMaxRuntimeSeconds ?? int.MaxValue)" Variant="Variant.Outlined" Disabled="@_isManagingInstallation" />
            <MudCheckBox T="bool" Label="Schedule enabled" @bind-Value="_scheduleEnabled" Disabled="@_isManagingInstallation" />
            @if (!string.IsNullOrWhiteSpace(_scheduleError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_scheduleError</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Disabled="@_isManagingInstallation" OnClick="CloseScheduleDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isManagingInstallation" OnClick="SaveScheduleAsync">
            @(_isManagingInstallation ? "Saving..." : "Save Schedule")
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_runsDialogOpen" Options="_managementDialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Runtime History · @_runsInstallation?.AgentName</MudText></TitleContent>
    <DialogContent>
        @if (_isLoadingManagementDetail)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
        else if (!string.IsNullOrWhiteSpace(_managementDetailError))
        {
            <MudAlert Severity="Severity.Error">@_managementDetailError</MudAlert>
        }
        else if (_runtimeRuns.Count == 0)
        {
            <MudText Color="Color.Secondary">No runtime instances have been recorded.</MudText>
        }
        else
        {
            <MudExpansionPanels>
                @foreach (var run in _runtimeRuns)
                {
                    <MudExpansionPanel Text="@($"{run.Status} · {run.QueuedAt.ToLocalTime():g}")">
                        <dl class="configuration-details agents-details">
                            <div><dt>Tick</dt><dd>@run.TickId</dd></div>
                            <div><dt>Started</dt><dd>@FormatTimestamp(run.StartedAt)</dd></div>
                            <div><dt>Completed</dt><dd>@FormatTimestamp(run.CompletedAt)</dd></div>
                            <div><dt>Result</dt><dd>@(run.Reason ?? run.Status)</dd></div>
                        </dl>
                        @foreach (var runtimeEvent in run.Events)
                        {
                            <MudText Typo="Typo.caption"><strong>@runtimeEvent.Status</strong> · @runtimeEvent.OccurredAt.ToLocalTime().ToString("g") · @(runtimeEvent.Reason ?? "No detail")</MudText>
                        }
                        @if (!string.IsNullOrWhiteSpace(run.LogExcerpt))
                        {
                            <MudText Typo="Typo.subtitle2" Class="mt-3">Container log excerpt</MudText>
                            <pre class="agent-build-log">@run.LogExcerpt</pre>
                        }
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    </DialogContent>
    <DialogActions><MudButton Variant="Variant.Text" OnClick="CloseRunsDialog">Close</MudButton></DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_buildLogDialogOpen" Options="_managementDialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Build Log · @_buildLogInstallation?.AgentName</MudText></TitleContent>
    <DialogContent>
        @if (_isLoadingManagementDetail)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
        else if (!string.IsNullOrWhiteSpace(_managementDetailError))
        {
            <MudAlert Severity="Severity.Error">@_managementDetailError</MudAlert>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">Status: @_buildLog?.Status @(_buildLog?.IsTruncated == true ? "· truncated" : string.Empty)</MudText>
            <pre class="agent-build-log">@(_buildLog?.Content ?? "No build output was retained.")</pre>
        }
    </DialogContent>
    <DialogActions><MudButton Variant="Variant.Text" OnClick="CloseBuildLogDialog">Close</MudButton></DialogActions>
</MudDialog>

@code {
    private static readonly JsonSerializerOptions SerializerOptions = new(JsonSerializerDefaults.Web);

    private IReadOnlyList<AgentCatalogItemResponse> _agents = [];
    private IReadOnlyList<AgentInstallationResponse> _installations = [];
    private IReadOnlyList<LlmProviderProfileResponse> _providerProfiles = [];
    private AgentRuntimeSettingsResponse? _runtimeSettings;
    private LlmTokenUsageSummaryResponse? _usageSummary;
    private AgentCatalogItemResponse? _selectedAgent;
    private AgentConfigurationSchemaResponse? _schema;
    private readonly Dictionary<string, object?> _formValues = new(StringComparer.Ordinal);
    private bool _isLoading = true;
    private bool _isLoadingConfiguration;
    private bool _isBusy;
    private bool _isManagingInstallation;
    private string? _pageError;
    private string? _installationActionMessage;
    private bool _installationActionSucceeded;
    private string? _configurationError;
    private string? _actionMessage;
    private bool? _actionSucceeded;
    private readonly DialogOptions _importDialogOptions = new() { MaxWidth = MaxWidth.Large, FullWidth = true };
    private bool _importDialogOpen;
    private bool _isPreviewingImport;
    private bool _isInstallingImport;
    private string _importRepositoryUrl = string.Empty;
    private string _importRef = string.Empty;
    private string? _importError;
    private AgentImportPreviewResponse? _importPreview;
    private string _installBusinessId = "default";
    private string _installActivationMode = "Periodic";
    private int _installTickFrequencySeconds = 3600;
    private string _installOverlapPolicy = "Skip";
    private int _installMaxRuntimeSeconds = 600;
    private int _installMemoryMb = 512;
    private int _installCpuPercent = 50;
    private readonly HashSet<string> _approvedCapabilities = new(StringComparer.Ordinal);
    private readonly HashSet<string> _approvedSubscriptions = new(StringComparer.Ordinal);
    private readonly HashSet<string> _approvedPublications = new(StringComparer.Ordinal);
    private readonly HashSet<string> _approvedPermissions = new(StringComparer.Ordinal);
    private readonly HashSet<string> _approvedNetworkAccess = new(StringComparer.Ordinal);
    private readonly DialogOptions _scheduleDialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private bool _scheduleDialogOpen;
    private AgentInstallationResponse? _scheduleInstallation;
    private string _scheduleActivationMode = "Periodic";
    private int _scheduleTickFrequencySeconds = 3600;
    private string _scheduleOverlapPolicy = "Skip";
    private int _scheduleMaxRuntimeSeconds = 600;
    private bool _scheduleEnabled = true;
    private string? _scheduleError;
    private readonly DialogOptions _managementDialogOptions = new() { MaxWidth = MaxWidth.Large, FullWidth = true };
    private bool _runsDialogOpen;
    private AgentInstallationResponse? _runsInstallation;
    private IReadOnlyList<AgentRuntimeRunResponse> _runtimeRuns = [];
    private bool _buildLogDialogOpen;
    private AgentInstallationResponse? _buildLogInstallation;
    private AgentBuildLogResponse? _buildLog;
    private bool _isLoadingManagementDetail;
    private string? _managementDetailError;

    private string SchemaChipLabel => _schema is null ? "Offline" : "Configurable";
    private Color SchemaChipColor => _schema is null ? Color.Warning : Color.Success;
    private Severity ActionMessageSeverity => _actionSucceeded == false ? Severity.Error : Severity.Success;
    private AgentTokenUsageResponse? SelectedAgentUsage =>
        _selectedAgent is null ? null : AgentUsage(_selectedAgent.Id);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _pageError = null;

        try
        {
            var agentsTask = AgentApi.ListAsync();
            var installationsTask = AgentApi.ListInstallationsAsync();
            var providersTask = LlmProviderApi.ListAsync();
            var usageTask = LlmProviderApi.GetUsageSummaryAsync();
            var runtimeSettingsTask = AgentRuntimeSettingsApi.GetAsync();

            await Task.WhenAll(agentsTask, installationsTask, providersTask, usageTask, runtimeSettingsTask);

            _agents = await agentsTask;
            _installations = await installationsTask;
            _providerProfiles = await providersTask;
            _usageSummary = await usageTask;
            _runtimeSettings = await runtimeSettingsTask;
            if (_selectedAgent is not null)
            {
                _selectedAgent = _agents.FirstOrDefault(agent => agent.Id == _selectedAgent.Id);
            }
        }
        catch
        {
            _pageError = "Unable to load agents from the API.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectAgentAsync(AgentCatalogItemResponse agent)
    {
        _selectedAgent = agent;
        await LoadConfigurationAsync(agent);
    }

    private void OpenImportDialog()
    {
        _importRepositoryUrl = string.Empty;
        _importRef = string.Empty;
        _importError = null;
        _importPreview = null;
        ClearImportApproval();
        _importDialogOpen = true;
    }

    private void CloseImportDialog()
    {
        _importDialogOpen = false;
    }

    private async Task PreviewImportAsync()
    {
        _isPreviewingImport = true;
        _importError = null;
        _importPreview = null;

        try
        {
            _importPreview = await AgentApi.PreviewImportAsync(new PreviewAgentImportRequest(
                _importRepositoryUrl.Trim(),
                string.IsNullOrWhiteSpace(_importRef) ? null : _importRef.Trim()));
            InitializeImportApproval(_importPreview);
        }
        catch (Exception exception)
        {
            _importError = exception.Message;
        }
        finally
        {
            _isPreviewingImport = false;
        }
    }

    private void ResetImportPreview()
    {
        _importPreview = null;
        _importError = null;
        ClearImportApproval();
    }

    private void InitializeImportApproval(AgentImportPreviewResponse preview)
    {
        _installBusinessId = "default";
        _installActivationMode = preview.DefaultActivationMode ?? _runtimeSettings?.DefaultActivationMode ?? "Periodic";
        _installTickFrequencySeconds = _runtimeSettings?.DefaultTickFrequencySeconds ?? 3600;
        _installOverlapPolicy = _runtimeSettings?.DefaultOverlapPolicy ?? "Skip";
        _installMaxRuntimeSeconds = _runtimeSettings?.DefaultMaxRuntimeSeconds ?? 600;
        _installMemoryMb = _runtimeSettings?.DefaultContainerMemoryMb ?? 512;
        _installCpuPercent = _runtimeSettings?.DefaultContainerCpuPercent ?? 50;
        ReplaceApproval(_approvedCapabilities, preview.Capabilities);
        ReplaceApproval(_approvedSubscriptions, preview.RequestedSubscriptions);
        ReplaceApproval(_approvedPublications, preview.RequestedPublications);
        ReplaceApproval(_approvedPermissions, preview.RequestedPermissions);
        ReplaceApproval(_approvedNetworkAccess, preview.RequestedNetworkAccess);
    }

    private async Task InstallImportAsync()
    {
        if (_importPreview is null)
        {
            return;
        }

        _isInstallingImport = true;
        _importError = null;
        try
        {
            var installation = await AgentApi.InstallAsync(
                _importPreview.ImportId,
                new InstallAgentRequest(
                    _installBusinessId.Trim(),
                    _installActivationMode,
                    _installTickFrequencySeconds,
                    _installOverlapPolicy,
                    _approvedCapabilities.ToList(),
                    _approvedSubscriptions.ToList(),
                    _approvedPublications.ToList(),
                    _approvedPermissions.ToList(),
                    _approvedNetworkAccess.ToList(),
                    _installMaxRuntimeSeconds,
                    _installMemoryMb,
                    _installCpuPercent));
            _installations = _installations.Append(installation).ToList();
            _importDialogOpen = false;
            SetInstallationMessage($"{installation.AgentName} installed.", true);
        }
        catch (Exception exception)
        {
            _importError = exception.Message;
        }
        finally
        {
            _isInstallingImport = false;
        }
    }

    private void ClearImportApproval()
    {
        _approvedCapabilities.Clear();
        _approvedSubscriptions.Clear();
        _approvedPublications.Clear();
        _approvedPermissions.Clear();
        _approvedNetworkAccess.Clear();
    }

    private static void ReplaceApproval(HashSet<string> target, IReadOnlyList<string> values)
    {
        target.Clear();
        target.UnionWith(values);
    }

    private static void SetApproval(HashSet<string> values, string value, bool approved)
    {
        if (approved)
        {
            values.Add(value);
        }
        else
        {
            values.Remove(value);
        }
    }

    private void OpenScheduleDialog(AgentInstallationResponse installation)
    {
        _scheduleInstallation = installation;
        _scheduleActivationMode = installation.Schedule.ActivationMode;
        _scheduleTickFrequencySeconds = installation.Schedule.TickFrequencySeconds;
        _scheduleOverlapPolicy = installation.Schedule.OverlapPolicy;
        _scheduleMaxRuntimeSeconds = installation.Schedule.MaxRuntimeSeconds;
        _scheduleEnabled = installation.Schedule.IsEnabled;
        _scheduleError = null;
        _scheduleDialogOpen = true;
    }

    private void CloseScheduleDialog()
    {
        _scheduleDialogOpen = false;
    }

    private async Task SaveScheduleAsync()
    {
        if (_scheduleInstallation is null)
        {
            return;
        }

        _isManagingInstallation = true;
        _scheduleError = null;
        try
        {
            var updated = await AgentApi.UpdateScheduleAsync(
                _scheduleInstallation.Id,
                new UpdateAgentScheduleRequest(
                    _scheduleActivationMode,
                    _scheduleTickFrequencySeconds,
                    _scheduleOverlapPolicy,
                    _scheduleMaxRuntimeSeconds,
                    _scheduleEnabled));
            ReplaceInstallation(updated);
            _scheduleDialogOpen = false;
            SetInstallationMessage("Schedule updated.", true);
        }
        catch (Exception exception)
        {
            _scheduleError = exception.Message;
        }
        finally
        {
            _isManagingInstallation = false;
        }
    }

    private async Task RunNowAsync(AgentInstallationResponse installation)
    {
        await ExecuteInstallationActionAsync(
            () => AgentApi.RunNowAsync(installation.Id),
            "Run requested. The scheduler will claim it when runtime execution is available.");
    }

    private async Task DisableInstallationAsync(AgentInstallationResponse installation)
    {
        await ExecuteInstallationActionAsync(
            () => AgentApi.DisableAsync(installation.Id),
            "Agent installation disabled.");
    }

    private async Task EnableInstallationAsync(AgentInstallationResponse installation)
    {
        await ExecuteInstallationActionAsync(
            () => AgentApi.EnableAsync(installation.Id),
            "Agent installation enabled.");
    }

    private async Task OpenRunsDialogAsync(AgentInstallationResponse installation)
    {
        _runsInstallation = installation;
        _runtimeRuns = [];
        _managementDetailError = null;
        _isLoadingManagementDetail = true;
        _runsDialogOpen = true;
        try { _runtimeRuns = await AgentApi.ListRunsAsync(installation.Id); }
        catch (Exception exception) { _managementDetailError = exception.Message; }
        finally { _isLoadingManagementDetail = false; }
    }

    private void CloseRunsDialog() => _runsDialogOpen = false;

    private async Task OpenBuildLogDialogAsync(AgentInstallationResponse installation)
    {
        _buildLogInstallation = installation;
        _buildLog = null;
        _managementDetailError = null;
        _isLoadingManagementDetail = true;
        _buildLogDialogOpen = true;
        try { _buildLog = await AgentApi.GetBuildLogAsync(installation.Id); }
        catch (Exception exception) { _managementDetailError = exception.Message; }
        finally { _isLoadingManagementDetail = false; }
    }

    private void CloseBuildLogDialog() => _buildLogDialogOpen = false;

    private async Task ExecuteInstallationActionAsync(
        Func<Task<AgentInstallationResponse>> action,
        string successMessage)
    {
        _isManagingInstallation = true;
        try
        {
            ReplaceInstallation(await action());
            SetInstallationMessage(successMessage, true);
        }
        catch (Exception exception)
        {
            SetInstallationMessage(exception.Message, false);
        }
        finally
        {
            _isManagingInstallation = false;
        }
    }

    private void ReplaceInstallation(AgentInstallationResponse installation)
    {
        _installations = _installations
            .Select(existing => existing.Id == installation.Id ? installation : existing)
            .ToList();
    }

    private void SetInstallationMessage(string message, bool succeeded)
    {
        _installationActionMessage = message;
        _installationActionSucceeded = succeeded;
    }

    private async Task LoadConfigurationAsync(AgentCatalogItemResponse agent)
    {
        _isLoadingConfiguration = true;
        _configurationError = null;
        _actionMessage = null;
        _schema = null;
        _formValues.Clear();

        try
        {
            _schema = await AgentApi.GetConfigurationAsync(agent.Id);
            HydrateFormValues(_schema);
        }
        catch (Exception ex)
        {
            _configurationError = ex.Message;
        }
        finally
        {
            _isLoadingConfiguration = false;
        }
    }

    private async Task SaveConfigurationAsync()
    {
        if (_selectedAgent is null || _schema is null)
        {
            return;
        }

        _isBusy = true;
        _actionMessage = null;
        _actionSucceeded = null;

        try
        {
            var settings = _schema.Fields.ToDictionary(
                field => field.Key,
                field => JsonSerializer.SerializeToElement(_formValues.GetValueOrDefault(field.Key), SerializerOptions),
                StringComparer.Ordinal);

            var result = await AgentApi.UpdateConfigurationAsync(
                _selectedAgent.Id,
                new UpdateAgentConfigurationRequest(settings));

            _actionSucceeded = result.Succeeded;
            _actionMessage = result.Message ?? "Agent settings saved.";
            _schema = new AgentConfigurationSchemaResponse(
                _schema.AgentId,
                _schema.AgentVersion,
                _schema.SchemaVersion,
                _schema.Fields,
                result.Settings);
            HydrateFormValues(_schema);
        }
        catch (Exception ex)
        {
            _actionSucceeded = false;
            _actionMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void HydrateFormValues(AgentConfigurationSchemaResponse schema)
    {
        _formValues.Clear();

        foreach (var field in schema.Fields)
        {
            if (!schema.Settings.TryGetValue(field.Key, out var value))
            {
                _formValues[field.Key] = field.Type == AgentConfigurationFieldTypes.Boolean ? false : null;
                continue;
            }

            _formValues[field.Key] = field.Type switch
            {
                AgentConfigurationFieldTypes.Boolean => value.ValueKind is JsonValueKind.True,
                AgentConfigurationFieldTypes.Number => value.ValueKind == JsonValueKind.Number && value.TryGetDecimal(out var number)
                    ? number
                    : null,
                _ => value.ValueKind == JsonValueKind.String ? value.GetString() : null
            };
        }
    }

    private string AgentButtonClass(AgentCatalogItemResponse agent) =>
        _selectedAgent?.Id == agent.Id
            ? "agent-list-item selected"
            : "agent-list-item";

    private AgentTokenUsageResponse? AgentUsage(string agentKey) =>
        _usageSummary?.Agents.FirstOrDefault(agent => string.Equals(agent.AgentKey, agentKey, StringComparison.Ordinal));

    private static RenderFragment UsageCard(string label, LlmTokenUsageWindowResponse usage) => @<MudPaper Elevation="1" Class="usage-summary-card">
        <MudText Typo="Typo.overline" Color="Color.Secondary">@label</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">@usage.RequestCount.ToString("N0") requests</MudText>
        <div class="usage-token-breakdown">
            <div>
                <span>Input</span>
                <strong>@FormatTokens(usage.InputTokens)</strong>
            </div>
            <div>
                <span>Output</span>
                <strong>@FormatTokens(usage.OutputTokens)</strong>
            </div>
        </div>
    </MudPaper>;

    private string GetStringValue(string key) =>
        _formValues.TryGetValue(key, out var value) ? value?.ToString() ?? string.Empty : string.Empty;

    private decimal? GetNumberValue(string key) =>
        _formValues.TryGetValue(key, out var value) && value is decimal number ? number : null;

    private bool GetBooleanValue(string key) =>
        _formValues.TryGetValue(key, out var value) && value is true;

    private void SetFormValue(string key, object? value)
    {
        _formValues[key] = value;
    }

    private void SetProviderValue(string key, string value)
    {
        _formValues[key] = value;

        if (_schema is null)
        {
            return;
        }

        foreach (var modelField in _schema.Fields.Where(field =>
            field.Type == AgentConfigurationFieldTypes.LlmModel &&
            string.Equals(ProviderFieldKey(field), key, StringComparison.Ordinal)))
        {
            var provider = FindProvider(value);
            _formValues[modelField.Key] = provider?.DefaultChatModel ?? string.Empty;
        }
    }

    private bool IsModelPickerDisabled(AgentConfigurationField field) =>
        FindProvider(GetStringValue(ProviderFieldKey(field))) is null;

    private string ModelPlaceholder(AgentConfigurationField field) =>
        FindProvider(GetStringValue(ProviderFieldKey(field))) is null
            ? "Select a provider first"
            : "Select a model";

    private IReadOnlyList<string> ModelOptions(AgentConfigurationField field)
    {
        var provider = FindProvider(GetStringValue(ProviderFieldKey(field)));
        return string.IsNullOrWhiteSpace(provider?.DefaultChatModel)
            ? []
            : [provider.DefaultChatModel];
    }

    private bool SelectedModelMissing(AgentConfigurationField field)
    {
        var selected = GetStringValue(field.Key);
        return !string.IsNullOrWhiteSpace(selected) &&
            !ModelOptions(field).Contains(selected, StringComparer.Ordinal);
    }

    private string ProviderFieldKey(AgentConfigurationField modelField)
    {
        if (!string.IsNullOrWhiteSpace(modelField.DependsOnFieldKey))
        {
            return modelField.DependsOnFieldKey;
        }

        return _schema?.Fields.FirstOrDefault(field => field.Type == AgentConfigurationFieldTypes.LlmProvider)?.Key
            ?? string.Empty;
    }

    private LlmProviderProfileResponse? FindProvider(string providerId)
    {
        return Guid.TryParse(providerId, out var id)
            ? _providerProfiles.FirstOrDefault(provider => provider.Id == id)
            : null;
    }

    private static string FormatTokens(long tokens) => tokens >= 1_000_000
        ? $"{tokens / 1_000_000d:0.##}M"
        : tokens >= 1_000
            ? $"{tokens / 1_000d:0.#}K"
            : tokens.ToString("N0");

    private static string FormatUsageCaption(LlmTokenUsageWindowResponse? usage) =>
        usage is null
            ? "In 0 / Out 0 / 30d"
            : $"In {FormatTokens(usage.InputTokens)} / Out {FormatTokens(usage.OutputTokens)} / 30d";

    private static string DisplayImportValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "Not specified" : value;

    private static Color BuildStatusColor(string status) => status switch
    {
        "Succeeded" => Color.Success,
        "Failed" or "Cancelled" => Color.Error,
        _ => Color.Warning
    };

    private static string BuildStatusLabel(string status) => status switch
    {
        "Queued" => "Build queued",
        "Cloning" or "Building" => "Building",
        "Succeeded" => "Built",
        "Failed" => "Build failed",
        "Cancelled" => "Build cancelled",
        _ => status
    };

    private static bool IsRuntimeActive(string? status) => status is
        "Queued" or "Starting" or "WaitingForBrokerRegistration" or "Running" or "CompletionReported" or "Stopping";

    private static string FormatLastRun(AgentRuntimeRunResponse? run) => run is null
        ? "Never"
        : $"{run.Status} · {run.QueuedAt.ToLocalTime():g}";

    private static string FormatTimestamp(DateTimeOffset? timestamp) =>
        timestamp?.ToLocalTime().ToString("g") ?? "—";

    private static string FormatFrequency(int seconds) => seconds % 3600 == 0
        ? $"{seconds / 3600}h"
        : seconds % 60 == 0
            ? $"{seconds / 60}m"
            : $"{seconds}s";

    private static string FormatNextTick(DateTimeOffset? nextTickAt) =>
        nextTickAt?.ToLocalTime().ToString("g") ?? "Not scheduled";

    private static RenderFragment ImportValueSection(string title, IReadOnlyList<string> values) => @<div class="agent-import-values-section">
        <MudText Typo="Typo.subtitle2">@title</MudText>
        @if (values.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">None requested</MudText>
        }
        else
        {
            <div class="agent-import-values">
                @foreach (var value in values)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@value</MudChip>
                }
            </div>
        }
    </div>;

    private RenderFragment ApprovalSection(string title, IReadOnlyList<string> requested, HashSet<string> approved) => @<div class="agent-import-values-section">
        <MudText Typo="Typo.subtitle2">Approved @title.ToLowerInvariant()</MudText>
        @if (requested.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">None requested</MudText>
        }
        else
        {
            <div class="agent-import-approval-list">
                @foreach (var value in requested)
                {
                    <MudCheckBox T="bool"
                                 Label="@value"
                                 Value="@approved.Contains(value)"
                                 ValueChanged="@((bool isApproved) => SetApproval(approved, value, isApproved))" />
                }
            </div>
        }
    </div>;
}

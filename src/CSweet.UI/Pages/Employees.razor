    private sealed record EmployeeGraphNode(OrganizationUserResponse Employee, int X, int Y);

    private sealed record EmployeeGraphEdge(EmployeeGraphNode From, EmployeeGraphNode To);

    private sealed record AgentChoice(
        string Key,
        string Name,
        string AgentId,
        Guid? InstallationId,
        IReadOnlyList<string> Capabilities,
        bool IsInstallation);

    public void Dispose()
    {
        _configurationCts?.Cancel();
        _configurationCts?.Dispose();
        _runtimeStatusCts?.Cancel();
        _runtimeStatusCts?.Dispose();
        _disposeCts.Cancel();
        _disposeCts.Dispose();
    }

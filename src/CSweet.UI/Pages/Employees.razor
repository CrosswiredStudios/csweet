@page "/organizations/{OrganizationId:guid}/employees"
@using System.Text.Json
@using CSweet.Contracts.Agents
@using CSweet.Contracts.Core
@using CSweet.Contracts.Llm
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IAgentApiClient AgentApi
@inject ILlmProviderApiClient LlmProviderApi

<PageTitle>Employees - C-Sweet</PageTitle>

<div class="command-center-shell employees-page">
    <MudPaper Elevation="0" Class="page-header employees-page-header">
        <div>
            <MudText Typo="Typo.h3">Employees</MudText>
            <MudText Color="Color.Secondary">A reporting graph of human teammates and agent employees.</MudText>
        </div>
        <MudStack Row="true" Spacing="2" Class="employees-header-actions">
            @if (!IsHiringTab)
            {
                <MudButton OnClick="OpenHireDialog" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd">Hire employee</MudButton>
            }
            <MudButton Href="@($"/organizations/{OrganizationId}/command-center")" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Dashboard">Command Center</MudButton>
        </MudStack>
    </MudPaper>

    <MudStack Row="true" Spacing="1" Class="employees-tabs">
        <MudButton Href="@($"/organizations/{OrganizationId}/employees?tab=team")"
                   Variant="@(IsHiringTab ? Variant.Text : Variant.Filled)" Color="Color.Primary">Team</MudButton>
        <MudButton Href="@($"/organizations/{OrganizationId}/employees?tab=hiring")"
                   Variant="@(IsHiringTab ? Variant.Filled : Variant.Text)" Color="Color.Primary">Hiring</MudButton>
    </MudStack>

    @if (IsHiringTab)
    {
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                Marketplace <strong>coming soon</strong>. Production recommendations currently use current staff and installed agents only.
            </MudAlert>
            @if (!string.IsNullOrWhiteSpace(_hiringMessage))
            {
                <MudAlert Severity="@(_hiringError ? Severity.Error : Severity.Success)" Class="mb-4">@_hiringMessage</MudAlert>
            }
            @if (_hiringDashboard?.Recommendations.Count is null or 0)
            {
                <MudPaper Class="pa-6" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.h6">No hiring recommendation yet</MudText>
                    <MudText Color="Color.Secondary">The Chief of Staff will maintain the ranked staffing backlog here and surface only the top need in chat.</MudText>
                </MudPaper>
            }
            else
            {
                <MudStack Spacing="3">
                    @foreach (var recommendation in _hiringDashboard!.Recommendations)
                    {
                        var workflow = _hiringDashboard.Workflows.FirstOrDefault(x => x.RecommendationId == recommendation.Id);
                        <MudPaper Class="@($"pa-5 hiring-recommendation {(Recommendation == recommendation.Id ? "highlighted" : string.Empty)}")" Elevation="0" Outlined="true">
                            <MudStack Spacing="2">
                                <div class="hiring-heading">
                                    <div><MudText Typo="Typo.overline">@recommendation.Status</MudText><MudText Typo="Typo.h5">@recommendation.Title</MudText><MudText Color="Color.Secondary">@recommendation.Objective</MudText></div>
                                    @if (workflow?.Status == "Pending")
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_confirmingHire"
                                                   OnClick="@(() => ConfirmHireAsync(workflow.Id))">Approve hire</MudButton>
                                    }
                                </div>
                                @foreach (var candidate in recommendation.Candidates)
                                {
                                    <div class="hiring-candidate @(candidate.CandidateReference == recommendation.RecommendedCandidateReference ? "recommended" : null)">
                                        <div><strong>@candidate.DisplayName</strong>
                                            @if (candidate.CandidateReference == recommendation.RecommendedCandidateReference) { <span>RECOMMENDED</span> }
                                            <small>@candidate.Source · @candidate.InstallationState · @candidate.Trust</small>
                                        </div>
                                        <div class="hiring-price">@(candidate.Price.HasValue ? $"{candidate.Price:0.##} {candidate.Currency}" : "No listed cost")<small>@($"Fit {candidate.FitScore:P0}")</small></div>
                                        <p>@candidate.Rationale</p>
                                        <div class="hiring-chips">@foreach (var capability in candidate.Capabilities.Take(6)) { <span>@capability</span> }</div>
                                        @if (candidate.RequiredGrants.Count > 0) { <small>Required grants: @string.Join(", ", candidate.RequiredGrants)</small> }
                                    </div>
                                }
                                @if (workflow is null)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">The agent has not staged an approval workflow yet.</MudText>
                                }
                                else if (workflow.Status != "Pending")
                                {
                                    <MudAlert Severity="Severity.Success" Dense="true">@workflow.Message</MudAlert>
                                }
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
        }
    }
    else if (_loading)
    {
        <EmployeeLoadingState />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_errorMessage</MudAlert>
    }
    else if (_employees.Count == 0)
    {
        <EmployeeEmptyState HireRequested="OpenHireDialog" />
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_actionError))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@_actionError</MudAlert>
        }
        <EmployeeViewToggle Value="_activeView" ValueChanged="ChangeViewAsync" />
        @if (_activeView == EmployeeViewKind.Graph)
        {
            <EmployeeGraphView Employees="PresentedEmployees"
                               SelectedId="_selectedEmployeeId"
                               SelectedIdChanged="SelectEmployeeAsync"
                               Degrees="_graphDegrees"
                               DegreesChanged="ChangeDegreesAsync"
                               ActionRequested="HandleEmployeeActionAsync" />
        }
        else
        {
            <EmployeeDirectoryView Employees="PresentedEmployees"
                                   Roles="_roles"
                                   Filter="_directoryFilter"
                                   FilterChanged="ChangeFilterAsync"
                                   SelectedId="_selectedEmployeeId"
                                   EmployeeSelected="SelectEmployeeAsync"
                                   ActionRequested="HandleEmployeeActionAsync" />
        }
    }
</div>
<MudDialog @bind-Visible="_configurationDialogOpen" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Configure @_configurationEmployee?.DisplayName</MudText></TitleContent>
    <DialogContent>
        @if (_loadingConfiguration)
        {
            <MudStack Spacing="2" role="status" aria-live="polite">
                <MudText Typo="Typo.subtitle2">@ConfigurationLoadingMessage</MudText>
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                @if (!string.IsNullOrWhiteSpace(_configurationRuntime?.Reason))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_configurationRuntime.Reason</MudText>
                }
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_configurationError))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">@_configurationError</MudAlert>
        }
        else if (_configurationSchema is not null)
        {
            <MudStack Spacing="2">
                @foreach (var field in _configurationSchema.Fields)
                {
                    @if (field.Type == AgentConfigurationFieldTypes.Boolean)
                    {
                        <MudCheckBox T="bool" Label="@field.Label" Value="@ConfigurationBoolean(field.Key)" ValueChanged="@(value => SetConfigurationValue(field.Key, value))" />
                    }
                    else if (field.Type == AgentConfigurationFieldTypes.Number)
                    {
                        <MudNumericField T="decimal?" Label="@field.Label" Value="@ConfigurationNumber(field.Key)" ValueChanged="@(value => SetConfigurationValue(field.Key, value))" Min="@field.Minimum" Max="@field.Maximum" Variant="Variant.Outlined" />
                    }
                    else if (field.Type == AgentConfigurationFieldTypes.Select)
                    {
                        <MudSelect T="string" Label="@field.Label" Value="@ConfigurationString(field.Key)" ValueChanged="@((string value) => SetConfigurationValue(field.Key, value))" Variant="Variant.Outlined">
                            @foreach (var option in field.Options ?? [])
                            {
                                <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (field.Type == AgentConfigurationFieldTypes.LlmProvider)
                    {
                        <MudSelect T="string" Label="@field.Label" Value="@ConfigurationString(field.Key)" ValueChanged="@(value => SetProviderValue(field.Key, value))" Variant="Variant.Outlined">
                            @foreach (var provider in _providerProfiles.Where(x => x.IsEnabled))
                            {
                                <MudSelectItem T="string" Value="@provider.Id.ToString()">@provider.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (field.Type == AgentConfigurationFieldTypes.LlmModel)
                    {
                        <MudSelect T="string" Label="@field.Label" Value="@ConfigurationString(field.Key)" ValueChanged="@(value => SetConfigurationValue(field.Key, value))" Variant="Variant.Outlined" Disabled="@(ConfigurationProvider(field) is null)">
                            @if (ConfigurationProvider(field) is { } provider && !string.IsNullOrWhiteSpace(provider.DefaultChatModel))
                            {
                                <MudSelectItem T="string" Value="@provider.DefaultChatModel">@provider.DefaultChatModel</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        <MudTextField Label="@field.Label" Value="@ConfigurationString(field.Key)" ValueChanged="@((string value) => SetConfigurationValue(field.Key, value))" Lines="@(field.Type == AgentConfigurationFieldTypes.TextArea ? 4 : 1)" Variant="Variant.Outlined" />
                    }
                    @if (!string.IsNullOrWhiteSpace(field.Description))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@field.Description</MudText>
                    }
                }
                @if (!string.IsNullOrWhiteSpace(_configurationMessage))
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">@_configurationMessage</MudAlert>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseConfiguration" Disabled="@_savingConfiguration">Close</MudButton>
        <MudButton OnClick="SaveConfigurationAsync" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_savingConfiguration || _configurationSchema is null)">
            @(_savingConfiguration ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_runtimeConsoleOpen" Options="_runtimeConsoleOptions">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Terminal" />
            <MudText Typo="Typo.h6">@_runtimeConsoleEmployee?.DisplayName console</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_loadingRuntimeConsole)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (!string.IsNullOrWhiteSpace(_runtimeConsoleError))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_runtimeConsoleError</MudAlert>
        }
        else if (_runtimeRuns.Count == 0)
        {
            <MudText Color="Color.Secondary">No runtime attempts have been recorded for this instance.</MudText>
        }
        else
        {
            <MudExpansionPanels MultiExpansion="true">
                @foreach (var run in _runtimeRuns)
                {
                    <MudExpansionPanel Text="@($"{run.QueuedAt.LocalDateTime:g} · {run.Status}")">
                        <MudStack Spacing="1">
                            @if (!string.IsNullOrWhiteSpace(run.Reason))
                            {
                                <MudAlert Severity="@RuntimeRunSeverity(run.Status)" Dense="true" Variant="Variant.Outlined">@run.Reason</MudAlert>
                            }
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Runtime @run.Id · Tick @run.TickId</MudText>
                            <pre class="agent-build-log">@RuntimeEventLog(run)</pre>
                            @if (!string.IsNullOrWhiteSpace(run.LogExcerpt))
                            {
                                <MudText Typo="Typo.subtitle2">Container output</MudText>
                                <pre class="agent-build-log">@run.LogExcerpt</pre>
                            }
                        </MudStack>
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh" Disabled="@_loadingRuntimeConsole" OnClick="RefreshRuntimeConsoleAsync">Refresh</MudButton>
        <MudButton Variant="Variant.Text" OnClick="CloseRuntimeConsole">Close</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_hireDialogOpen" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Hire employee</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            @if (!string.IsNullOrWhiteSpace(_actionError))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_actionError</MudAlert>
            }
            <MudTextField Label="Name" @bind-Value="_hireName" Required="true" Variant="Variant.Outlined" Disabled="@_saving" />
            <MudTextField Label="Email (optional)" @bind-Value="_hireEmail" InputType="InputType.Email" Variant="Variant.Outlined" Disabled="@_saving" />
            <MudSelect T="int" Label="Employee type" @bind-Value="_hireEmployeeType" Variant="Variant.Outlined" Disabled="@_saving">
                <MudSelectItem T="int" Value="0">Human</MudSelectItem>
                <MudSelectItem T="int" Value="1">Agent</MudSelectItem>
            </MudSelect>
            @if (_hireEmployeeType == 1)
            {
                <MudSelect T="string" Label="Agent" @bind-Value="_hireAgentKey" Required="true" Variant="Variant.Outlined" Disabled="@_saving">
                    @foreach (var agent in AvailableAgents)
                    {
                        <MudSelectItem T="string" Value="@agent.Key">@agent.Name</MudSelectItem>
                    }
                </MudSelect>
                @if (AvailableAgents.Count == 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                        No enabled agents are available. Add or enable an agent before hiring an agent employee.
                    </MudAlert>
                }
            }
            <MudSelect T="Guid?" Label="Managed by" @bind-Value="_hireManagerId" Clearable="true" Variant="Variant.Outlined" Disabled="@_saving">
                @foreach (var employee in _employees)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)employee.Id)">@employee.DisplayName</MudSelectItem>
                }
            </MudSelect>
            <MudText Typo="Typo.subtitle2">Manages</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Select existing employees who will report to this new hire.</MudText>
            @if (_employees.Count == 0)
            {
                <MudText Color="Color.Secondary">There are no existing employees to assign.</MudText>
            }
            else
            {
                <div class="employee-management-picker">
                    @foreach (var employee in _employees)
                    {
                        <MudCheckBox T="bool"
                                     Label="@employee.DisplayName"
                                     Value="@_managedEmployeeIds.Contains(employee.Id)"
                                     ValueChanged="@(value => SetManaged(employee.Id, value))"
                                     Disabled="@(_saving || _hireManagerId == employee.Id)" />
                    }
                </div>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseHireDialog" Disabled="@_saving">Cancel</MudButton>
        <MudButton OnClick="HireAsync" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_saving">
            @(_saving ? "Hiring..." : "Hire")
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_roleDialogOpen" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Change company role</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Color="Color.Secondary">This changes the administrator’s position in this company. System administrator and Owner access remain unchanged.</MudText>
            <MudSelect T="Guid?" Label="Company role" @bind-Value="_selectedRoleId" Clearable="true" Variant="Variant.Outlined" Disabled="_saving">
                @foreach (var role in _roles)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)role.Id)">@role.Name</MudSelectItem>
                }
            </MudSelect>
            @if (!string.IsNullOrWhiteSpace(_actionError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_actionError</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseRoleDialog" Disabled="_saving">Cancel</MudButton>
        <MudButton OnClick="SaveRoleAsync" Variant="Variant.Filled" Color="Color.Primary" Disabled="_saving">@(_saving ? "Saving..." : "Save role")</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_fireDialogOpen" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Fire employee?</MudText></TitleContent>
    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(_actionError))
        {
            <MudAlert Severity="Severity.Error" Dense="true">@_actionError</MudAlert>
        }
        <MudText>Remove <strong>@_employeeToFire?.DisplayName</strong> from this organization?</MudText>
        @if (_employeeToFire?.EmployeeType == 1)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-3">
                Firing an agent also permanently removes its conversation history.
            </MudAlert>
        }
        @if (_employeeToFire is not null && SubordinateCount(_employeeToFire) > 0)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-3">
                Their @SubordinateCount(_employeeToFire) direct report(s) will become unassigned.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseFireDialog" Disabled="@_saving">Cancel</MudButton>
        <MudButton OnClick="FireAsync" Variant="Variant.Filled" Color="Color.Error" Disabled="@_saving">@(_saving ? "Firing..." : "Fire")</MudButton>
    </DialogActions>
</MudDialog>

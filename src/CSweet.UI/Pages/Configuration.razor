@page "/configuration"
@using CSweet.Contracts.Llm
@using CSweet.Contracts.Setup
@using CSweet.Domain.Setup
@inject ISetupApiClient SetupApi
@inject ILlmProviderApiClient LlmProviderApi
@inject IAgentRuntimeSettingsApiClient AgentRuntimeSettingsApi

<PageTitle>Configuration - C-Sweet</PageTitle>

<div class="setup-shell configuration-page">
    <MudPaper Elevation="0" Class="page-header">
        <div>
            <MudText Typo="Typo.overline" Color="Color.Primary">System configuration</MudText>
            <MudText Typo="Typo.h3">Configuration</MudText>
            <MudText Color="Color.Secondary">Review and manage the settings C-Sweet uses for setup, model access, and worker readiness.</MudText>
        </div>
        <MudStack AlignItems="AlignItems.End" Spacing="0">
            <MudChip T="string" Color="@ConfigurationStateColor" Variant="Variant.Filled">@ConfigurationStateLabel</MudChip>
            <MudText Typo="Typo.caption" Color="Color.Secondary">first-run status</MudText>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <MudPaper Elevation="1" Class="surface-panel surface-panel-narrow">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Color="Color.Secondary">Loading configuration...</MudText>
        </MudPaper>
    }
    else if (!string.IsNullOrWhiteSpace(_pageError))
    {
        <MudPaper Elevation="1" Class="surface-panel surface-panel-narrow">
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_pageError</MudAlert>
            <MudStack Row="true" Class="setup-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync">Retry</MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <section class="configuration-grid">
            <MudPaper Elevation="1" Class="surface-panel command-section-wide">
                <div class="configuration-section-header">
                    <div>
                        <MudText Typo="Typo.h6">System</MudText>
                        <MudText Color="Color.Secondary">Current setup state and selected provider defaults.</MudText>
                    </div>
                    @if (_status?.IsFirstRunComplete == false)
                    {
                        <MudButton Href="/setup" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Tune">Finish setup</MudButton>
                    }
                </div>

                <dl class="configuration-details">
                    <div>
                        <dt>First-run complete</dt>
                        <dd>@YesNo(_status?.IsFirstRunComplete)</dd>
                    </div>
                    <div>
                        <dt>Default chat provider</dt>
                        <dd>@ProviderName(_status?.DefaultChatProviderId)</dd>
                    </div>
                    <div>
                        <dt>Default embedding provider</dt>
                        <dd>@ProviderName(_status?.DefaultEmbeddingProviderId)</dd>
                    </div>
                    <div>
                        <dt>Provider profiles</dt>
                        <dd>@_profiles.Count</dd>
                    </div>
                </dl>

                <div class="setup-check-list configuration-checks">
                    @foreach (var step in _status?.Steps ?? [])
                    {
                        @ConfigurationStepRow(step)
                    }
                </div>
            </MudPaper>

            <MudPaper Elevation="1" Class="surface-panel command-section-wide">
                <div class="configuration-section-header">
                    <div>
                        <MudText Typo="Typo.h6">LLM Provider Profiles</MudText>
                        <MudText Color="Color.Secondary">Every saved provider profile and its configured model options.</MudText>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="@_isBusy" OnClick="LoadAsync" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
                </div>

                @if (_profiles.Count == 0)
                {
                    <MudText Color="Color.Secondary">No provider profiles have been created yet.</MudText>
                }
                else
                {
                    <div class="configuration-profile-list">
                        @foreach (var profile in _profiles)
                        {
                            <MudPaper Elevation="0" Class="configuration-profile">
                                <div class="configuration-profile-heading">
                                    <div>
                                        <MudText Typo="Typo.subtitle1">@profile.Name</MudText>
                                        <MudText Color="Color.Secondary">@ProviderTypeLabel(profile.ProviderType)</MudText>
                                    </div>
                                    <MudChip T="string" Color="@DefaultBadgeColor(profile)" Variant="Variant.Outlined">
                                        @(profile.Id == _status?.DefaultChatProviderId ? "Default chat" : "Available")
                                    </MudChip>
                                </div>

                                <dl class="configuration-details">
                                    <div>
                                        <dt>Base URL</dt>
                                        <dd>@profile.BaseUrl</dd>
                                    </div>
                                    <div>
                                        <dt>Chat model</dt>
                                        <dd>@profile.DefaultChatModel</dd>
                                    </div>
                                    <div>
                                        <dt>Embedding model</dt>
                                        <dd>@Display(profile.DefaultEmbeddingModel)</dd>
                                    </div>
                                    <div>
                                        <dt>API key secret</dt>
                                        <dd>@Display(profile.ApiKeySecretName)</dd>
                                    </div>
                                    <div>
                                        <dt>Context window</dt>
                                        <dd>@Display(profile.ContextWindowTokens)</dd>
                                    </div>
                                    <div>
                                        <dt>Max output</dt>
                                        <dd>@Display(profile.MaxOutputTokens)</dd>
                                    </div>
                                    <div>
                                        <dt>Enabled</dt>
                                        <dd>@YesNo(profile.IsEnabled)</dd>
                                    </div>
                                    <div>
                                        <dt>Last connected</dt>
                                        <dd>@Display(profile.LastSuccessfulConnectionAt)</dd>
                                    </div>
                                    <div>
                                        <dt>Created</dt>
                                        <dd>@Display(profile.CreatedAt)</dd>
                                    </div>
                                    <div>
                                        <dt>Updated</dt>
                                        <dd>@Display(profile.UpdatedAt)</dd>
                                    </div>
                                </dl>

                                <div class="setup-toggle-row configuration-capabilities">
                                    @CapabilityPill("Streaming", profile.SupportsStreaming)
                                    @CapabilityPill("Tool calling", profile.SupportsToolCalling)
                                    @CapabilityPill("Structured output", profile.SupportsStructuredOutput)
                                    @CapabilityPill("Vision", profile.SupportsVision)
                                </div>

                                @if (_testResults.TryGetValue(profile.Id, out var testResult))
                                {
                                    <div class="setup-check-list configuration-test-results">
                                        @TestRow("Connection", testResult.ConnectionSucceeded)
                                        @TestRow("Chat", testResult.ChatSucceeded)
                                        @TestRow("Streaming", testResult.StreamingSucceeded)
                                        @TestRow("Structured output", testResult.StructuredOutputSucceeded)
                                        @TestRow("Tool calling", testResult.ToolCallingSucceeded)
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(testResult.FailureMessage))
                                    {
                                        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-4">@testResult.FailureMessage</MudAlert>
                                    }
                                }

                                <MudStack Row="true" Class="setup-actions">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Disabled="@_isBusy"
                                               OnClick="@(() => TestProviderAsync(profile.Id))">
                                        Test provider
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="@(_isBusy || profile.Id == _status?.DefaultChatProviderId)"
                                               OnClick="@(() => SetDefaultProviderAsync(profile.Id))">
                                        Set as default chat
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </div>
                }
            </MudPaper>

            <MudPaper Elevation="1" Class="surface-panel command-section-wide">
                <MudText Typo="Typo.h6">Add Provider Profile</MudText>
                <div class="setup-form-grid">
                    <MudSelect T="LlmProviderType" Label="Provider Type" Value="_providerType" ValueChanged="OnProviderTypeChanged" Variant="Variant.Outlined">
                            @foreach (var providerType in Enum.GetValues<LlmProviderType>())
                            {
                            <MudSelectItem T="LlmProviderType" Value="@providerType">@ProviderTypeLabel(providerType)</MudSelectItem>
                            }
                    </MudSelect>
                    <MudTextField Label="Provider Name" @bind-Value="_providerName" Variant="Variant.Outlined" />
                    <div class="setup-form-wide">
                        <MudTextField Label="Base URL" @bind-Value="_baseUrl" Immediate="true" OnBlur="@(_ => PreviewModelCatalogAsync())" Variant="Variant.Outlined" />
                        @if (!string.IsNullOrWhiteSpace(_modelCatalogMessage))
                        {
                            <MudText Typo="Typo.caption" Class="@ModelCatalogFeedbackClass">@_modelCatalogMessage</MudText>
                        }
                    </div>
                    <MudTextField Class="setup-form-wide" Label="API Key / Token" @bind-Value="_apiKey" InputType="InputType.Password" autocomplete="off" Variant="Variant.Outlined" />
                    <MudSelect T="string" Label="Default Chat Model" @bind-Value="_defaultChatModel" Disabled="@IsModelSelectDisabled" Variant="Variant.Outlined">
                            <MudSelectItem T="string" Value="@string.Empty">@ModelSelectPlaceholder</MudSelectItem>
                            @if (SelectedChatModelMissingFromCatalog)
                            {
                            <MudSelectItem T="string" Value="@_defaultChatModel">@_defaultChatModel</MudSelectItem>
                            }
                            @foreach (var model in _availableModels)
                            {
                            <MudSelectItem T="string" Value="@model.Id">@model.Id</MudSelectItem>
                            }
                    </MudSelect>
                    <MudTextField Label="Default Embedding Model" @bind-Value="_defaultEmbeddingModel" Variant="Variant.Outlined" />
                    <MudNumericField T="int?" Label="Context Window Tokens" @bind-Value="_contextWindowTokens" Variant="Variant.Outlined" />
                    <MudNumericField T="int?" Label="Max Output Tokens" @bind-Value="_maxOutputTokens" Variant="Variant.Outlined" />
                </div>

                <MudStack Row="true" Class="setup-toggle-row">
                    <MudCheckBox T="bool" Label="Streaming" @bind-Value="_supportsStreaming" />
                    <MudCheckBox T="bool" Label="Structured output" @bind-Value="_supportsStructuredOutput" />
                    <MudCheckBox T="bool" Label="Tool calling" @bind-Value="_supportsToolCalling" />
                    <MudCheckBox T="bool" Label="Vision" @bind-Value="_supportsVision" />
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_actionMessage))
                {
                    <MudAlert Severity="@ActionMessageSeverity" Variant="Variant.Outlined" Class="mt-4">@_actionMessage</MudAlert>
                }

                <MudStack Row="true" Class="setup-actions">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@(_isBusy || _isCheckingModelCatalog || string.IsNullOrWhiteSpace(_defaultChatModel))"
                               OnClick="CreateProviderAsync">
                        @(_isBusy ? "Saving..." : "Save Provider")
                    </MudButton>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="surface-panel command-section-wide">
                <div class="configuration-section-header">
                    <div>
                        <MudText Typo="Typo.h6">Agent Runtime</MudText>
                        <MudText Color="Color.Secondary">Global defaults and hard limits for imported agents, builds, schedules, and containers.</MudText>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_runtimeActionMessage))
                    {
                        <MudAlert Severity="@RuntimeActionMessageSeverity" Variant="Variant.Outlined" Class="mt-4">@_runtimeActionMessage</MudAlert>
                    }
                </div>

                @if (_runtimeSettings is not null)
                {
                    <MudExpansionPanels MultiExpansion="true">
                        <MudExpansionPanel Text="Runtime Defaults" Expanded="true" Class="configuration-expand-panel">
                            <div class="setup-form-grid">
                                <MudCheckBox T="bool" Label="Enable imported agents" @bind-Value="_runtimeEnableImportedAgents" Disabled="@_runtimeIsBusy" />
                                <MudSelect T="string" Label="Default Activation Mode" @bind-Value="_runtimeDefaultActivationMode" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy">
                                    <MudSelectItem T="string" Value="@("AlwaysOn")">Always On</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("Periodic")">Periodic</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("Manual")">Manual</MudSelectItem>
                                </MudSelect>
                                <MudNumericField T="int" Label="Default Tick Frequency (seconds)" @bind-Value="_runtimeDefaultTickFrequencySeconds" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Minimum Tick Frequency (seconds)" @bind-Value="_runtimeMinimumTickFrequencySeconds" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Default Max Runtime (seconds)" @bind-Value="_runtimeDefaultMaxRuntimeSeconds" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudSelect T="string" Label="Default Overlap Policy" @bind-Value="_runtimeDefaultOverlapPolicy" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy">
                                    <MudSelectItem T="string" Value="@("Skip")">Skip</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("Queue")">Queue</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("CancelPrevious")">Cancel Previous</MudSelectItem>
                                </MudSelect>
                                <MudSelect T="string" Label="Default Restart Policy" @bind-Value="_runtimeDefaultRestartPolicy" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy">
                                    <MudSelectItem T="string" Value="@("Never")">Never</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("OnFailure")">On Failure</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("Always")">Always</MudSelectItem>
                                </MudSelect>
                                <MudCheckBox T="bool" Label="Allow Always-On Community Agents" @bind-Value="_runtimeAllowAlwaysOnCommunityAgents" Disabled="@_runtimeIsBusy" />
                            </div>
                        </MudExpansionPanel>

                        <MudExpansionPanel Text="Container Limits" Class="configuration-expand-panel">
                            <div class="setup-form-grid">
                                <MudNumericField T="int" Label="Global Max Active Containers" @bind-Value="_runtimeGlobalMaxActiveContainers" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Per-Business Max Active Containers" @bind-Value="_runtimePerBusinessMaxActiveContainers" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Per-Installation Max Active Containers" @bind-Value="_runtimePerInstallationMaxActiveContainers" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Default Container Memory (MB)" @bind-Value="_runtimeDefaultContainerMemoryMb" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Maximum Container Memory (MB)" @bind-Value="_runtimeMaximumContainerMemoryMb" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Default Container CPU (%)" @bind-Value="_runtimeDefaultContainerCpuPercent" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Maximum Container CPU (%)" @bind-Value="_runtimeMaximumContainerCpuPercent" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Default Container PIDs Limit" @bind-Value="_runtimeDefaultContainerPidsLimit" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Default Container Log Limit (MB)" @bind-Value="_runtimeDefaultContainerLogLimitMb" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Container Start Timeout (seconds)" @bind-Value="_runtimeContainerStartTimeoutSeconds" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Broker Registration Timeout (seconds)" @bind-Value="_runtimeBrokerRegistrationTimeoutSeconds" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Container Stop Grace (seconds)" @bind-Value="_runtimeContainerStopGraceSeconds" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                            </div>
                        </MudExpansionPanel>

                        <MudExpansionPanel Text="Network &amp; Storage" Class="configuration-expand-panel">
                            <div class="setup-form-grid">
                                <MudSelect T="string" Label="Default Network Policy" @bind-Value="_runtimeDefaultNetworkPolicy" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy">
                                    <MudSelectItem T="string" Value="@("BrokerOnly")">Broker Only</MudSelectItem>
                                </MudSelect>
                                <MudCheckBox T="bool" Label="Allow Public Internet by Default" @bind-Value="_runtimeAllowPublicInternetByDefault" Disabled="@_runtimeIsBusy" />
                                <MudTextField Label="Allowed Package Feed Hosts" @bind-Value="_runtimeAllowedPackageFeedHosts" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudTextField Label="Blocked Network CIDRs" @bind-Value="_runtimeBlockedNetworkCidrs" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudTextField Label="Agent Source Root Path" @bind-Value="_runtimeAgentSourceRootPath" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudTextField Label="Agent Package Cache Path" @bind-Value="_runtimeAgentPackageCachePath" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                            </div>
                        </MudExpansionPanel>

                        <MudExpansionPanel Text="Build &amp; Import" Class="configuration-expand-panel">
                            <div class="setup-form-grid">
                                <MudTextField Label=".NET Builder Image" @bind-Value="_runtimeDotNetBuilderImage" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudTextField Label=".NET Runtime Base Image" @bind-Value="_runtimeDotNetRuntimeBaseImage" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Build Timeout (seconds)" @bind-Value="_runtimeBuildTimeoutSeconds" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Build Memory (MB)" @bind-Value="_runtimeBuildMemoryMb" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Build CPU (%)" @bind-Value="_runtimeBuildCpuPercent" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Maximum Repository Size (MB)" @bind-Value="_runtimeMaximumRepositorySizeMb" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Maximum Build Log (MB)" @bind-Value="_runtimeMaximumBuildLogMb" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudCheckBox T="bool" Label="Keep Failed Build Workspaces" @bind-Value="_runtimeKeepFailedBuildWorkspaces" Disabled="@_runtimeIsBusy" />
                            </div>
                        </MudExpansionPanel>

                        <MudExpansionPanel Text="Cleanup &amp; Retention" Class="configuration-expand-panel">
                            <div class="setup-form-grid">
                                <MudNumericField T="int" Label="Completed Runtime Retention (days)" @bind-Value="_runtimeCompletedRuntimeRetentionDays" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Failed Runtime Retention (days)" @bind-Value="_runtimeFailedRuntimeRetentionDays" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudNumericField T="int" Label="Build Log Retention (days)" @bind-Value="_runtimeBuildLogRetentionDays" Variant="Variant.Outlined" Disabled="@_runtimeIsBusy" />
                                <MudCheckBox T="bool" Label="Remove Containers After Completion" @bind-Value="_runtimeRemoveContainersAfterCompletion" Disabled="@_runtimeIsBusy" />
                                <MudCheckBox T="bool" Label="Remove Workspaces After Completion" @bind-Value="_runtimeRemoveWorkspacesAfterCompletion" Disabled="@_runtimeIsBusy" />
                            </div>
                        </MudExpansionPanel>
                    </MudExpansionPanels>

                    <MudStack Row="true" Class="setup-actions">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@_runtimeIsBusy"
                                   OnClick="SaveAgentRuntimeSettingsAsync">
                            @_runtimeIsBusy ? "Saving..." : "Save Agent Runtime Settings"
                        </MudButton>
                    </MudStack>
                }
            </MudPaper>
        </section>
    }
</div>

@code {
    private SetupStatusResponse? _status;
    private IReadOnlyList<LlmProviderProfileResponse> _profiles = [];
    private readonly Dictionary<Guid, ModelCapabilityTestResult> _testResults = [];
    private bool _isLoading = true;
    private bool _isBusy;
    private string? _pageError;
    private string? _actionMessage;
    private string _actionMessageClass = "setup-alert setup-alert-info";

    private LlmProviderType _providerType = LlmProviderType.LmStudio;
    private string _providerName = "Local LM Studio";
    private string _baseUrl = "http://localhost:1234/v1";
    private string _apiKey = "lm-studio";
    private string _defaultChatModel = string.Empty;
    private string _defaultEmbeddingModel = string.Empty;
    private IReadOnlyList<ModelDescriptor> _availableModels = [];
    private bool _isCheckingModelCatalog;
    private bool? _modelCatalogSucceeded;
    private string? _modelCatalogMessage;
    private int? _contextWindowTokens;
    private int? _maxOutputTokens;
    private bool _supportsStreaming = true;
    private bool _supportsToolCalling;
    private bool _supportsStructuredOutput;
    private bool _supportsVision;

    // Agent Runtime settings
    private AgentRuntimeSettingsResponse? _runtimeSettings;
    private bool _runtimeIsBusy;
    private string? _runtimeActionMessage;
    private bool? _runtimeActionSucceeded;

    // Form fields for runtime settings
    private bool _runtimeEnableImportedAgents;
    private string _runtimeDefaultActivationMode = "Periodic";
    private int _runtimeDefaultTickFrequencySeconds = 3600;
    private int _runtimeMinimumTickFrequencySeconds = 300;
    private int _runtimeDefaultMaxRuntimeSeconds = 600;
    private string _runtimeDefaultOverlapPolicy = "Skip";
    private bool _runtimeAllowAlwaysOnCommunityAgents;
    private string _runtimeDefaultRestartPolicy = "Never";
    private int _runtimeGlobalMaxActiveContainers = 10;
    private int _runtimePerBusinessMaxActiveContainers = 5;
    private int _runtimePerInstallationMaxActiveContainers = 1;
    private int _runtimeDefaultContainerMemoryMb = 512;
    private int _runtimeMaximumContainerMemoryMb = 2048;
    private int _runtimeDefaultContainerCpuPercent = 50;
    private int _runtimeMaximumContainerCpuPercent = 200;
    private int _runtimeDefaultContainerPidsLimit = 100;
    private int _runtimeDefaultContainerLogLimitMb = 10;
    private int _runtimeContainerStartTimeoutSeconds = 60;
    private int _runtimeBrokerRegistrationTimeoutSeconds = 30;
    private int _runtimeContainerStopGraceSeconds = 15;
    private string _runtimeDefaultNetworkPolicy = "BrokerOnly";
    private bool _runtimeAllowPublicInternetByDefault;
    private string _runtimeAllowedPackageFeedHosts = string.Empty;
    private string _runtimeBlockedNetworkCidrs = string.Empty;
    private string _runtimeAgentSourceRootPath = string.Empty;
    private string _runtimeAgentPackageCachePath = string.Empty;
    private string _runtimeDotNetBuilderImage = "mcr.microsoft.com/dotnet/sdk:9.0";
    private string _runtimeDotNetRuntimeBaseImage = "mcr.microsoft.com/dotnet/runtime:9.0";
    private int _runtimeBuildTimeoutSeconds = 600;
    private int _runtimeBuildMemoryMb = 2048;
    private int _runtimeBuildCpuPercent = 200;
    private int _runtimeMaximumRepositorySizeMb = 500;
    private int _runtimeMaximumBuildLogMb = 10;
    private bool _runtimeKeepFailedBuildWorkspaces;
    private int _runtimeCompletedRuntimeRetentionDays = 14;
    private int _runtimeFailedRuntimeRetentionDays = 30;
    private int _runtimeBuildLogRetentionDays = 30;
    private bool _runtimeRemoveContainersAfterCompletion = true;
    private bool _runtimeRemoveWorkspacesAfterCompletion = true;

    private Severity RuntimeActionMessageSeverity => _runtimeActionSucceeded switch
    {
        true => Severity.Success,
        false => Severity.Error,
        _ => Severity.Info
    };

    private string ConfigurationStateLabel => _status?.IsFirstRunComplete switch
    {
        true => "Complete",
        false => "Incomplete",
        _ => "Unknown"
    };

    private Color ConfigurationStateColor => _status?.IsFirstRunComplete switch
    {
        true => Color.Success,
        false => Color.Warning,
        _ => Color.Default
    };

    private Severity ActionMessageSeverity => _actionMessageClass switch
    {
        "setup-alert setup-alert-success" => Severity.Success,
        "setup-alert setup-alert-error" => Severity.Error,
        _ => Severity.Info
    };

    private bool IsModelSelectDisabled => _isCheckingModelCatalog || (_availableModels.Count == 0 && string.IsNullOrWhiteSpace(_defaultChatModel));
    private bool SelectedChatModelMissingFromCatalog => !string.IsNullOrWhiteSpace(_defaultChatModel) &&
        !_availableModels.Any(model => string.Equals(model.Id, _defaultChatModel, StringComparison.Ordinal));
    private string ModelSelectPlaceholder => _isCheckingModelCatalog
        ? "Checking models..."
        : _availableModels.Count == 0
            ? "Blur Base URL to load models"
            : "Select a model";
    private string ModelCatalogFeedbackClass => _modelCatalogSucceeded switch
    {
        true => "setup-field-feedback setup-field-feedback-success",
        false => "setup-field-feedback setup-field-feedback-error",
        _ => "setup-field-feedback"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _pageError = null;

        try
        {
            _status = await SetupApi.GetStatusAsync();
            _profiles = await LlmProviderApi.ListAsync();
            _runtimeSettings = await AgentRuntimeSettingsApi.GetAsync();
            HydrateRuntimeSettings(_runtimeSettings);
        }
        catch
        {
            _pageError = "Unable to load configuration from the API.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void HydrateRuntimeSettings(AgentRuntimeSettingsResponse settings)
    {
        _runtimeEnableImportedAgents = settings.EnableImportedAgents;
        _runtimeDefaultActivationMode = settings.DefaultActivationMode;
        _runtimeDefaultTickFrequencySeconds = settings.DefaultTickFrequencySeconds;
        _runtimeMinimumTickFrequencySeconds = settings.MinimumTickFrequencySeconds;
        _runtimeDefaultMaxRuntimeSeconds = settings.DefaultMaxRuntimeSeconds;
        _runtimeDefaultOverlapPolicy = settings.DefaultOverlapPolicy;
        _runtimeAllowAlwaysOnCommunityAgents = settings.AllowAlwaysOnCommunityAgents;
        _runtimeDefaultRestartPolicy = settings.DefaultRestartPolicy;
        _runtimeGlobalMaxActiveContainers = settings.GlobalMaxActiveContainers;
        _runtimePerBusinessMaxActiveContainers = settings.PerBusinessMaxActiveContainers;
        _runtimePerInstallationMaxActiveContainers = settings.PerInstallationMaxActiveContainers;

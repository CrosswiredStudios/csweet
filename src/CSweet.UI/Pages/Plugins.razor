@page "/settings/plugins"
@using CSweet.Contracts.Agents
@inject IPluginApiClient PluginApi

<PageTitle>Plugins - C-Sweet</PageTitle>

<SettingsNavigation />

<div class="setup-shell">
    <MudPaper Elevation="0" Class="page-header">
        <div>
            <MudText Typo="Typo.overline" Color="Color.Primary">Enterprise extensions</MudText>
            <MudText Typo="Typo.h3">Plugins</MudText>
            <MudText Color="Color.Secondary">Import immutable agent and communication-provider packages. Nothing runs until an administrator approves the manifest and grants.</MudText>
        </div>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync" Disabled="@_busy">Refresh</MudButton>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <MudAlert Severity="@(_error ? Severity.Error : Severity.Success)" Variant="Variant.Outlined">@_message</MudAlert>
    }

    <MudPaper Elevation="1" Class="surface-panel">
        <MudText Typo="Typo.h6">Import from GitHub</MudText>
        <MudText Color="Color.Secondary">Use an exact 40-character commit SHA for reproducible imports. The manifest digest is shown before approval.</MudText>
        <MudTextField @bind-Value="_repositoryUrl" Label="Public GitHub repository URL" Variant="Variant.Outlined" Disabled="@_busy" />
        <MudTextField @bind-Value="_commitSha" Label="Exact commit SHA" Variant="Variant.Outlined" Disabled="@_busy" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="PreviewAsync" Disabled="@(_busy || string.IsNullOrWhiteSpace(_repositoryUrl) || string.IsNullOrWhiteSpace(_commitSha))">
            Preview manifest
        </MudButton>

        @if (_preview is not null)
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle1">@_preview.AgentName (@_preview.PluginKind)</MudText>
            <MudText Typo="Typo.body2">@_preview.AgentId · @_preview.AgentVersion</MudText>
            <MudText Typo="Typo.caption">Commit: @_preview.CommitSha</MudText><br />
            <MudText Typo="Typo.caption">Manifest: @_preview.ManifestFileName · SHA-256 @_preview.ManifestDigest</MudText>
            <MudText Typo="Typo.body2" Class="mt-3">Provided capabilities: @Format(_preview.Capabilities)</MudText>
            <MudText Typo="Typo.body2">Requested platform capabilities: @Format(_preview.RequestedCapabilities)</MudText>
            <MudText Typo="Typo.body2">Network access: @Format(_preview.RequestedNetworkAccess)</MudText>
            <MudCheckBox @bind-Value="_approve" Label="I approve the displayed capabilities, permissions, publications, subscriptions, and network grants." Color="Color.Primary" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="InstallAsync" Disabled="@(_busy || !_approve)">
                Build and install
            </MudButton>
        }
    </MudPaper>

    <MudPaper Elevation="1" Class="surface-panel">
        <div class="configuration-section-header">
            <div>
                <MudText Typo="Typo.h6">Installed plugins</MudText>
                <MudText Color="Color.Secondary">Communication providers are system-scoped, always-on runtimes with durable storage under <code>/data</code>.</MudText>
            </div>
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@_installations.Count</MudChip>
        </div>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_installations.Count == 0)
        {
            <MudText Color="Color.Secondary">No plugins are installed. The default topology starts no communication-provider containers.</MudText>
        }
        else
        {
            @foreach (var installation in _installations)
            {
                <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-3">
                    <div class="configuration-section-header">
                        <div>
                            <MudText Typo="Typo.subtitle1">@installation.AgentName</MudText>
                            <MudText Typo="Typo.caption">@installation.PluginKind · @installation.InstallationScope · @installation.CommitSha</MudText>
                        </div>
                        <MudChip T="string" Color="@(installation.IsEnabled ? Color.Success : Color.Default)">@(installation.IsEnabled ? "Enabled" : "Disabled")</MudChip>
                    </div>
                    <MudText Typo="Typo.body2">Build: @(installation.Build?.Status ?? "Queued") · Runtime: @(installation.LatestRuntime?.Status ?? "Not started")</MudText>
                    <MudStack Row="true" Class="mt-3">
                        <MudButton Variant="Variant.Outlined" OnClick="@(() => ToggleAsync(installation))" Disabled="@_busy">
                            @(installation.IsEnabled ? "Disable" : "Enable")
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => RemoveAsync(installation))" Disabled="@_busy">Remove installation</MudButton>
                    </MudStack>
                </MudPaper>
            }
        }
    </MudPaper>
</div>

@code {
    private readonly List<AgentInstallationResponse> _installations = [];
    private AgentImportPreviewResponse? _preview;
    private string _repositoryUrl = string.Empty;
    private string _commitSha = string.Empty;
    private string? _message;
    private bool _loading = true;
    private bool _busy;
    private bool _error;
    private bool _approve;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _installations.Clear();
            _installations.AddRange(await PluginApi.ListAsync());
        }
        catch (Exception exception) { ShowError(exception); }
        finally { _loading = false; }
    }

    private async Task PreviewAsync()
    {
        _busy = true; _message = null; _preview = null; _approve = false;
        try { _preview = await PluginApi.PreviewAsync(new(_repositoryUrl.Trim(), _commitSha.Trim())); }
        catch (Exception exception) { ShowError(exception); }
        finally { _busy = false; }
    }

    private async Task InstallAsync()
    {
        if (_preview is null) return;
        _busy = true;
        try
        {
            var communication = string.Equals(_preview.PluginKind, "CommunicationProvider", StringComparison.OrdinalIgnoreCase);
            var request = new InstallAgentRequest(
                communication ? "enterprise" : "shared",
                communication ? "AlwaysOn" : (_preview.DefaultActivationMode ?? "OnDemand"),
                communication ? 30 : 300,
                "Skip",
                _preview.Capabilities,
                _preview.RequestedSubscriptions,
                _preview.RequestedPublications,
                _preview.RequestedPermissions,
                _preview.RequestedNetworkAccess,
                300, 512, 50)
            {
                PluginScope = communication ? "System" : "Organization",
                GrantedRequestedCapabilities = _preview.RequestedCapabilities
            };
            await PluginApi.InstallAsync(_preview.ImportId, request);
            _preview = null; _approve = false; _repositoryUrl = string.Empty; _commitSha = string.Empty;
            ShowSuccess("Plugin approved and queued for an isolated build.");
            await LoadAsync();
        }
        catch (Exception exception) { ShowError(exception); }
        finally { _busy = false; }
    }

    private async Task ToggleAsync(AgentInstallationResponse installation)
    {
        _busy = true;
        try { await PluginApi.SetEnabledAsync(installation.Id, !installation.IsEnabled); ShowSuccess("Plugin state updated."); await LoadAsync(); }
        catch (Exception exception) { ShowError(exception); }
        finally { _busy = false; }
    }

    private async Task RemoveAsync(AgentInstallationResponse installation)
    {
        _busy = true;
        try { await PluginApi.RemoveAsync(installation.Id); ShowSuccess("Plugin installation removed. Persistent provider data remains preserved for controlled cleanup."); await LoadAsync(); }
        catch (Exception exception) { ShowError(exception); }
        finally { _busy = false; }
    }

    private static string Format(IReadOnlyList<string> values) => values.Count == 0 ? "None" : string.Join(", ", values);
    private void ShowSuccess(string message) { _message = message; _error = false; }
    private void ShowError(Exception exception) { _message = exception.Message; _error = true; }
}

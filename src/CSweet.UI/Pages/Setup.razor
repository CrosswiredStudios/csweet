@page "/setup"
@layout SetupLayout
@using CSweet.Contracts.Llm
@using CSweet.Contracts.Setup
@using System.Net.Http.Json
@using CSweet.Domain.Setup
@using CSweet.UI.Setup
@inject ISetupApiClient SetupApi
@inject ILlmProviderApiClient LlmProviderApi
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IAuthenticationApiClient AuthenticationApi
@inject AuthSessionStore AuthSession

<PageTitle>C-Sweet Setup</PageTitle>

<div class="setup-shell">
    <MudPaper Elevation="0" Class="page-header">
        <div>
            <MudText Typo="Typo.overline" Color="Color.Primary">First-run configuration</MudText>
            <MudText Typo="Typo.h3">C-Sweet Setup</MudText>
            <MudText Color="Color.Secondary">Connect the services C-Sweet needs before business onboarding starts.</MudText>
        </div>
        <MudStack AlignItems="AlignItems.End" Spacing="0">
            <MudText Typo="Typo.h4" Color="Color.Primary">@CompletedStepCount / @SetupSteps.Count</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">steps complete</MudText>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <MudPaper Elevation="1" Class="surface-panel">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Color="Color.Secondary">Loading setup status...</MudText>
        </MudPaper>
    }
    else if (!string.IsNullOrWhiteSpace(_pageError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_pageError</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync" Class="mt-4">Retry</MudButton>
    }
    else
    {
        <div class="setup-grid">
            <aside class="setup-steps" aria-label="Setup steps">
                @foreach (var step in SetupSteps)
                {
                    var isActive = step.Key == _activeStepKey;
                    var isComplete = IsStepComplete(step.Key);
                    <MudButton Class="@($"setup-step {(isActive ? "active" : null)} {(isComplete ? "complete" : null)}")"
                               Variant="Variant.Text"
                               OnClick="@(() => SelectStep(step.Key))">
                        <span class="setup-step-index">@step.Number</span>
                        <span>
                            <strong>@step.Title</strong>
                            <small>@(isComplete ? "Complete" : step.Description)</small>
                        </span>
                    </MudButton>
                }
            </aside>

            <MudPaper Elevation="1" Class="surface-panel">
                @if (_status?.IsFirstRunComplete == true)
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Filled">Setup is complete. Redirecting to business onboarding...</MudAlert>
                }
                else
                {
                    @RenderActiveStep()
                }
            </MudPaper>
        </div>
    }
</div>

@code {
    private static readonly IReadOnlyList<WizardStep> SetupSteps =
    [
        new(1, "welcome", "Welcome", "Start here"),
        new(2, "llm-provider", "LLM Provider", "Chat model"),
        new(3, "model-capability-test", "Capability Test", "Provider checks"),
        new(4, "email-delivery", "Email Delivery", "Optional"),
        new(5, "finish", "Finish", "Unlock app")
    ];

    private SetupStatusResponse? _status;
    private IReadOnlyList<LlmProviderProfileResponse> _profiles = [];
    private ModelCapabilityTestResult? _capabilityResult;
    private string _activeStepKey = "welcome";
    private bool _isLoading = true;
    private bool _isBusy;
    private string? _pageError;
    private string? _stepMessage;
    private EmailDeliverySettingsResponse? _emailSettings;
    private string _smtpHost = string.Empty;
    private int _smtpPort = 587;
    private bool _smtpTls = true;
    private string? _smtpUsername;
    private string? _smtpPassword;
    private string _smtpFromAddress = string.Empty;
    private string _smtpFromName = "C-Sweet";
    private string _publicAppUrl = string.Empty;

    private Guid? _providerProfileId;
    private LlmProviderType _providerType = LlmProviderType.LmStudio;
    private string _providerName = "Local LM Studio";
    private string _baseUrl = "http://localhost:1234/v1";
    private string _apiKey = "lm-studio";
    private string _defaultChatModel = string.Empty;
    private string _defaultEmbeddingModel = string.Empty;
    private IReadOnlyList<ModelDescriptor> _availableModels = [];
    private bool _initialModelCatalogLoadRequested;
    private bool _isCheckingModelCatalog;
    private bool? _modelCatalogSucceeded;
    private string? _modelCatalogMessage;
    private int? _contextWindowTokens;
    private int? _maxOutputTokens;
    private bool _supportsStreaming = true;
    private bool _supportsToolCalling;
    private bool _supportsStructuredOutput;
    private bool _supportsVision;

    private int CompletedStepCount => SetupSteps.Count(step => IsStepComplete(step.Key));
    private bool CanFinish => RequiredPriorStepsComplete && _status?.DefaultChatProviderId is not null;
    private bool RequiredPriorStepsComplete => _status?.Steps.Where(x => x.IsRequired && x.Key != "finish").All(x => x.IsComplete) == true;
    private bool IsModelSelectDisabled => _isCheckingModelCatalog || (_availableModels.Count == 0 && string.IsNullOrWhiteSpace(_defaultChatModel));
    private bool SelectedChatModelMissingFromCatalog => !string.IsNullOrWhiteSpace(_defaultChatModel) &&
        !_availableModels.Any(model => string.Equals(model.Id, _defaultChatModel, StringComparison.Ordinal));
    private string ModelSelectPlaceholder => _isCheckingModelCatalog
        ? "Checking models..."
        : _availableModels.Count == 0
            ? "Blur Base URL to load models"
            : "Select a model";
    private string ModelCatalogFeedbackClass => _modelCatalogSucceeded switch
    {
        true => "setup-field-feedback setup-field-feedback-success",
        false => "setup-field-feedback setup-field-feedback-error",
        _ => "setup-field-feedback"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isLoading ||
            _activeStepKey != "llm-provider" ||
            _initialModelCatalogLoadRequested ||
            _availableModels.Count > 0)
        {
            return;
        }

        _initialModelCatalogLoadRequested = true;
        await PreviewModelCatalogAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _pageError = null;

        try
        {
            _status = await SetupApi.GetStatusAsync();
            _profiles = await LlmProviderApi.ListAsync();
            _emailSettings = await Http.GetFromJsonAsync<EmailDeliverySettingsResponse>("api/setup/email-delivery");
            ApplyEmailSettings();
            _providerProfileId ??= _status.DefaultChatProviderId ?? _profiles.LastOrDefault()?.Id;

            if (_status.IsFirstRunComplete)
            {
                Navigation.NavigateTo("/");
                return;
            }

            _activeStepKey = SetupWizardState.FirstIncompleteStepKey(SetupSteps.Select(x => x.Key).ToList(), _status);
        }
        catch
        {
            _pageError = "Unable to load setup status from the API.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task ContinueFromWelcomeAsync()
    {
        return CompleteStepAsync("welcome", "llm-provider");
    }

    private void BackToWelcome() => SelectStep("welcome");
    private void BackToProvider() => SelectStep("llm-provider");
    private void BackToCapabilityTest() => SelectStep("model-capability-test");
    private void BackToEmailDelivery() => SelectStep("email-delivery");

    private RenderFragment RenderActiveStep() => _activeStepKey switch
    {
        "welcome" => WelcomeStep,
        "llm-provider" => LlmProviderStep,
        "model-capability-test" => CapabilityTestStep,
        "email-delivery" => EmailDeliveryStep,
        "finish" => FinishStep,
        _ => WelcomeStep
    };

    private RenderFragment WelcomeStep => @<div>
        <div class="setup-step-heading">
            <MudText Typo="Typo.overline" Color="Color.Primary">Step 1</MudText>
            <MudText Typo="Typo.h5">Welcome to C-Sweet.</MudText>
            <MudText Color="Color.Secondary">Before creating your first business, connect a model provider and choose your account preferences.</MudText>
        </div>
        <MudStack Row="true" Class="setup-actions">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isBusy" OnClick="ContinueFromWelcomeAsync">Continue</MudButton>
        </MudStack>
    </div>;

    private RenderFragment LlmProviderStep => @<div>
        <div class="setup-step-heading">
            <MudText Typo="Typo.overline" Color="Color.Primary">Step 2</MudText>
            <MudText Typo="Typo.h5">LLM Provider</MudText>
            <MudText Color="Color.Secondary">Create the default chat provider profile. LM Studio is prefilled for local setup.</MudText>
        </div>

        <div class="setup-form-grid">
            <MudSelect T="LlmProviderType" Label="Provider Type" Value="_providerType" ValueChanged="OnProviderTypeChanged" Variant="Variant.Outlined">
                @foreach (var providerType in Enum.GetValues<LlmProviderType>())
                {
                    <MudSelectItem T="LlmProviderType" Value="@providerType">@ProviderTypeLabel(providerType)</MudSelectItem>
                }
            </MudSelect>
            <MudTextField Label="Provider Name" @bind-Value="_providerName" Variant="Variant.Outlined" />
            <div class="setup-form-wide">
                <MudTextField Label="Base URL" @bind-Value="_baseUrl" Immediate="true" OnBlur="@(_ => PreviewModelCatalogAsync())" Variant="Variant.Outlined" />
                @if (!string.IsNullOrWhiteSpace(_modelCatalogMessage))
                {
                    <MudText Typo="Typo.caption" Class="@ModelCatalogFeedbackClass">@_modelCatalogMessage</MudText>
                }
            </div>
            <MudTextField Class="setup-form-wide" Label="API Key / Token" @bind-Value="_apiKey" InputType="InputType.Password" autocomplete="off" Variant="Variant.Outlined" />
            <MudSelect T="string" Label="Default Chat Model" @bind-Value="_defaultChatModel" Disabled="@IsModelSelectDisabled" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@string.Empty">@ModelSelectPlaceholder</MudSelectItem>
                @if (SelectedChatModelMissingFromCatalog)
                {
                    <MudSelectItem T="string" Value="@_defaultChatModel">@_defaultChatModel</MudSelectItem>
                }
                @foreach (var model in _availableModels)
                {
                    <MudSelectItem T="string" Value="@model.Id">@model.Id</MudSelectItem>
                }
            </MudSelect>
            <MudTextField Label="Default Embedding Model" @bind-Value="_defaultEmbeddingModel" Variant="Variant.Outlined" />
            <MudNumericField T="int?" Label="Context Window Tokens" @bind-Value="_contextWindowTokens" Variant="Variant.Outlined" />
            <MudNumericField T="int?" Label="Max Output Tokens" @bind-Value="_maxOutputTokens" Variant="Variant.Outlined" />
        </div>

        <MudStack Row="true" Class="setup-toggle-row">
            <MudCheckBox T="bool" Label="Streaming" @bind-Value="_supportsStreaming" />
            <MudCheckBox T="bool" Label="Structured output" @bind-Value="_supportsStructuredOutput" />
            <MudCheckBox T="bool" Label="Tool calling" @bind-Value="_supportsToolCalling" />
            <MudCheckBox T="bool" Label="Vision" @bind-Value="_supportsVision" />
        </MudStack>

        @if (_profiles.Count > 0)
        {
            <MudStack Row="true" Class="setup-inline-list">
                <MudText Color="Color.Secondary">Existing profiles</MudText>
                @foreach (var profile in _profiles)
                {
                    <MudButton Size="Size.Small"
                               Variant="@(profile.Id == _providerProfileId ? Variant.Filled : Variant.Outlined)"
                               Color="@(profile.Id == _providerProfileId ? Color.Primary : Color.Secondary)"
                               OnClick="@(() => SelectProvider(profile))">
                        @profile.Name
                    </MudButton>
                }
            </MudStack>
        }

        @StepMessage()
        <MudStack Row="true" Class="setup-actions">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="BackToWelcome">Back</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_isBusy || _isCheckingModelCatalog || string.IsNullOrWhiteSpace(_defaultChatModel))" OnClick="CreateProviderAsync">
                @(_isBusy ? "Saving..." : "Save Provider")
            </MudButton>
        </MudStack>
    </div>;

    private RenderFragment CapabilityTestStep => @<div>
        <div class="setup-step-heading">
            <MudText Typo="Typo.overline" Color="Color.Primary">Step 3</MudText>
            <MudText Typo="Typo.h5">Model Capability Test</MudText>
            <MudText Color="Color.Secondary">Required checks must pass. Optional capabilities are recorded honestly if unsupported.</MudText>
        </div>

        @if (_providerProfileId is null)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Create or select a provider profile before running the capability test.</MudAlert>
        }
        else
        {
            <div class="setup-check-list">
                @CapabilityRow("Connection", _capabilityResult?.ConnectionSucceeded, required: true)
                @CapabilityRow("Model list", _capabilityResult?.ConnectionSucceeded, required: false)
                @CapabilityRow("Chat completion", _capabilityResult?.ChatSucceeded, required: true)
                @CapabilityRow("Streaming", _capabilityResult?.StreamingSucceeded, required: false)
                @CapabilityRow("Structured JSON output", _capabilityResult?.StructuredOutputSucceeded, required: false)
                @CapabilityRow("Tool calling", _capabilityResult?.ToolCallingSucceeded, required: false)
                @CapabilityRow("Embeddings", null, required: false)
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_capabilityResult?.FailureMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-4">@_capabilityResult.FailureMessage</MudAlert>
        }

        @StepMessage()
        <MudStack Row="true" Class="setup-actions">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="BackToProvider">Back</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_isBusy || _providerProfileId is null)" OnClick="RunCapabilityTestAsync">
                @(_isBusy ? "Testing..." : "Run Test")
            </MudButton>
        </MudStack>
    </div>;

    private RenderFragment EmailDeliveryStep => @<div>
        <div class="setup-step-heading">
            <MudText Typo="Typo.overline" Color="Color.Primary">Step 4</MudText>
            <MudText Typo="Typo.h5">Email Delivery <MudChip T="string" Size="Size.Small">Optional</MudChip></MudText>
            <MudText Color="Color.Secondary">Configure SMTP for email verification, password recovery, and future invitations. You can safely skip this and return later.</MudText>
        </div>
        <div class="setup-form-grid">
            <MudTextField Label="SMTP Host" @bind-Value="_smtpHost" Variant="Variant.Outlined" />
            <MudNumericField T="int" Label="Port" @bind-Value="_smtpPort" Variant="Variant.Outlined" />
            <MudTextField Label="Username (optional)" @bind-Value="_smtpUsername" Variant="Variant.Outlined" />
            <MudTextField Label="Password" @bind-Value="_smtpPassword" InputType="InputType.Password" Placeholder="@(_emailSettings?.HasPassword == true ? "Saved password (leave blank to keep)" : null)" Variant="Variant.Outlined" />
            <MudTextField Label="Sender Email" @bind-Value="_smtpFromAddress" InputType="InputType.Email" Variant="Variant.Outlined" />
            <MudTextField Label="Sender Name" @bind-Value="_smtpFromName" Variant="Variant.Outlined" />
            <MudTextField Class="setup-form-wide" Label="Public App URL" @bind-Value="_publicAppUrl" Variant="Variant.Outlined" />
            <MudCheckBox T="bool" @bind-Value="_smtpTls" Label="Use TLS" />
        </div>
        @if (_emailSettings?.IsReady == true)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mt-4">Email delivery was tested successfully.</MudAlert>
        }
        @StepMessage()
        <MudStack Row="true" Class="setup-actions">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="BackToCapabilityTest">Back</MudButton>
            <MudButton Variant="Variant.Text" Disabled="@_isBusy" OnClick="SkipEmailDeliveryAsync">Skip for now</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@_isBusy" OnClick="SaveEmailDeliveryAsync">Save</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isBusy" OnClick="TestEmailDeliveryAsync">Save &amp; Test</MudButton>
        </MudStack>
    </div>;

    private RenderFragment FinishStep => @<div>
        <div class="setup-step-heading">
            <MudText Typo="Typo.overline" Color="Color.Primary">Step 5</MudText>
            <MudText Typo="Typo.h5">Finish Setup</MudText>
            <MudText Color="Color.Secondary">Complete first-run setup and unlock business onboarding.</MudText>
        </div>

        <div class="setup-check-list">
            @CapabilityRow("Required steps complete", RequiredPriorStepsComplete, required: true)
            @CapabilityRow("Default chat provider selected", _status?.DefaultChatProviderId is not null, required: true)
            @CapabilityRow("Last capability test had chat success", IsStepComplete("model-capability-test"), required: true)
            @CapabilityRow("Email delivery tested", _emailSettings?.IsReady, required: false)
        </div>

        @StepMessage()
        <MudStack Row="true" Class="setup-actions">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="BackToEmailDelivery">Back</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(_isBusy || !CanFinish)" OnClick="FinishSetupAsync">
                @(_isBusy ? "Finishing..." : "Complete Setup")
            </MudButton>
        </MudStack>
    </div>;

    private RenderFragment CapabilityRow(string label, bool? value, bool required) => @<div class="setup-check-row">
        <span class="@CheckClass(value, required)">@CheckGlyph(value, required)</span>
        <span>@label</span>
        <small>@CheckText(value, required)</small>
    </div>;

    private RenderFragment StepMessage() => @<div>
        @if (!string.IsNullOrWhiteSpace(_stepMessage))
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">@_stepMessage</MudAlert>
        }
    </div>;

    private async Task OnProviderTypeChanged(LlmProviderType providerType)
    {
        _providerType = providerType;
        ApplyProviderPreset();

        if (_providerType == LlmProviderType.LmStudio)
        {
            _initialModelCatalogLoadRequested = true;
            await PreviewModelCatalogAsync();
        }
    }

    private async Task CreateProviderAsync()
    {
        _isBusy = true;
        _stepMessage = null;

        try
        {
            var profile = await LlmProviderApi.CreateAsync(new CreateLlmProviderProfileRequest(
                _providerName,
                _providerType,
                _baseUrl,
                string.IsNullOrWhiteSpace(_apiKey) ? null : _apiKey,
                _defaultChatModel,
                string.IsNullOrWhiteSpace(_defaultEmbeddingModel) ? null : _defaultEmbeddingModel,
                _contextWindowTokens,
                _maxOutputTokens,
                _supportsStreaming,
                _supportsToolCalling,
                _supportsStructuredOutput,
                _supportsVision));

            _providerProfileId = profile.Id;
            await CompleteStepAsync("llm-provider", "model-capability-test");
            _profiles = await LlmProviderApi.ListAsync();
            _stepMessage = "Provider profile saved.";
        }
        catch (Exception ex)
        {
            _stepMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task PreviewModelCatalogAsync()
    {
        _modelCatalogMessage = null;
        _modelCatalogSucceeded = null;

        if (!Uri.TryCreate(_baseUrl.Trim(), UriKind.Absolute, out var baseUri) ||
            (baseUri.Scheme != Uri.UriSchemeHttp && baseUri.Scheme != Uri.UriSchemeHttps))
        {
            _availableModels = [];
            _modelCatalogSucceeded = false;
            _modelCatalogMessage = "Enter a valid HTTP or HTTPS base URL.";
            return;
        }

        _isCheckingModelCatalog = true;

        try
        {
            var result = await LlmProviderApi.PreviewModelCatalogAsync(new PreviewModelCatalogRequest(
                _providerType,
                _baseUrl.Trim(),
                string.IsNullOrWhiteSpace(_apiKey) ? null : _apiKey));

            _availableModels = result.Models;
            _modelCatalogSucceeded = result.Succeeded;
            _modelCatalogMessage = result.Message ?? (result.Succeeded
                ? $"Found {result.Models.Count} model(s)."
                : "Unable to load models from this provider.");

            if (result.Models.Count > 0 && (string.IsNullOrWhiteSpace(_defaultChatModel) || SelectedChatModelMissingFromCatalog))
            {
                _defaultChatModel = result.Models[0].Id;
            }
        }
        catch
        {
            _availableModels = [];
            _modelCatalogSucceeded = false;
            _modelCatalogMessage = "Unable to check this provider. Confirm the API is running and the base URL is reachable.";
        }
        finally
        {
            _isCheckingModelCatalog = false;
        }
    }

    private async Task RunCapabilityTestAsync()
    {
        if (_providerProfileId is null)
        {
            return;
        }

        _isBusy = true;
        _stepMessage = null;
        _capabilityResult = null;

        try
        {
            _capabilityResult = await LlmProviderApi.TestAsync(_providerProfileId.Value);

            if (_capabilityResult.ConnectionSucceeded && _capabilityResult.ChatSucceeded)
            {
                var defaultResult = await LlmProviderApi.SetDefaultChatProviderAsync(_providerProfileId.Value);
                if (!defaultResult.Succeeded)
                {
                    _stepMessage = defaultResult.Message;
                    return;
                }

                await CompleteStepAsync("model-capability-test", "email-delivery");
                _stepMessage = SetupWizardState.ProviderTestMessage(_capabilityResult);
            }
            else
            {
                _stepMessage = SetupWizardState.ProviderTestMessage(_capabilityResult);
            }
        }
        catch (Exception ex)
        {
            _stepMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ApplyEmailSettings()
    {
        if (_emailSettings is null) return;
        _smtpHost = _emailSettings.Host;
        _smtpPort = _emailSettings.Port;
        _smtpTls = _emailSettings.EnableSsl;
        _smtpUsername = _emailSettings.UserName;
        _smtpFromAddress = _emailSettings.FromAddress;
        _smtpFromName = _emailSettings.FromName;
        _publicAppUrl = string.IsNullOrWhiteSpace(_emailSettings.PublicAppUrl) ? Navigation.BaseUri.TrimEnd('/') : _emailSettings.PublicAppUrl;
    }

    private async Task<bool> SaveEmailDeliveryAsync()
    {
        _isBusy = true;
        _stepMessage = null;
        try
        {
            var request = new UpdateEmailDeliverySettingsRequest(_smtpHost, _smtpPort, _smtpTls, _smtpUsername,
                string.IsNullOrEmpty(_smtpPassword) ? null : _smtpPassword, false, _smtpFromAddress, _smtpFromName, _publicAppUrl);
            var response = await Http.PutAsJsonAsync("api/setup/email-delivery", request);
            var result = await response.Content.ReadFromJsonAsync<EmailDeliveryActionResponse>();
            _stepMessage = result?.Message ?? "Email delivery settings could not be saved.";
            if (result?.Succeeded == true)
            {
                _emailSettings = result.Settings;
                _smtpPassword = null;
                return true;
            }
            return false;
        }
        finally { _isBusy = false; }
    }

    private async Task TestEmailDeliveryAsync()
    {
        if (!await SaveEmailDeliveryAsync()) return;
        _isBusy = true;
        try
        {
            var response = await Http.PostAsync("api/setup/email-delivery/test", null);
            var result = await response.Content.ReadFromJsonAsync<EmailDeliveryActionResponse>();
            _stepMessage = result?.Message ?? "The test email could not be delivered.";
            if (result?.Succeeded == true)
            {
                _emailSettings = result.Settings;
                if (AuthSession.Current?.IsEmailConfirmed == false && !string.IsNullOrWhiteSpace(AuthSession.Current.Email))
                {
                    await AuthenticationApi.ResendConfirmationAsync(AuthSession.Current.Email);
                    _stepMessage += " A verification email was also sent.";
                }
                await CompleteStepAsync("email-delivery", "finish");
            }
        }
        finally { _isBusy = false; }
    }

    private async Task SkipEmailDeliveryAsync()
    {
        await CompleteStepAsync("email-delivery", "finish");
        _stepMessage = "Email delivery skipped. Root recovery codes remain available, and SMTP can be configured later.";
    }

    private async Task FinishSetupAsync()
    {
        _isBusy = true;
        _stepMessage = null;

        try
        {
            var result = await SetupApi.CompleteSetupAsync();
            _status = result.Status ?? _status;

            if (result.Succeeded)
            {
                Navigation.NavigateTo("/");
                return;
            }

            _stepMessage = result.Message ?? "Setup could not be completed.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CompleteStepAsync(string key, string nextStepKey)
    {
        _isBusy = true;
        _stepMessage = null;

        var result = await SetupApi.CompleteStepAsync(key);
        _status = result.Status ?? _status;

        if (result.Succeeded)
        {
            _activeStepKey = nextStepKey;
        }
        else
        {
            _stepMessage = result.Message;
        }

        _isBusy = false;
    }

    private void SelectStep(string key)
    {
        _activeStepKey = key;
        _stepMessage = null;
    }

    private void SelectProvider(LlmProviderProfileResponse profile)
    {
        _providerProfileId = profile.Id;
        _providerType = profile.ProviderType;
        _providerName = profile.Name;
        _baseUrl = profile.BaseUrl;
        _defaultChatModel = profile.DefaultChatModel;
        _defaultEmbeddingModel = profile.DefaultEmbeddingModel ?? string.Empty;
        _availableModels = string.IsNullOrWhiteSpace(profile.DefaultChatModel)
            ? []
            : [new ModelDescriptor(profile.DefaultChatModel, null)];
        _modelCatalogMessage = null;
        _modelCatalogSucceeded = null;
        _contextWindowTokens = profile.ContextWindowTokens;
        _maxOutputTokens = profile.MaxOutputTokens;
        _supportsStreaming = profile.SupportsStreaming;
        _supportsToolCalling = profile.SupportsToolCalling;
        _supportsStructuredOutput = profile.SupportsStructuredOutput;
        _supportsVision = profile.SupportsVision;
    }

    private void ApplyProviderPreset()
    {
        _defaultChatModel = string.Empty;
        _availableModels = [];
        _modelCatalogMessage = null;
        _modelCatalogSucceeded = null;

        if (_providerType != LlmProviderType.LmStudio)
        {
            return;
        }

        var defaults = SetupWizardState.LmStudioDefaults();
        _providerName = defaults.ProviderName;
        _baseUrl = defaults.BaseUrl;
        _apiKey = defaults.ApiKey;
        _supportsStreaming = defaults.SupportsStreaming;
        _supportsToolCalling = defaults.SupportsToolCalling;
        _supportsStructuredOutput = defaults.SupportsStructuredOutput;
        _supportsVision = defaults.SupportsVision;
    }

    private bool IsStepComplete(string key)
    {
        return _status?.Steps.Any(x => x.Key == key && x.IsComplete) == true;
    }

    private static string ProviderTypeLabel(LlmProviderType providerType)
    {
        return providerType switch
        {
            LlmProviderType.LmStudio => "LM Studio",
            LlmProviderType.OpenAiCompatible => "OpenAI-compatible",
            LlmProviderType.OpenAi => "OpenAI",
            LlmProviderType.AzureOpenAi => "Azure OpenAI",
            LlmProviderType.MicrosoftFoundry => "Microsoft Foundry",
            _ => providerType.ToString()
        };
    }

    private static string CheckGlyph(bool? value, bool required)
    {
        return value switch
        {
            true => "✓",
            false when required => "!",
            false => "!",
            _ => "•"
        };
    }

    private static string CheckClass(bool? value, bool required)
    {
        return value switch
        {
            true => "setup-check setup-check-success",
            false when required => "setup-check setup-check-error",
            false => "setup-check setup-check-warning",
            _ => "setup-check setup-check-muted"
        };
    }

    private static string CheckText(bool? value, bool required)
    {
        return value switch
        {
            true => "Passed",
            false when required => "Required",
            false => "Optional unsupported",
            _ when required => "Required",
            _ => "Optional"
        };
    }

    private sealed record WizardStep(int Number, string Key, string Title, string Description);
}

@page "/organizations/{OrganizationId:guid}/communications"
@page "/organizations/{OrganizationId:guid}/communications/{ChatId:guid}"
@using CSweet.Contracts.Communications
@using CSweet.Contracts.Core
@implements IAsyncDisposable
@inject HttpClient Http
@inject IChatTurnApiClient ChatTurns
@inject AppRealtimeState Realtime
@inject CommunicationUnreadState Unread
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Communications - C-Sweet</PageTitle>

<div class="hub-page">
    @if (_loading)
    {
        <div class="hub-centered"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /><span>Opening communications…</span></div>
    }
    else if (!string.IsNullOrWhiteSpace(_error) || _hub is null)
    {
        <div class="hub-centered">
            <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h6">Communications could not be opened</MudText>
            <MudText Color="Color.Secondary">@_error</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync">Try again</MudButton>
        </div>
    }
    else
    {
        <aside class="hub-sidebar">
            <div class="hub-brand">
                <div class="hub-logo"><MudIcon Icon="@Icons.Material.Filled.Forum" /></div>
                <div><strong>Communications</strong><span>C-Sweet workspace</span></div>
            </div>
            <div class="hub-search">
                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                <input aria-label="Search conversations" placeholder="Search" @bind="_search" @bind:event="oninput" />
            </div>
            <nav class="hub-nav" aria-label="Conversations">
                <div class="hub-section-title">
                    <span>Channels</span>
                    @if (_hub.CanManageChats)
                    {
                        <button title="Create channel" aria-label="Create channel" @onclick="OpenCreateGroup"><MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" /></button>
                    }
                </div>
                @foreach (var chat in FilteredChats.Where(x => !x.IsDirect))
                {
                    <button class="hub-nav-item @(chat.Id == _selected?.Id ? "active" : null) @(ChatUnread(chat) > 0 ? "unread" : null)" @onclick="@(() => SelectChatAsync(chat))">
                        <MudIcon Icon="@(chat.IsPrivate ? Icons.Material.Filled.Lock : Icons.Material.Filled.Tag)" Size="Size.Small" />
                        <span>@chat.Title</span>
                        @if (ChatUnread(chat) > 0) { <span class="hub-unread-count">@UnreadLabel(chat)</span> }
                    </button>
                }
                @if (!FilteredChats.Any(x => !x.IsDirect))
                {
                    <p class="hub-nav-empty">No channels yet</p>
                }

                <div class="hub-section-title direct"><span>Direct messages</span></div>
                @foreach (var chat in FilteredChats.Where(x => x.IsDirect))
                {
                    var person = chat.Participants.FirstOrDefault(x => x.OrganizationUserId != _hub.CurrentOrganizationUserId);
                    <button class="hub-nav-item @(chat.Id == _selected?.Id ? "active" : null) @(ChatUnread(chat) > 0 ? "unread" : null)" @onclick="@(() => SelectChatAsync(chat))">
                        <span class="presence-dot"></span><span>@chat.Title</span>
                        @if (ChatUnread(chat) > 0) { <span class="hub-unread-dot" aria-label="@($"{ChatUnread(chat)} unread messages")"></span> }
                        @if (person?.EmployeeType == "Agent") { <span class="agent-mark">AI</span> }
                    </button>
                }
            </nav>
            <a class="hub-settings" href="/settings/communications"><MudIcon Icon="@Icons.Material.Outlined.Settings" Size="Size.Small" /> Connected apps</a>
        </aside>

        <main class="hub-main">
            @if (_selected is null)
            {
                <div class="hub-empty">
                    <div class="hub-empty-icon"><MudIcon Icon="@Icons.Material.Outlined.Forum" Size="Size.Large" /></div>
                    <MudText Typo="Typo.h5">Your company conversations live here</MudText>
                    <MudText Color="Color.Secondary">Choose a channel, or start a direct message with a teammate.</MudText>
                </div>
            }
            else
            {
                <header class="hub-chat-header">
                    <div>
                        <div class="hub-title-line">
                            <MudIcon Icon="@(_selected.IsDirect ? Icons.Material.Filled.AlternateEmail : _selected.IsPrivate ? Icons.Material.Filled.Lock : Icons.Material.Filled.Tag)" />
                            <strong>@_selected.Title</strong>
                        </div>
                        <span>@(_selected.Description ?? ParticipantSummary(_selected))</span>
                    </div>
                    <div class="hub-header-actions">
                        <button title="Members" @onclick="@(() => _showMembers = !_showMembers)"><MudIcon Icon="@Icons.Material.Outlined.Group" /><span>@_selected.Participants.Count</span></button>
                        @if (_selected.CanManage)
                        {
                            <button title="Manage channel" @onclick="OpenEdit"><MudIcon Icon="@Icons.Material.Outlined.Edit" /></button>
                        }
                    </div>
                </header>

                @if (!string.IsNullOrWhiteSpace(_notice))
                {
                    <div class="hub-notice">@_notice</div>
                }

                <section class="hub-message-list" role="log" aria-live="polite" @ref="_messageList">
                    @if (_messages.Count == 0)
                    {
                        <div class="hub-welcome">
                            <div class="hub-welcome-icon">@(_selected.IsDirect ? "@" : "#")</div>
                            <MudText Typo="Typo.h5">This is the start of @_selected.Title</MudText>
                            <MudText Color="Color.Secondary">Keep decisions, context, and work moving in one place.</MudText>
                        </div>
                    }
                    @foreach (var message in _messages)
                    {
                        <article class="hub-message @(message.SenderOrganizationUserId == _hub.CurrentOrganizationUserId ? "mine" : null)">
                            <div class="hub-avatar @AvatarClass(message.SenderEmployeeType)">@Initials(message.SenderDisplayName)</div>
                            <div class="hub-message-body">
                                <div class="hub-message-meta">
                                    <strong>@message.SenderDisplayName</strong>
                                    @if (message.SenderEmployeeType == "Agent") { <span>AGENT</span> }
                                    <time>@message.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</time>
                                    @if (message.ChatTurnId is Guid messageTurnId &&
                                        _turns.TryGetValue(messageTurnId, out var messageTurn) &&
                                        messageTurn.Turn.AssistantMessageId == message.Id)
                                    {
                                        @ThinkingButton(messageTurn)
                                    }
                                </div>
                                 <ChatMarkdown Content="@message.Content" />
                                @if (message.Decision is { } decision)
                                {
                                    <section class="executive-decision-card" aria-label="Question">
                                        <header>
                                            <span>QUESTION</span>
                                            <strong>@decision.Prompt</strong>
                                        </header>
                                        @if (decision.Status == "Pending")
                                        {
                                            <div class="executive-decision-options">
                                                @foreach (var option in decision.Options)
                                                {
                                                    <label class="@(option.Recommended ? "recommended" : null)">
                                                        <input type="radio" name="@($"decision-{decision.Id}")"
                                                               checked="@SelectedDecisionOption(decision.Id, option.Id)"
                                                               @onchange="@(() => SelectDecisionOption(decision.Id, option.Id))" />
                                                        <span><strong>@option.Label</strong>
                                                            @if (option.Recommended) { <small class="recommendation-badge">RECOMMENDED</small> }
                                                            @if (!string.IsNullOrWhiteSpace(option.Description)) { <small>@option.Description</small> }
                                                        </span>
                                                    </label>
                                                }
                                                <label>
                                                    <input type="radio" name="@($"decision-{decision.Id}")"
                                                           checked="@SelectedDecisionOption(decision.Id, SomethingElseKey)"
                                                           @onchange="@(() => SelectDecisionOption(decision.Id, SomethingElseKey))" />
                                                    <span><strong>Something else</strong><small>Give the agent a different direction.</small></span>
                                                </label>
                                                @if (SelectedDecisionOption(decision.Id, SomethingElseKey))
                                                {
                                                    <textarea aria-label="Something else" placeholder="Your direction"
                                                              value="@DecisionOther(decision.Id)"
                                                              @oninput="@(e => SetDecisionOther(decision.Id, e.Value?.ToString()))"></textarea>
                                                }
                                            </div>
                                            @if (_decisionErrors.TryGetValue(decision.Id, out var decisionError))
                                            {
                                                <div class="executive-decision-error">@decisionError</div>
                                            }
                                            <footer>
                                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                                           Disabled="@(!CanSubmitDecision(decision.Id) || _decisionBusy.Contains(decision.Id))"
                                                           OnClick="@(() => SubmitDecisionAsync(message, decision))">Submit</MudButton>
                                            </footer>
                                        }
                                        else
                                        {
                                            <div class="executive-decision-answer">
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                                <span>@DecisionAnswer(decision)</span>
                                            </div>
                                        }
                                    </section>
                                }
                            </div>
                        </article>
                    }
                    @foreach (var pending in ActiveTurns)
                    {
                        <article class="hub-message hub-message-pending">
                            <div class="hub-avatar agent">AI</div>
                            <div class="hub-message-body">
                                <div class="hub-message-meta">
                                    <strong>@_selected.Title</strong><span>AGENT</span>
                                    <time>@pending.Turn.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</time>
                                    @ThinkingButton(pending)
                                </div>
                                @if (string.IsNullOrWhiteSpace(pending.StreamingText))
                                {
                                    <div class="hub-turn-running"><MudProgressLinear Indeterminate="true" Color="Color.Primary" /><span>The agent turn is running.</span></div>
                                }
                                else
                                {
                                    <ChatMarkdown Content="@pending.StreamingText" />
                                }
                            </div>
                        </article>
                    }
                </section>

                <footer class="hub-composer">
                    <MudTextField @bind-Value="_draft" Placeholder="@ComposerPlaceholder"
                                  Variant="Variant.Outlined" Lines="2" Immediate="true" OnKeyDown="OnComposerKeyDown" Disabled="@(_sending || ComposerBlocked)" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SendAsync"
                               Disabled="@(_sending || ComposerBlocked || string.IsNullOrWhiteSpace(_draft))" EndIcon="@Icons.Material.Filled.Send">Send</MudButton>
                </footer>
            }
        </main>

        <aside class="hub-people @(_showMembers ? "open" : null)">
            <div class="hub-people-header"><strong>@(_selected is null ? "People" : "Members")</strong><button @onclick="@(() => _showMembers = false)"><MudIcon Icon="@Icons.Material.Filled.Close" /></button></div>
            @foreach (var person in VisiblePeople)
            {
                <button class="hub-person" @onclick="@(() => StartDirectAsync(person))" disabled="@(person.Id == _hub.CurrentOrganizationUserId)">
                    <span class="hub-avatar @AvatarClass(person.EmployeeType)">@Initials(person.DisplayName)</span>
                    <span><strong>@person.DisplayName</strong><small>@(person.EmployeeType == "Agent" ? "AI employee" : person.RoleName ?? "Team member")</small></span>
                    <span class="presence-dot"></span>
                </button>
            }
        </aside>

        @if (_showEditor)
        {
            <div class="hub-dialog-backdrop" @onclick="CloseEditor">
                <section class="hub-dialog" role="dialog" aria-modal="true" aria-labelledby="chat-editor-title" @onclick:stopPropagation="true">
                    <header><div><span>@(_editing is null ? "NEW CHANNEL" : "CHANNEL SETTINGS")</span><h2 id="chat-editor-title">@(_editing is null ? "Create a place to work" : $"Manage #{_editing.Title}")</h2></div><button @onclick="CloseEditor"><MudIcon Icon="@Icons.Material.Filled.Close" /></button></header>
                    @if (!string.IsNullOrWhiteSpace(_editorError)) { <MudAlert Severity="Severity.Error" Dense="true">@_editorError</MudAlert> }
                    <MudTextField Label="Channel name" @bind-Value="_editorTitle" Variant="Variant.Outlined" Immediate="true" />
                    <MudTextField Label="Description" @bind-Value="_editorDescription" Variant="Variant.Outlined" Lines="2" />
                    <MudCheckBox T="bool" @bind-Value="_editorPrivate" Label="Private channel" />
                    @if (_hub.Audiences.Count > 0)
                    {
                        <div class="hub-editor-section"><strong>Add a whole group</strong><span>Role-based departments and active product workstreams stay easy to select.</span>
                            <div class="hub-audience-list">
                                @foreach (var audience in _hub.Audiences)
                                {
                                    <button class="@(_selectedAudiences.Contains(AudienceKey(audience)) ? "selected" : null)" @onclick="@(() => ToggleAudience(audience))">
                                        <MudIcon Icon="@(audience.Kind == "Workstream" ? Icons.Material.Outlined.RocketLaunch : Icons.Material.Outlined.CorporateFare)" />
                                        <span>@audience.Name<small>@audience.Kind · @audience.OrganizationUserIds.Count people</small></span>
                                        <MudIcon Icon="@(_selectedAudiences.Contains(AudienceKey(audience)) ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.AddCircleOutline)" />
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    <div class="hub-editor-section"><strong>Members</strong><span>@_selectedMembers.Count selected</span>
                        <div class="hub-member-grid">
                            @foreach (var person in _hub.People)
                            {
                                <label><input type="checkbox" checked="@_selectedMembers.Contains(person.Id)" @onchange="@(() => ToggleMember(person.Id))" /><span class="hub-avatar @AvatarClass(person.EmployeeType)">@Initials(person.DisplayName)</span><span>@person.DisplayName<small>@(person.RoleName ?? person.EmployeeType)</small></span></label>
                            }
                        </div>
                    </div>
                    @if (_confirmArchive)
                    {
                        <MudAlert Severity="Severity.Warning">Archive this channel? Its history will be preserved and it will disappear from the workspace.</MudAlert>
                    }
                    <footer>
                        @if (_editing is not null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="ArchiveAsync">@(_confirmArchive ? "Confirm archive" : "Archive channel")</MudButton>
                        }
                        <span></span><MudButton Variant="Variant.Text" OnClick="CloseEditor">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_editorBusy" OnClick="SaveEditorAsync">@(_editing is null ? "Create channel" : "Save changes")</MudButton>
                    </footer>
                </section>
            </div>
        }
    }
</div>

<MudDialog @bind-Visible="_thinkingDialogOpen" Options="_thinkingDialogOptions">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.h6">Memory &amp; thinking</MudText>
                @if (_thinkingDialogTurn is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@TraceSummary(_thinkingDialogTurn)</MudText>
                }
            </div>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_thinkingDialogLoading)
        {
            <div class="thinking-dialog-loading" role="status">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                <span>Loading memory and thinking output...</span>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_thinkingDialogError))
        {
            <MudAlert Severity="Severity.Error">@_thinkingDialogError</MudAlert>
        }
        else if (_thinkingDialogTurn is { } dialogTurn)
        {
            <div class="thinking-dialog @TraceClass(dialogTurn.Turn.Status)">
                <div class="chat-trace-events" role="list" aria-label="Memory and thinking output" tabindex="0">
                    @foreach (var traceEvent in dialogTurn.Events.OrderBy(x => x.Sequence))
                    {
                        <div class="chat-trace-event" role="listitem">
                            <div><strong>@traceEvent.Title</strong><small>@traceEvent.OccurredAt.ToLocalTime().ToString("T") @if (traceEvent.DurationMs.HasValue) { <span>· @traceEvent.DurationMs ms</span> }</small></div>
                            @if (!string.IsNullOrWhiteSpace(traceEvent.Summary)) { <pre>@traceEvent.Summary</pre> }
                            @if (traceEvent.Details.HasValue) { <details><summary>Structured details</summary><pre>@traceEvent.Details.Value.ToString()</pre></details> }
                        </div>
                    }
                    @if (dialogTurn.Events.Count == 0)
                    {
                        <div class="thinking-dialog-empty">No memory or thinking output has been recorded yet.</div>
                    }
                </div>
            </div>
        }
    </DialogContent>
    <DialogActions>
        @if (_thinkingDialogTurn is { } actionTurn)
        {
            @if (!IsTerminal(actionTurn.Turn.Status))
            {
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error" OnClick="@(() => CancelTurnAsync(actionTurn))">Cancel turn</MudButton>
            }
            else if (actionTurn.Turn.Status is "Failed" or "CompletedWithWarnings" or "Cancelled")
            {
                <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Refresh" Disabled="@HasActiveTurnFor(actionTurn)" OnClick="@(() => RetryTurnAsync(actionTurn))">Retry</MudButton>
            }
        }
        <MudButton Variant="Variant.Text" OnClick="CloseThinkingDialog">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid OrganizationId { get; set; }
    [Parameter] public Guid? ChatId { get; set; }
    private readonly CancellationTokenSource _disposeCts = new();
    private CancellationTokenSource? _chatCts;
    private IJSObjectReference? _communicationsModule;
    private ElementReference _messageList;
    private CommunicationHubResponse? _hub;
    private CommunicationChatResponse? _selected;
    private CommunicationChatResponse? _editing;
    private readonly List<CommunicationHubMessageResponse> _messages = [];
    private readonly Dictionary<Guid, TurnView> _turns = [];
    private readonly HashSet<Guid> _observingTurns = [];
    private readonly HashSet<Guid> _selectedMembers = [];
    private readonly HashSet<string> _selectedAudiences = [];
    private readonly Dictionary<Guid, string> _decisionSelections = [];
    private readonly Dictionary<Guid, string> _decisionOther = [];
    private readonly HashSet<Guid> _decisionBusy = [];
    private readonly Dictionary<Guid, string> _decisionErrors = [];
    private const string SomethingElseKey = "__something_else__";
    private bool _loading = true, _sending, _showMembers, _showEditor, _editorBusy, _editorPrivate, _confirmArchive;
    private string _search = string.Empty, _draft = string.Empty, _editorTitle = string.Empty, _editorDescription = string.Empty;
    private string? _error, _notice, _editorError;
    private readonly DialogOptions _thinkingDialogOptions = new() { MaxWidth = MaxWidth.Large, FullWidth = true };
    private TurnView? _thinkingDialogTurn;
    private bool _thinkingDialogOpen, _thinkingDialogLoading;
    private string? _thinkingDialogError;
    private bool _realtimeRefreshing;
    private bool _scrollToBottomPending;
    private Guid? _observedChatId;
    private string BasePath => $"api/organizations/{OrganizationId}/communications/hub";
    private IEnumerable<CommunicationChatResponse> FilteredChats => (_hub?.Chats ?? []).Where(x => string.IsNullOrWhiteSpace(_search) || x.Title.Contains(_search, StringComparison.OrdinalIgnoreCase));
    private IEnumerable<CommunicationPersonResponse> VisiblePeople => _selected is null || !_showMembers
        ? (_hub?.People ?? [])
        : _hub!.People.Where(x => _selected.Participants.Any(p => p.OrganizationUserId == x.Id));
    private string ComposerPlaceholder => _selected is null ? "Message" :
        $"Message {(_selected.IsDirect ? _selected.Title : $"#{_selected.Title}")}";
    private bool HasActiveTurn => _turns.Values.Any(x => !IsTerminal(x.Turn.Status));
    private bool ComposerBlocked => _selected?.IsDirect == true && HasActiveTurn;
    private IEnumerable<TurnView> ActiveTurns => _turns.Values
        .Where(x => !IsTerminal(x.Turn.Status) && x.Turn.AssistantMessageId is null)
        .OrderBy(x => x.Turn.CreatedAt);

    protected override void OnInitialized() => Realtime.EventReceived += OnRealtimeEvent;

    protected override Task OnParametersSetAsync() => LoadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_scrollToBottomPending) return;
        _scrollToBottomPending = false;

        try
        {
            var module = await GetCommunicationsModuleAsync();
            await module.InvokeVoidAsync("scrollToBottom", _messageList);
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
    }

    private async Task LoadAsync()
    {
        _loading = true; _error = null;
        try
        {
            _hub = await Http.GetFromJsonAsync<CommunicationHubResponse>(BasePath, _disposeCts.Token);
            _selected = ChatId.HasValue
                ? _hub?.Chats.FirstOrDefault(x => x.Id == ChatId.Value)
                : _hub?.Chats.FirstOrDefault(x => x.Id == _selected?.Id) ?? _hub?.Chats.FirstOrDefault();
            if (ChatId.HasValue && _selected is null)
                throw new InvalidOperationException("This conversation was not found or is not available to you.");
            if (_selected is not null) await LoadMessagesAsync();
        }
        catch (Exception ex) when (ex is not OperationCanceledException) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private Task SelectChatAsync(CommunicationChatResponse chat)
    {
        _showMembers = false;
        _thinkingDialogOpen = false;
        _notice = null;
        Navigation.NavigateTo(ChatHref(chat.Id));
        return Task.CompletedTask;
    }
    private async Task LoadMessagesAsync(bool markRead = true)
    {
        if (_selected is null) return;
        if (_observedChatId != _selected.Id)
        {
            _chatCts?.Cancel();
            _chatCts?.Dispose();
            _chatCts = CancellationTokenSource.CreateLinkedTokenSource(_disposeCts.Token);
            _observedChatId = _selected.Id;
            _observingTurns.Clear();
            _turns.Clear();
        }
        var token = _chatCts?.Token ?? _disposeCts.Token;
        var items = await Http.GetFromJsonAsync<List<CommunicationHubMessageResponse>>($"{BasePath}/chats/{_selected.Id}/messages", token) ?? [];
        _messages.Clear(); _messages.AddRange(items);
        await LoadTurnsAsync(_selected.Id, token);
        RequestScrollToBottom();
        if (markRead && items.LastOrDefault() is { } last)
        {
            var response = await Http.PostAsJsonAsync($"{BasePath}/chats/{_selected.Id}/read",
                new MarkCommunicationChatReadRequest(last.Sequence), token);
            if (response.IsSuccessStatusCode && await response.Content.ReadFromJsonAsync<CommunicationUnreadSummaryResponse>(token) is { } summary)
                Unread.Apply(summary);
        }
    }

    private async Task SendAsync()
    {
        if (_selected is null || ComposerBlocked || string.IsNullOrWhiteSpace(_draft)) return;
        _sending = true; _notice = null;
        var content = _draft.Trim(); _draft = string.Empty;
        try
        {
            var response = await Http.PostAsJsonAsync($"{BasePath}/chats/{_selected.Id}/messages",
                new SendCommunicationMessageRequest(content, Guid.NewGuid().ToString("N")), _disposeCts.Token);
            if (!response.IsSuccessStatusCode) throw new InvalidOperationException(await response.Content.ReadAsStringAsync(_disposeCts.Token));
            var sent = await response.Content.ReadFromJsonAsync<CommunicationMessageSendResponse>(_disposeCts.Token);
            if (sent is not null)
            {
                _messages.Add(sent.Message);
                RequestScrollToBottom();
                if (sent.Turn is not null)
                {
                    var view = new TurnView(sent.Turn);
                    _turns[sent.Turn.Id] = view;
                    _ = ObserveTurnAsync(_selected.Id, view, _chatCts?.Token ?? _disposeCts.Token);
                }
            }
        }
        catch (Exception ex) { _draft = content; _notice = ex.Message; }
        finally { _sending = false; }
    }

    private bool SelectedDecisionOption(Guid decisionId, string optionId) =>
        _decisionSelections.TryGetValue(decisionId, out var selected) && selected == optionId;

    private void SelectDecisionOption(Guid decisionId, string optionId)
    {
        _decisionSelections[decisionId] = optionId;
        _decisionErrors.Remove(decisionId);
    }

    private string DecisionOther(Guid decisionId) =>
        _decisionOther.TryGetValue(decisionId, out var value) ? value : string.Empty;

    private void SetDecisionOther(Guid decisionId, string? value)
    {
        _decisionOther[decisionId] = value ?? string.Empty;
        _decisionErrors.Remove(decisionId);
    }

    private bool CanSubmitDecision(Guid decisionId) =>
        _decisionSelections.TryGetValue(decisionId, out var selected) &&
        (selected != SomethingElseKey || !string.IsNullOrWhiteSpace(DecisionOther(decisionId)));

    private async Task SubmitDecisionAsync(CommunicationHubMessageResponse message, ExecutiveDecisionCardResponse decision)
    {
        if (_selected is null || !CanSubmitDecision(decision.Id) || !_decisionBusy.Add(decision.Id)) return;
        _decisionErrors.Remove(decision.Id);
        try
        {
            var selection = _decisionSelections[decision.Id];
            var request = new AnswerExecutiveDecisionRequest(
                selection == SomethingElseKey ? null : selection,
                selection == SomethingElseKey ? DecisionOther(decision.Id) : null,
                Guid.NewGuid().ToString("N"));
            var response = await Http.PostAsJsonAsync(
                $"{BasePath}/chats/{_selected.Id}/decisions/{decision.Id}/respond", request, _disposeCts.Token);
            var result = await response.Content.ReadFromJsonAsync<AnswerExecutiveDecisionResponse>(_disposeCts.Token);
            if (!response.IsSuccessStatusCode || result is null || !result.Succeeded)
                throw new InvalidOperationException(result?.Message ?? "The answer could not be submitted.");
            var index = _messages.FindIndex(x => x.Id == message.Id);
            if (index >= 0) _messages[index] = _messages[index] with { Decision = result.Decision };
            if (result.Turn is not null)
            {
                var view = new TurnView(result.Turn);
                _turns[result.Turn.Id] = view;
                _ = ObserveTurnAsync(_selected.Id, view, _chatCts?.Token ?? _disposeCts.Token);
            }
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            _decisionErrors[decision.Id] = exception.Message;
        }
        finally { _decisionBusy.Remove(decision.Id); }
    }

    private static string DecisionAnswer(ExecutiveDecisionCardResponse decision) =>
        decision.SelectedOptionId is { } selected
            ? decision.Options.FirstOrDefault(x => x.Id == selected)?.Label ?? "Answer submitted"
            : decision.FreeTextAnswer ?? decision.Status;

    private Task OnComposerKeyDown(KeyboardEventArgs args) => args.Key == "Enter" && !args.ShiftKey ? SendAsync() : Task.CompletedTask;

    private async Task StartDirectAsync(CommunicationPersonResponse person)
    {
        if (_hub is null || person.Id == _hub.CurrentOrganizationUserId) return;
        var existing = _hub.Chats.FirstOrDefault(x => x.IsDirect && x.Participants.Any(p => p.OrganizationUserId == person.Id));
        if (existing is not null) { Navigation.NavigateTo(ChatHref(existing.Id)); return; }
        var request = new CreateCommunicationChatRequest(null, null, true, true, [person.Id]);
        var response = await Http.PostAsJsonAsync($"{BasePath}/chats", request, _disposeCts.Token);
        if (!response.IsSuccessStatusCode) { _notice = await response.Content.ReadAsStringAsync(_disposeCts.Token); return; }
        var chat = await response.Content.ReadFromJsonAsync<CommunicationChatResponse>(_disposeCts.Token);
        if (chat is null) return;
        Navigation.NavigateTo(ChatHref(chat.Id));
    }

    private void OpenCreateGroup()
    {
        _editing = null; _editorTitle = string.Empty; _editorDescription = string.Empty; _editorPrivate = false;
        _selectedMembers.Clear(); if (_hub is not null) _selectedMembers.Add(_hub.CurrentOrganizationUserId);
        _selectedAudiences.Clear(); _editorError = null; _confirmArchive = false; _showEditor = true;
    }
    private void OpenEdit()
    {
        if (_selected is null) return;
        _editing = _selected; _editorTitle = _selected.Title; _editorDescription = _selected.Description ?? string.Empty; _editorPrivate = _selected.IsPrivate;
        _selectedMembers.Clear(); foreach (var member in _selected.Participants) _selectedMembers.Add(member.OrganizationUserId);
        _selectedAudiences.Clear(); _editorError = null; _confirmArchive = false; _showEditor = true;
    }
    private void CloseEditor() { if (_editorBusy) return; _showEditor = false; _confirmArchive = false; }
    private void ToggleMember(Guid id) { if (!_selectedMembers.Add(id)) _selectedMembers.Remove(id); }
    private static string AudienceKey(CommunicationAudienceResponse x) => $"{x.Kind}:{x.Id}";
    private void ToggleAudience(CommunicationAudienceResponse audience)
    {
        var key = AudienceKey(audience);
        if (!_selectedAudiences.Add(key)) _selectedAudiences.Remove(key);
        else foreach (var id in audience.OrganizationUserIds) _selectedMembers.Add(id);
    }

    private async Task SaveEditorAsync()
    {
        if (string.IsNullOrWhiteSpace(_editorTitle)) { _editorError = "Give the channel a name."; return; }
        _editorBusy = true; _editorError = null;
        try
        {
            var creating = _editing is null;
            var roles = SelectedAudienceIds("Role"); var workstreams = SelectedAudienceIds("Workstream");
            HttpResponseMessage response;
            if (_editing is null)
                response = await Http.PostAsJsonAsync($"{BasePath}/chats", new CreateCommunicationChatRequest(_editorTitle, _editorDescription, false, _editorPrivate, _selectedMembers.ToList(), roles, workstreams), _disposeCts.Token);
            else
                response = await Http.PutAsJsonAsync($"{BasePath}/chats/{_editing.Id}", new UpdateCommunicationChatRequest(_editorTitle, _editorDescription, _editorPrivate, _selectedMembers.ToList(), roles, workstreams), _disposeCts.Token);
            if (!response.IsSuccessStatusCode) { _editorError = await response.Content.ReadAsStringAsync(_disposeCts.Token); return; }
            var chat = await response.Content.ReadFromJsonAsync<CommunicationChatResponse>(_disposeCts.Token);
            _showEditor = false;
            if (creating && chat is not null) Navigation.NavigateTo(ChatHref(chat.Id));
            else await RefreshHubAsync(chat?.Id ?? _editing?.Id);
        }
        finally { _editorBusy = false; }
    }

    private async Task ArchiveAsync()
    {
        if (!_confirmArchive) { _confirmArchive = true; return; }
        if (_editing is null) return;
        _editorBusy = true;
        try
        {
            var response = await Http.DeleteAsync($"{BasePath}/chats/{_editing.Id}", _disposeCts.Token);
            if (!response.IsSuccessStatusCode) { _editorError = await response.Content.ReadAsStringAsync(_disposeCts.Token); return; }
            _showEditor = false;
            _selected = null;
            Navigation.NavigateTo($"/organizations/{OrganizationId}/communications");
        }
        finally { _editorBusy = false; }
    }

    private List<Guid> SelectedAudienceIds(string kind) => _hub?.Audiences.Where(x => x.Kind == kind && _selectedAudiences.Contains(AudienceKey(x))).Select(x => x.Id).ToList() ?? [];
    private async Task RefreshHubAsync(Guid? selectId = null, bool markRead = true)
    {
        _hub = await Http.GetFromJsonAsync<CommunicationHubResponse>(BasePath, _disposeCts.Token);
        var targetId = selectId ?? ChatId ?? _selected?.Id;
        _selected = _hub?.Chats.FirstOrDefault(x => x.Id == targetId) ?? _hub?.Chats.FirstOrDefault();
        if (_selected is not null) await LoadMessagesAsync(markRead); else _messages.Clear();
    }

    private async Task LoadTurnsAsync(Guid chatId, CancellationToken cancellationToken)
    {
        var snapshots = await ChatTurns.ListTurnsAsync(OrganizationId, chatId, cancellationToken);
        var ids = snapshots.Select(x => x.Id).ToHashSet();
        foreach (var removed in _turns.Keys.Where(x => !ids.Contains(x)).ToList()) _turns.Remove(removed);
        foreach (var snapshot in snapshots)
        {
            if (!_turns.TryGetValue(snapshot.Id, out var view))
            {
                view = new TurnView(snapshot)
                {
                    StreamingText = snapshot.PartialResponse
                };
                _turns[snapshot.Id] = view;
            }
            else
            {
                view.Turn = snapshot;
                if (string.IsNullOrEmpty(view.StreamingText)) view.StreamingText = snapshot.PartialResponse;
            }
            if (!IsTerminal(snapshot.Status)) _ = ObserveTurnAsync(chatId, view, cancellationToken);
        }
    }

    private async Task ObserveTurnAsync(Guid chatId, TurnView view, CancellationToken cancellationToken)
    {
        if (!_observingTurns.Add(view.Turn.Id)) return;
        try
        {
            while (!cancellationToken.IsCancellationRequested && _selected?.Id == chatId)
            {
                var cursor = view.Events.Count == 0 ? -1 : view.Events.Max(x => x.Sequence);
                try
                {
                    await foreach (var traceEvent in ChatTurns.StreamTurnEventsAsync(
                        OrganizationId, chatId, view.Turn.Id, cursor, cancellationToken))
                    {
                        if (view.Events.All(x => x.Sequence != traceEvent.Sequence)) view.Events.Add(traceEvent);
                        if (traceEvent.EventType == "turn.restarted") view.StreamingText = string.Empty;
                        if (traceEvent.EventType == "output.delta" && !string.IsNullOrEmpty(traceEvent.Summary))
                            view.StreamingText += traceEvent.Summary;
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested) { return; }
                catch
                {
                    await Task.Delay(TimeSpan.FromSeconds(2), cancellationToken);
                }

                var latest = await ChatTurns.GetTurnAsync(OrganizationId, chatId, view.Turn.Id, cancellationToken);
                if (latest is null) return;
                view.Turn = latest;
                if (!IsTerminal(latest.Status)) continue;
                var visible = await IsDocumentVisibleAsync();
                await RefreshHubAsync(chatId, visible);
                await InvokeAsync(StateHasChanged);
                return;
            }
        }
        finally
        {
            _observingTurns.Remove(view.Turn.Id);
        }
    }

    private RenderFragment ThinkingButton(TurnView view) => @<button type="button"
        class="hub-thinking-button"
        title="View memory and thinking"
        aria-label="View memory and thinking for this message"
        @onclick="@(() => OpenThinkingDialogAsync(view))">
        <MudIcon Icon="@Icons.Material.Outlined.Psychology" Size="Size.Small" />
    </button>;

    private async Task OpenThinkingDialogAsync(TurnView view)
    {
        if (_selected is null) return;

        var chatId = _selected.Id;
        _thinkingDialogTurn = view;
        _thinkingDialogError = null;
        _thinkingDialogLoading = true;
        _thinkingDialogOpen = true;

        try
        {
            var latest = await ChatTurns.GetTurnTraceAsync(OrganizationId, chatId, view.Turn.Id, _disposeCts.Token);
            foreach (var traceEvent in latest)
            {
                if (view.Events.All(x => x.Sequence != traceEvent.Sequence)) view.Events.Add(traceEvent);
            }
            view.Turn = await ChatTurns.GetTurnAsync(OrganizationId, chatId, view.Turn.Id, _disposeCts.Token) ?? view.Turn;
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            _thinkingDialogError = exception.Message;
        }
        finally
        {
            _thinkingDialogLoading = false;
        }
    }

    private void CloseThinkingDialog() => _thinkingDialogOpen = false;

    private async Task RetryTurnAsync(TurnView failed)
    {
        if (_selected is null || HasActiveTurnFor(failed)) return;
        _notice = null;
        try
        {
            var started = await ChatTurns.RetryTurnAsync(OrganizationId, _selected.Id, failed.Turn.Id, _disposeCts.Token);
            var view = new TurnView(started.Turn);
            _turns[started.Turn.Id] = view;
            await RefreshHubAsync(_selected.Id, markRead: false);
            _thinkingDialogOpen = false;
            _ = ObserveTurnAsync(_selected.Id, view, _chatCts?.Token ?? _disposeCts.Token);
        }
        catch (Exception ex) { _notice = ex.Message; }
    }

    private async Task CancelTurnAsync(TurnView view)
    {
        if (_selected is null) return;
        try
        {
            view.Turn = await ChatTurns.CancelTurnAsync(OrganizationId, _selected.Id, view.Turn.Id, _disposeCts.Token);
        }
        catch (Exception ex) { _notice = ex.Message; }
    }

    private static bool IsTerminal(string status) => status is "Completed" or "CompletedWithWarnings" or "Failed" or "Cancelled";
    private bool HasActiveTurnFor(TurnView view) => _turns.Values.Any(x =>
        x.Turn.Id != view.Turn.Id &&
        x.Turn.TargetAgentOrganizationUserId == view.Turn.TargetAgentOrganizationUserId &&
        !IsTerminal(x.Turn.Status));
    private static string TraceClass(string status) => status switch { "Failed" => "chat-trace-failed", "CompletedWithWarnings" => "chat-trace-warning", _ => string.Empty };
    private static string TraceSummary(TurnView view)
    {
        var duration = (view.Turn.CompletedAt ?? DateTimeOffset.UtcNow) - view.Turn.CreatedAt;
        return $"{view.Turn.Status} · {Math.Max(0, (int)duration.TotalSeconds)}s";
    }

    private string ChatHref(Guid chatId) => $"/organizations/{OrganizationId}/communications/{chatId}";

    private void OnRealtimeEvent(CSweet.Contracts.Realtime.AppRealtimeEventEnvelope envelope)
    {
        if (envelope.OrganizationId != OrganizationId ||
            !envelope.EventType.StartsWith("com.csweet.communication.", StringComparison.Ordinal)) return;
        _ = InvokeAsync(RefreshFromRealtimeAsync);
    }

    private async Task RefreshFromRealtimeAsync()
    {
        if (_realtimeRefreshing || _sending || _showEditor) return;
        _realtimeRefreshing = true;
        try
        {
            var visible = await IsDocumentVisibleAsync();
            await RefreshHubAsync(_selected?.Id, visible);
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
        finally { _realtimeRefreshing = false; }
    }

    private async Task<bool> IsDocumentVisibleAsync()
    {
        var module = await GetCommunicationsModuleAsync();
        return await module.InvokeAsync<bool>("isDocumentVisible");
    }

    private async Task<IJSObjectReference> GetCommunicationsModuleAsync() =>
        _communicationsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/CSweet.UI/js/communications.js");

    private void RequestScrollToBottom() => _scrollToBottomPending = true;

    private int ChatUnread(CommunicationChatResponse chat) =>
        Unread.ChatUnreadCounts.TryGetValue(chat.Id, out var count) ? count : chat.UnreadCount;
    private string UnreadLabel(CommunicationChatResponse chat) => ChatUnread(chat) > 99 ? "99+" : ChatUnread(chat).ToString();

    private static string ParticipantSummary(CommunicationChatResponse chat) => string.Join(", ", chat.Participants.Take(4).Select(x => x.DisplayName)) + (chat.Participants.Count > 4 ? $" +{chat.Participants.Count - 4}" : string.Empty);
    private static string AvatarClass(string type) => type == "Agent" ? "agent" : "human";
    private static string Initials(string name) => string.Join(string.Empty, name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => char.ToUpperInvariant(x[0])));
    private sealed class TurnView(ChatTurnResponse turn)
    {
        public ChatTurnResponse Turn { get; set; } = turn;
        public List<ChatTurnTraceEventResponse> Events { get; } = [];
        public string StreamingText { get; set; } = string.Empty;
    }

    public async ValueTask DisposeAsync()
    {
        Realtime.EventReceived -= OnRealtimeEvent;
        _chatCts?.Cancel();
        _chatCts?.Dispose();
        _disposeCts.Cancel();
        _disposeCts.Dispose();
        if (_communicationsModule is not null) await _communicationsModule.DisposeAsync();
    }
}

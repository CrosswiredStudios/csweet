@page "/organizations/{OrganizationId:guid}/communications"
@using CSweet.Contracts.Communications
@implements IDisposable
@inject HttpClient Http

<PageTitle>Communications - C-Sweet</PageTitle>

<div class="hub-page">
    @if (_loading)
    {
        <div class="hub-centered"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /><span>Opening communications…</span></div>
    }
    else if (!string.IsNullOrWhiteSpace(_error) || _hub is null)
    {
        <div class="hub-centered">
            <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h6">Communications could not be opened</MudText>
            <MudText Color="Color.Secondary">@_error</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync">Try again</MudButton>
        </div>
    }
    else
    {
        <aside class="hub-sidebar">
            <div class="hub-brand">
                <div class="hub-logo"><MudIcon Icon="@Icons.Material.Filled.Forum" /></div>
                <div><strong>Communications</strong><span>C-Sweet workspace</span></div>
            </div>
            <div class="hub-search">
                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                <input aria-label="Search conversations" placeholder="Search" @bind="_search" @bind:event="oninput" />
            </div>
            <nav class="hub-nav" aria-label="Conversations">
                <div class="hub-section-title">
                    <span>Channels</span>
                    @if (_hub.CanManageChats)
                    {
                        <button title="Create channel" aria-label="Create channel" @onclick="OpenCreateGroup"><MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" /></button>
                    }
                </div>
                @foreach (var chat in FilteredChats.Where(x => !x.IsDirect))
                {
                    <button class="hub-nav-item @(chat.Id == _selected?.Id ? "active" : null)" @onclick="@(() => SelectChatAsync(chat))">
                        <MudIcon Icon="@(chat.IsPrivate ? Icons.Material.Filled.Lock : Icons.Material.Filled.Tag)" Size="Size.Small" />
                        <span>@chat.Title</span>
                    </button>
                }
                @if (!FilteredChats.Any(x => !x.IsDirect))
                {
                    <p class="hub-nav-empty">No channels yet</p>
                }

                <div class="hub-section-title direct"><span>Direct messages</span></div>
                @foreach (var chat in FilteredChats.Where(x => x.IsDirect))
                {
                    var person = chat.Participants.FirstOrDefault(x => x.OrganizationUserId != _hub.CurrentOrganizationUserId);
                    <button class="hub-nav-item @(chat.Id == _selected?.Id ? "active" : null)" @onclick="@(() => SelectChatAsync(chat))">
                        <span class="presence-dot"></span><span>@chat.Title</span>
                        @if (person?.EmployeeType == "Agent") { <span class="agent-mark">AI</span> }
                    </button>
                }
            </nav>
            <a class="hub-settings" href="/settings/communications"><MudIcon Icon="@Icons.Material.Outlined.Settings" Size="Size.Small" /> Connected apps</a>
        </aside>

        <main class="hub-main">
            @if (_selected is null)
            {
                <div class="hub-empty">
                    <div class="hub-empty-icon"><MudIcon Icon="@Icons.Material.Outlined.Forum" Size="Size.Large" /></div>
                    <MudText Typo="Typo.h5">Your company conversations live here</MudText>
                    <MudText Color="Color.Secondary">Choose a channel, or start a direct message with a teammate.</MudText>
                </div>
            }
            else
            {
                <header class="hub-chat-header">
                    <div>
                        <div class="hub-title-line">
                            <MudIcon Icon="@(_selected.IsDirect ? Icons.Material.Filled.AlternateEmail : _selected.IsPrivate ? Icons.Material.Filled.Lock : Icons.Material.Filled.Tag)" />
                            <strong>@_selected.Title</strong>
                        </div>
                        <span>@(_selected.Description ?? ParticipantSummary(_selected))</span>
                    </div>
                    <div class="hub-header-actions">
                        <button title="Members" @onclick="@(() => _showMembers = !_showMembers)"><MudIcon Icon="@Icons.Material.Outlined.Group" /><span>@_selected.Participants.Count</span></button>
                        @if (_selected.CanManage)
                        {
                            <button title="Manage channel" @onclick="OpenEdit"><MudIcon Icon="@Icons.Material.Outlined.Edit" /></button>
                        }
                    </div>
                </header>

                @if (!string.IsNullOrWhiteSpace(_notice))
                {
                    <div class="hub-notice">@_notice</div>
                }

                <section class="hub-message-list" role="log" aria-live="polite">
                    @if (_messages.Count == 0)
                    {
                        <div class="hub-welcome">
                            <div class="hub-welcome-icon">@(_selected.IsDirect ? "@" : "#")</div>
                            <MudText Typo="Typo.h5">This is the start of @_selected.Title</MudText>
                            <MudText Color="Color.Secondary">Keep decisions, context, and work moving in one place.</MudText>
                        </div>
                    }
                    @foreach (var message in _messages)
                    {
                        <article class="hub-message @(message.SenderOrganizationUserId == _hub.CurrentOrganizationUserId ? "mine" : null)">
                            <div class="hub-avatar @AvatarClass(message.SenderEmployeeType)">@Initials(message.SenderDisplayName)</div>
                            <div>
                                <div class="hub-message-meta"><strong>@message.SenderDisplayName</strong>@if (message.SenderEmployeeType == "Agent") { <span>AGENT</span> }<time>@message.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</time></div>
                                <p>@message.Content</p>
                            </div>
                        </article>
                    }
                </section>

                <footer class="hub-composer">
                    <MudTextField @bind-Value="_draft" Placeholder="@ComposerPlaceholder"
                                  Variant="Variant.Outlined" Lines="2" Immediate="true" OnKeyDown="OnComposerKeyDown" Disabled="_sending" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SendAsync"
                               Disabled="@(_sending || string.IsNullOrWhiteSpace(_draft))" EndIcon="@Icons.Material.Filled.Send">Send</MudButton>
                </footer>
            }
        </main>

        <aside class="hub-people @(_showMembers ? "open" : null)">
            <div class="hub-people-header"><strong>@(_selected is null ? "People" : "Members")</strong><button @onclick="@(() => _showMembers = false)"><MudIcon Icon="@Icons.Material.Filled.Close" /></button></div>
            @foreach (var person in VisiblePeople)
            {
                <button class="hub-person" @onclick="@(() => StartDirectAsync(person))" disabled="@(person.Id == _hub.CurrentOrganizationUserId)">
                    <span class="hub-avatar @AvatarClass(person.EmployeeType)">@Initials(person.DisplayName)</span>
                    <span><strong>@person.DisplayName</strong><small>@(person.EmployeeType == "Agent" ? "AI employee" : person.RoleName ?? "Team member")</small></span>
                    <span class="presence-dot"></span>
                </button>
            }
        </aside>

        @if (_showEditor)
        {
            <div class="hub-dialog-backdrop" @onclick="CloseEditor">
                <section class="hub-dialog" role="dialog" aria-modal="true" aria-labelledby="chat-editor-title" @onclick:stopPropagation="true">
                    <header><div><span>@(_editing is null ? "NEW CHANNEL" : "CHANNEL SETTINGS")</span><h2 id="chat-editor-title">@(_editing is null ? "Create a place to work" : $"Manage #{_editing.Title}")</h2></div><button @onclick="CloseEditor"><MudIcon Icon="@Icons.Material.Filled.Close" /></button></header>
                    @if (!string.IsNullOrWhiteSpace(_editorError)) { <MudAlert Severity="Severity.Error" Dense="true">@_editorError</MudAlert> }
                    <MudTextField Label="Channel name" @bind-Value="_editorTitle" Variant="Variant.Outlined" Immediate="true" />
                    <MudTextField Label="Description" @bind-Value="_editorDescription" Variant="Variant.Outlined" Lines="2" />
                    <MudCheckBox T="bool" @bind-Value="_editorPrivate" Label="Private channel" />
                    @if (_hub.Audiences.Count > 0)
                    {
                        <div class="hub-editor-section"><strong>Add a whole group</strong><span>Role-based departments and active product workstreams stay easy to select.</span>
                            <div class="hub-audience-list">
                                @foreach (var audience in _hub.Audiences)
                                {
                                    <button class="@(_selectedAudiences.Contains(AudienceKey(audience)) ? "selected" : null)" @onclick="@(() => ToggleAudience(audience))">
                                        <MudIcon Icon="@(audience.Kind == "Workstream" ? Icons.Material.Outlined.RocketLaunch : Icons.Material.Outlined.CorporateFare)" />
                                        <span>@audience.Name<small>@audience.Kind · @audience.OrganizationUserIds.Count people</small></span>
                                        <MudIcon Icon="@(_selectedAudiences.Contains(AudienceKey(audience)) ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.AddCircleOutline)" />
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    <div class="hub-editor-section"><strong>Members</strong><span>@_selectedMembers.Count selected</span>
                        <div class="hub-member-grid">
                            @foreach (var person in _hub.People)
                            {
                                <label><input type="checkbox" checked="@_selectedMembers.Contains(person.Id)" @onchange="@(() => ToggleMember(person.Id))" /><span class="hub-avatar @AvatarClass(person.EmployeeType)">@Initials(person.DisplayName)</span><span>@person.DisplayName<small>@(person.RoleName ?? person.EmployeeType)</small></span></label>
                            }
                        </div>
                    </div>
                    @if (_confirmArchive)
                    {
                        <MudAlert Severity="Severity.Warning">Archive this channel? Its history will be preserved and it will disappear from the workspace.</MudAlert>
                    }
                    <footer>
                        @if (_editing is not null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="ArchiveAsync">@(_confirmArchive ? "Confirm archive" : "Archive channel")</MudButton>
                        }
                        <span></span><MudButton Variant="Variant.Text" OnClick="CloseEditor">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_editorBusy" OnClick="SaveEditorAsync">@(_editing is null ? "Create channel" : "Save changes")</MudButton>
                    </footer>
                </section>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid OrganizationId { get; set; }
    private readonly CancellationTokenSource _disposeCts = new();
    private CommunicationHubResponse? _hub;
    private CommunicationChatResponse? _selected;
    private CommunicationChatResponse? _editing;
    private readonly List<CommunicationHubMessageResponse> _messages = [];
    private readonly HashSet<Guid> _selectedMembers = [];
    private readonly HashSet<string> _selectedAudiences = [];
    private bool _loading = true, _sending, _showMembers, _showEditor, _editorBusy, _editorPrivate, _confirmArchive;
    private string _search = string.Empty, _draft = string.Empty, _editorTitle = string.Empty, _editorDescription = string.Empty;
    private string? _error, _notice, _editorError;
    private string BasePath => $"api/organizations/{OrganizationId}/communications/hub";
    private IEnumerable<CommunicationChatResponse> FilteredChats => (_hub?.Chats ?? []).Where(x => string.IsNullOrWhiteSpace(_search) || x.Title.Contains(_search, StringComparison.OrdinalIgnoreCase));
    private IEnumerable<CommunicationPersonResponse> VisiblePeople => _selected is null || !_showMembers
        ? (_hub?.People ?? [])
        : _hub!.People.Where(x => _selected.Participants.Any(p => p.OrganizationUserId == x.Id));
    private string ComposerPlaceholder => _selected is null ? "Message" :
        $"Message {(_selected.IsDirect ? _selected.Title : $"#{_selected.Title}")}";

    protected override Task OnParametersSetAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null;
        try
        {
            _hub = await Http.GetFromJsonAsync<CommunicationHubResponse>(BasePath, _disposeCts.Token);
            _selected = _hub?.Chats.FirstOrDefault(x => x.Id == _selected?.Id) ?? _hub?.Chats.FirstOrDefault();
            if (_selected is not null) await LoadMessagesAsync();
            _ = PollAsync();
        }
        catch (Exception ex) when (ex is not OperationCanceledException) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task PollAsync()
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (await timer.WaitForNextTickAsync(_disposeCts.Token))
            {
                if (_selected is not null && !_sending && !_showEditor)
                {
                    var latest = await Http.GetFromJsonAsync<List<CommunicationHubMessageResponse>>($"{BasePath}/chats/{_selected.Id}/messages", _disposeCts.Token) ?? [];
                    if (latest.Count != _messages.Count || latest.LastOrDefault()?.Id != _messages.LastOrDefault()?.Id)
                    {
                        _messages.Clear(); _messages.AddRange(latest); await InvokeAsync(StateHasChanged);
                    }
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task SelectChatAsync(CommunicationChatResponse chat) { _selected = chat; _showMembers = false; _notice = null; await LoadMessagesAsync(); }
    private async Task LoadMessagesAsync()
    {
        if (_selected is null) return;
        var items = await Http.GetFromJsonAsync<List<CommunicationHubMessageResponse>>($"{BasePath}/chats/{_selected.Id}/messages", _disposeCts.Token) ?? [];
        _messages.Clear(); _messages.AddRange(items);
    }

    private async Task SendAsync()
    {
        if (_selected is null || string.IsNullOrWhiteSpace(_draft)) return;
        _sending = true; _notice = null;
        var content = _draft.Trim(); _draft = string.Empty;
        try
        {
            var response = await Http.PostAsJsonAsync($"{BasePath}/chats/{_selected.Id}/messages", new SendCommunicationMessageRequest(content), _disposeCts.Token);
            if (!response.IsSuccessStatusCode) throw new InvalidOperationException(await response.Content.ReadAsStringAsync(_disposeCts.Token));
            var message = await response.Content.ReadFromJsonAsync<CommunicationHubMessageResponse>(_disposeCts.Token);
            if (message is not null) _messages.Add(message);
        }
        catch (Exception ex) { _draft = content; _notice = ex.Message; }
        finally { _sending = false; }
    }

    private Task OnComposerKeyDown(KeyboardEventArgs args) => args.Key == "Enter" && !args.ShiftKey ? SendAsync() : Task.CompletedTask;

    private async Task StartDirectAsync(CommunicationPersonResponse person)
    {
        if (_hub is null || person.Id == _hub.CurrentOrganizationUserId) return;
        var existing = _hub.Chats.FirstOrDefault(x => x.IsDirect && x.Participants.Any(p => p.OrganizationUserId == person.Id));
        if (existing is not null) { await SelectChatAsync(existing); return; }
        var request = new CreateCommunicationChatRequest(null, null, true, true, [person.Id]);
        var response = await Http.PostAsJsonAsync($"{BasePath}/chats", request, _disposeCts.Token);
        if (!response.IsSuccessStatusCode) { _notice = await response.Content.ReadAsStringAsync(_disposeCts.Token); return; }
        var chat = await response.Content.ReadFromJsonAsync<CommunicationChatResponse>(_disposeCts.Token);
        if (chat is null) return;
        await RefreshHubAsync(chat.Id);
    }

    private void OpenCreateGroup()
    {
        _editing = null; _editorTitle = string.Empty; _editorDescription = string.Empty; _editorPrivate = false;
        _selectedMembers.Clear(); if (_hub is not null) _selectedMembers.Add(_hub.CurrentOrganizationUserId);
        _selectedAudiences.Clear(); _editorError = null; _confirmArchive = false; _showEditor = true;
    }
    private void OpenEdit()
    {
        if (_selected is null) return;
        _editing = _selected; _editorTitle = _selected.Title; _editorDescription = _selected.Description ?? string.Empty; _editorPrivate = _selected.IsPrivate;
        _selectedMembers.Clear(); foreach (var member in _selected.Participants) _selectedMembers.Add(member.OrganizationUserId);
        _selectedAudiences.Clear(); _editorError = null; _confirmArchive = false; _showEditor = true;
    }
    private void CloseEditor() { if (_editorBusy) return; _showEditor = false; _confirmArchive = false; }
    private void ToggleMember(Guid id) { if (!_selectedMembers.Add(id)) _selectedMembers.Remove(id); }
    private static string AudienceKey(CommunicationAudienceResponse x) => $"{x.Kind}:{x.Id}";
    private void ToggleAudience(CommunicationAudienceResponse audience)
    {
        var key = AudienceKey(audience);
        if (!_selectedAudiences.Add(key)) _selectedAudiences.Remove(key);
        else foreach (var id in audience.OrganizationUserIds) _selectedMembers.Add(id);
    }

    private async Task SaveEditorAsync()
    {
        if (string.IsNullOrWhiteSpace(_editorTitle)) { _editorError = "Give the channel a name."; return; }
        _editorBusy = true; _editorError = null;
        try
        {
            var roles = SelectedAudienceIds("Role"); var workstreams = SelectedAudienceIds("Workstream");
            HttpResponseMessage response;
            if (_editing is null)
                response = await Http.PostAsJsonAsync($"{BasePath}/chats", new CreateCommunicationChatRequest(_editorTitle, _editorDescription, false, _editorPrivate, _selectedMembers.ToList(), roles, workstreams), _disposeCts.Token);
            else
                response = await Http.PutAsJsonAsync($"{BasePath}/chats/{_editing.Id}", new UpdateCommunicationChatRequest(_editorTitle, _editorDescription, _editorPrivate, _selectedMembers.ToList(), roles, workstreams), _disposeCts.Token);
            if (!response.IsSuccessStatusCode) { _editorError = await response.Content.ReadAsStringAsync(_disposeCts.Token); return; }
            var chat = await response.Content.ReadFromJsonAsync<CommunicationChatResponse>(_disposeCts.Token);
            _showEditor = false; await RefreshHubAsync(chat?.Id ?? _editing?.Id);
        }
        finally { _editorBusy = false; }
    }

    private async Task ArchiveAsync()
    {
        if (!_confirmArchive) { _confirmArchive = true; return; }
        if (_editing is null) return;
        _editorBusy = true;
        try
        {
            var response = await Http.DeleteAsync($"{BasePath}/chats/{_editing.Id}", _disposeCts.Token);
            if (!response.IsSuccessStatusCode) { _editorError = await response.Content.ReadAsStringAsync(_disposeCts.Token); return; }
            _showEditor = false; _selected = null; await RefreshHubAsync();
        }
        finally { _editorBusy = false; }
    }

    private List<Guid> SelectedAudienceIds(string kind) => _hub?.Audiences.Where(x => x.Kind == kind && _selectedAudiences.Contains(AudienceKey(x))).Select(x => x.Id).ToList() ?? [];
    private async Task RefreshHubAsync(Guid? selectId = null)
    {
        _hub = await Http.GetFromJsonAsync<CommunicationHubResponse>(BasePath, _disposeCts.Token);
        _selected = _hub?.Chats.FirstOrDefault(x => x.Id == selectId) ?? _hub?.Chats.FirstOrDefault();
        if (_selected is not null) await LoadMessagesAsync(); else _messages.Clear();
    }

    private static string ParticipantSummary(CommunicationChatResponse chat) => string.Join(", ", chat.Participants.Take(4).Select(x => x.DisplayName)) + (chat.Participants.Count > 4 ? $" +{chat.Participants.Count - 4}" : string.Empty);
    private static string AvatarClass(string type) => type == "Agent" ? "agent" : "human";
    private static string Initials(string name) => string.Join(string.Empty, name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => char.ToUpperInvariant(x[0])));
    public void Dispose() { _disposeCts.Cancel(); _disposeCts.Dispose(); }
}

@page "/forgot-password"
@layout AnonymousLayout
@using System.ComponentModel.DataAnnotations
@inject IAuthenticationApiClient AuthenticationApi
@inject AuthSessionStore AuthSession

<PageTitle>Forgot password - C-Sweet</PageTitle>

<MudPaper Elevation="0" Class="auth-card">
    <MudText Typo="Typo.h4">Reset your password</MudText>
    @if (AuthSession.Current?.EmailRecoveryAvailable != true)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Email recovery is unavailable until SMTP is configured and successfully tested. The root administrator can still use an offline recovery code.</MudAlert>
        <MudButton Href="/recover-root" Variant="Variant.Text" Color="Color.Primary" FullWidth="true">Use a root recovery code</MudButton>
    }
    <MudText Color="Color.Secondary">Enter the administrator email and we’ll send a reset link.</MudText>
    <EditForm Model="_model" OnValidSubmit="SendAsync" Class="auth-form">
        <DataAnnotationsValidator />
        <MudTextField Label="Email" InputType="InputType.Email" @bind-Value="_model.Email" For="@(() => _model.Email)" Variant="Variant.Outlined" Required="true" />
        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <MudAlert Severity="@(_success ? Severity.Success : Severity.Error)" Variant="Variant.Outlined">@_message</MudAlert>
        }
        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="@(AuthSession.Current?.EmailRecoveryAvailable != true)">Send reset link</MudButton>
        <MudButton Href="/login" Variant="Variant.Text" Color="Color.Primary" FullWidth="true">Back to sign in</MudButton>
    </EditForm>
</MudPaper>

@code {
    private readonly EmailModel _model = new();
    private string? _message;
    private bool _success;
    private async Task SendAsync()
    {
        var result = await AuthenticationApi.ForgotPasswordAsync(_model.Email);
        _success = result.Succeeded;
        _message = result.Message;
    }
    private sealed class EmailModel { [Required, EmailAddress] public string Email { get; set; } = string.Empty; }
}

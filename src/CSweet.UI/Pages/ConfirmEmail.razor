@page "/confirm-email"
@layout AnonymousLayout
@using CSweet.Contracts.Auth
@inject IAuthenticationApiClient AuthenticationApi
@inject NavigationManager Navigation

<PageTitle>Confirm email - C-Sweet</PageTitle>

<MudPaper Elevation="0" Class="auth-card auth-card-centered">
    @if (_working)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.h5">Confirming your email…</MudText>
    }
    else if (_succeeded)
    {
        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
        <MudText Typo="Typo.h5">Email confirmed</MudText>
        <MudText Color="Color.Secondary">Continuing to system setup…</MudText>
    }
    else
    {
        <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
        <MudText Typo="Typo.h5">Confirmation failed</MudText>
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_message</MudAlert>
        <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary">Return to sign in</MudButton>
    }
</MudPaper>

@code {
    [SupplyParameterFromQuery] public Guid UserId { get; set; }
    [SupplyParameterFromQuery] public string? Code { get; set; }
    private bool _working = true;
    private bool _succeeded;
    private string _message = "The confirmation link is invalid or expired.";

    protected override async Task OnInitializedAsync()
    {
        if (UserId != Guid.Empty && !string.IsNullOrWhiteSpace(Code))
        {
            var result = await AuthenticationApi.ConfirmEmailAsync(new ConfirmEmailRequest(UserId, Code));
            _succeeded = result.Succeeded;
            _message = result.Message;
        }
        _working = false;
        if (_succeeded)
        {
            await Task.Delay(600);
            Navigation.NavigateTo("/setup", forceLoad: true);
        }
    }
}

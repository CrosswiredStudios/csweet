@page "/business-onboarding"
@using System.ComponentModel.DataAnnotations
@using CSweet.Contracts.BusinessOnboarding
@inject IBusinessOnboardingApiClient BusinessOnboardingApi
@inject ISetupApiClient SetupApi
@inject NavigationManager Navigation

<PageTitle>Business Onboarding - C-Sweet</PageTitle>

<div class="setup-shell">
    <MudPaper Elevation="0" Class="page-header">
        <div>
            <MudText Typo="Typo.overline" Color="Color.Primary">Business onboarding</MudText>
            <MudText Typo="Typo.h3">Create your operating context</MudText>
            <MudText Color="Color.Secondary">Capture enough context for C-Sweet to create roles, a first objective, an initial backlog, and a local strategy worker.</MudText>
        </div>
    </MudPaper>

    @if (_loadingSetup)
    {
        <MudPaper Elevation="1" Class="surface-panel surface-panel-narrow">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Color="Color.Secondary">Checking setup status...</MudText>
        </MudPaper>
    }
    else if (!_isFirstRunComplete)
    {
        <MudPaper Elevation="1" Class="surface-panel surface-panel-narrow">
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                First-run setup must be complete before business onboarding.
            </MudAlert>
            <MudStack Row="true" Class="setup-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NavigateToSetup" StartIcon="@Icons.Material.Filled.Tune">Go to setup</MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <EditForm Model="_model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            <MudPaper Elevation="1" Class="surface-panel">
                <div class="setup-step-heading">
                    <MudText Typo="Typo.h5">Company profile</MudText>
                    <MudText Color="Color.Secondary">This becomes the first organization command center.</MudText>
                </div>

                <ValidationSummary />

                <div class="setup-form-grid">
                    <div>
                        <MudTextField Label="Business name" @bind-Value="_model.BusinessName" For="@(() => _model.BusinessName)" Required="true" Variant="Variant.Outlined" />
                        <ValidationMessage For="() => _model.BusinessName" />
                    </div>

                    <MudTextField Label="Industry" @bind-Value="_model.Industry" Variant="Variant.Outlined" />

                    <MudSelect T="string" Label="Stage" @bind-Value="_model.Stage" Variant="Variant.Outlined">
                            @foreach (var stage in Stages)
                            {
                            <MudSelectItem T="string" Value="@stage">@stage</MudSelectItem>
                            }
                    </MudSelect>

                    <MudSelect T="string" Label="Preferred operating style" @bind-Value="_model.PreferredOperatingStyle" Variant="Variant.Outlined">
                            @foreach (var style in OperatingStyles)
                            {
                            <MudSelectItem T="string" Value="@style">@style</MudSelectItem>
                            }
                    </MudSelect>

                    <div class="setup-form-wide">
                        <MudTextField Label="Primary goal" @bind-Value="_model.PrimaryGoal" For="@(() => _model.PrimaryGoal)" Required="true" Lines="3" Variant="Variant.Outlined" />
                        <ValidationMessage For="() => _model.PrimaryGoal" />
                    </div>

                    <MudTextField Class="setup-form-wide"
                                  Label="Current constraints"
                                  @bind-Value="_model.ConstraintsText"
                                  HelperText="Use one constraint per line, or separate short constraints with commas."
                                  Lines="4"
                                  Variant="Variant.Outlined" />
                </div>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-4">@_errorMessage</MudAlert>
                }

                <MudStack Row="true" Class="setup-actions">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_saving" StartIcon="@Icons.Material.Filled.AddBusiness">
                        @(_saving ? "Creating..." : "Create command center")
                    </MudButton>
                </MudStack>
            </MudPaper>
        </EditForm>
    }
</div>

@code {
    private static readonly string[] Stages =
    [
        "Idea",
        "Pre-revenue",
        "Early revenue",
        "Growing",
        "Established"
    ];

    private static readonly string[] OperatingStyles =
    [
        "Conservative and careful",
        "Balanced and practical",
        "Aggressive growth",
        "Experimental"
    ];

    private readonly BusinessOnboardingFormModel _model = new()
    {
        Stage = "Idea",
        PreferredOperatingStyle = "Balanced and practical"
    };

    private bool _loadingSetup = true;
    private bool _isFirstRunComplete;
    private bool _saving;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var setupStatus = await SetupApi.GetStatusAsync();
            _isFirstRunComplete = setupStatus.IsFirstRunComplete;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to check setup status: {ex.Message}";
        }
        finally
        {
            _loadingSetup = false;
        }
    }

    private async Task SubmitAsync()
    {
        _saving = true;
        _errorMessage = null;

        try
        {
            var request = new CompleteBusinessOnboardingRequest(
                _model.BusinessName,
                _model.Industry,
                _model.Stage,
                _model.PrimaryGoal,
                ParseConstraints(_model.ConstraintsText),
                _model.PreferredOperatingStyle);

            var response = await BusinessOnboardingApi.CompleteAsync(request);
            Navigation.NavigateTo(response.NextRoute);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void NavigateToSetup() => Navigation.NavigateTo("/setup");

    private static IReadOnlyList<string> ParseConstraints(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return [];
        }

        return value
            .Split(['\r', '\n', ','], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private sealed class BusinessOnboardingFormModel
    {
        [Required(ErrorMessage = "Business name is required.")]
        public string BusinessName { get; set; } = string.Empty;

        public string? Industry { get; set; }

        public string Stage { get; set; } = "Idea";

        [Required(ErrorMessage = "Primary goal is required.")]
        public string PrimaryGoal { get; set; } = string.Empty;

        public string? ConstraintsText { get; set; }

        public string PreferredOperatingStyle { get; set; } = "Balanced and practical";
    }
}

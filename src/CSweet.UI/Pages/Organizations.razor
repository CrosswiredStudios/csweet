@page "/organizations"
@using CSweet.Contracts.Core
@using Microsoft.JSInterop
@inject IOrganizationApiClient OrganizationApi
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Businesses - C-Sweet</PageTitle>

<div class="setup-shell">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="page-header">
        <MudText Typo="Typo.h3">Businesses</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddBusiness" OnClick="ShowCreateForm">
            New Business
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudPaper Elevation="1" Class="surface-panel">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Color="Color.Secondary">Loading businesses...</MudText>
        </MudPaper>
    }
    else if (_organizations.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No businesses yet. Create your first business to get started.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var org in _organizations)
            {
                <MudItem xs="12" md="6" lg="4">
                    <MudCard Elevation="1" Class="organization-card">
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@org.Name</MudText>
                            @if (!string.IsNullOrEmpty(org.Industry))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Industry: @org.Industry</MudText>
                            }
                            @if (!string.IsNullOrEmpty(org.Stage))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@org.Stage</MudChip>
                            }
                            @if (!string.IsNullOrEmpty(org.PrimaryGoal))
                            {
                                <MudText Class="mt-2">@Truncate(org.PrimaryGoal, 150)</MudText>
                            }
                        </MudCardContent>
                        <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="() => NavigateToCommandCenter(org.Id)">
                                    Open
                                </MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="() => ShowEditForm(org)">
                                    Edit
                                </MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => ConfirmDelete(org)">
                                    Delete
                                </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</div>

<MudDialog @bind-Visible="_showForm" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingOrg != null ? "Edit Business" : "New Business")</MudText>
    </TitleContent>
    <DialogContent>
        <div class="setup-form-grid">
            <MudTextField Label="Name" @bind-Value="_formName" Required="true" Placeholder="Acme Corp" Variant="Variant.Outlined" Class="setup-form-wide" />
            <MudTextField Label="Industry" @bind-Value="_formIndustry" Placeholder="Retail, SaaS, Manufacturing..." Variant="Variant.Outlined" />
            <MudSelect T="string" Label="Stage" @bind-Value="_formStage" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@string.Empty">Select stage...</MudSelectItem>
                @foreach (var stage in OrganizationStages)
                {
                    <MudSelectItem T="string" Value="@stage">@stage</MudSelectItem>
                }
            </MudSelect>
            <MudTextField Label="Mission" @bind-Value="_formMission" Lines="3" Placeholder="What does this business do?" Variant="Variant.Outlined" Class="setup-form-wide" />
            <MudTextField Label="Primary Goal" @bind-Value="_formPrimaryGoal" Lines="3" Placeholder="What should C-Sweet help this business accomplish first?" Variant="Variant.Outlined" Class="setup-form-wide" />
            <MudTextField Label="Constraints JSON" @bind-Value="_formConstraintsJson" Lines="3" Placeholder="{ }" Variant="Variant.Outlined" Class="setup-form-wide" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="HideForm">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">
            @(_saving ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IReadOnlyList<OrganizationResponse> _organizations = Array.Empty<OrganizationResponse>();
    private bool _loading = true;
    private bool _showForm = false;
    private bool _saving = false;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    private static readonly string[] OrganizationStages =
    [
        "Idea",
        "Pre-seed",
        "Seed",
        "Early-stage",
        "Growth",
        "Mature"
    ];

    private OrganizationResponse? _editingOrg;
    private string _formName = string.Empty;
    private string _formIndustry = string.Empty;
    private string _formMission = string.Empty;
    private string _formStage = string.Empty;
    private string _formPrimaryGoal = string.Empty;
    private string _formConstraintsJson = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrganizations();
    }

    async Task LoadOrganizations()
    {
        _loading = true;
        try
        {
            _organizations = await OrganizationApi.ListAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to load organizations: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    void ShowCreateForm()
    {
        _editingOrg = null;
        _formName = string.Empty;
        _formIndustry = string.Empty;
        _formMission = string.Empty;
        _formStage = string.Empty;
        _formPrimaryGoal = string.Empty;
        _formConstraintsJson = string.Empty;
        _showForm = true;
    }

    void ShowEditForm(OrganizationResponse org)
    {
        _editingOrg = org;
        _formName = org.Name;
        _formIndustry = org.Industry ?? string.Empty;
        _formMission = org.Mission ?? string.Empty;
        _formStage = org.Stage ?? string.Empty;
        _formPrimaryGoal = org.PrimaryGoal ?? string.Empty;
        _formConstraintsJson = org.ConstraintsJson ?? string.Empty;
        _showForm = true;
    }

    void HideForm() => _showForm = false;

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_formName)) return;

        _saving = true;
        try
        {
            if (_editingOrg is null)
            {
                var request = new CreateOrganizationRequest(
                    _formName,
                    _formIndustry,
                    _formMission,
                    _formStage,
                    _formPrimaryGoal,
                    string.IsNullOrWhiteSpace(_formConstraintsJson) ? null : _formConstraintsJson);
                await OrganizationApi.CreateAsync(request);
            }
            else
            {
                var request = new UpdateOrganizationRequest(
                    _formName,
                    _formIndustry,
                    _formMission,
                    _formStage,
                    _formPrimaryGoal,
                    string.IsNullOrWhiteSpace(_formConstraintsJson) ? null : _formConstraintsJson);
                await OrganizationApi.UpdateAsync(_editingOrg.Id, request);
            }

            HideForm();
            await LoadOrganizations();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to save organization: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    async Task ConfirmDelete(OrganizationResponse org)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{org.Name}'? This will also delete all associated business data."))
        {
            try
            {
                await OrganizationApi.DeleteAsync(org.Id);
                await LoadOrganizations();
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Failed to delete organization: {ex.Message}");
            }
        }
    }

    void NavigateToCommandCenter(Guid orgId) => Navigation.NavigateTo($"/organizations/{orgId}/command-center");

    static string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        return value.Length <= maxLength ? value : value[..maxLength] + "...";
    }
}

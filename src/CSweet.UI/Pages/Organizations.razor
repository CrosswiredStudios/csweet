@using CSweet.Contracts.Agents
@using CSweet.Contracts.BusinessOnboarding
@using CSweet.Contracts.Core
@using CSweet.Contracts.Llm
@using CSweet.Contracts.Plugins
@using CSweet.Contracts.Setup
@using Microsoft.JSInterop
@inject IOrganizationApiClient OrganizationApi
@inject IBusinessOnboardingApiClient BusinessOnboardingApi
@inject IAgentApiClient AgentApi
@inject IPluginApiClient PluginApi
@inject ILlmProviderApiClient LlmProviderApi
@inject IAgentRuntimeSettingsApiClient AgentRuntimeSettingsApi
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IBusinessContext BusinessContext

<div class="setup-shell">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="page-header">
        <MudText Typo="Typo.h3">Businesses</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddBusiness" OnClick="ShowCreateForm">
            New Business
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudPaper Elevation="1" Class="surface-panel">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Color="Color.Secondary">Loading businesses...</MudText>
        </MudPaper>
    }
    else if (_organizations.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No businesses yet. Create your first business to get started.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var org in _organizations)
            {
                <MudItem xs="12" md="6" lg="4">
                    <MudCard Elevation="1" Class="organization-card">
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@org.Name</MudText>
                            @if (!string.IsNullOrEmpty(org.Industry))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Industry: @org.Industry</MudText>
                            }
                            @if (!string.IsNullOrEmpty(org.Stage))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@org.Stage</MudChip>
                            }
                            @if (!string.IsNullOrEmpty(org.Mission))
                            {
                                <MudText Class="mt-2">@Truncate(org.Mission, 150)</MudText>
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="() => NavigateToCommandCenter(org.Id)">Open</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="() => ShowEditForm(org)">Edit</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => ConfirmDelete(org)">Delete</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</div>

<MudDialog Visible="_showForm" VisibleChanged="OnDialogVisibilityChanged" Options="_dialogOptions">
    <DialogContent>
        <section class="business-dialog" aria-labelledby="business-dialog-title">
            <header class="business-dialog-header">
                <div class="business-dialog-brand">
                    <span class="business-dialog-mark"><MudIcon Icon="@Icons.Material.Filled.Business" /></span>
                    <div>
                        <span class="business-kicker">@(_editingOrg is null ? "New business" : "Business profile")</span>
                        <h2 id="business-dialog-title">@(_editingOrg is null ? "Build your command team." : $"Edit {_editingOrg.Name}")</h2>
                        <p>@(_editingOrg is null
                            ? "Give C-Sweet the essentials, then choose the first agent your business can talk to."
                            : "Keep the business context your team and agents use up to date.")</p>
                    </div>
                </div>
                <button type="button" class="business-dialog-close" aria-label="Close business dialog" disabled="@_saving" @onclick="HideForm">
                    <MudIcon Icon="@Icons.Material.Filled.Close" />
                </button>
            </header>

            @if (_editingOrg is null)
            {
                <nav class="business-progress" aria-label="New business progress">
                    <div class="@StepClass(0)"><span>@StepGlyph(0)</span><div><strong>Business</strong><small>Name and purpose</small></div></div>
                    <i></i>
                    <div class="@StepClass(1)"><span>@StepGlyph(1)</span><div><strong>Chief of Staff</strong><small>Your first agent</small></div></div>
                </nav>
            }

            <div class="business-dialog-stage" @key="_wizardStep">
                @if (_editingOrg is not null || _wizardStep == 0)
                {
                    <section class="business-profile-step">
                        <div class="business-step-heading">
                            <span class="business-kicker">Basic information</span>
                            <h3>Start with the business itself.</h3>
                            <p>A short mission statement gives every employee and agent a shared north star. You can refine it later.</p>
                        </div>
                        <div class="business-form-grid">
                            <MudTextField Label="Business name" @bind-Value="_formName" Required="true" Placeholder="Acme Corp"
                                          Variant="Variant.Outlined" Disabled="@_saving" Class="business-form-wide" />
                            <MudTextField Label="Industry" @bind-Value="_formIndustry" Placeholder="Software, retail, healthcare..."
                                          Variant="Variant.Outlined" Disabled="@_saving" />
                            <MudTextField Label="Mission statement" @bind-Value="_formMission" Lines="4"
                                          Placeholder="Describe who you serve, what you help them achieve, and why it matters."
                                          HelperText="Aim for one or two clear sentences."
                                          Variant="Variant.Outlined" Disabled="@_saving" Class="business-form-wide" />
                        </div>
                    </section>
                }
                else
                {
                    <section class="chief-step">
                        <div class="business-step-heading chief-heading">
                            <span class="business-kicker">First employee · required</span>
                            <h3>Choose a Chief of Staff.</h3>
                            <p>The title is only the initial assignment. Any valid C-Sweet agent can fill it, but every new business starts with one agent you can immediately interact with.</p>
                        </div>

                        <div class="chief-source-grid">
                            <button type="button" class="chief-source-card @(!_customAgent ? "selected" : null)" aria-pressed="@(!_customAgent)" @onclick="SelectRecommendedAgent">
                                <span class="chief-source-mark"><MudIcon Icon="@Icons.Material.Filled.AutoAwesome" /></span>
                                <span><strong>C-Sweet Chief of Staff</strong><small>First-party · designed for conversation, planning, and management cadence</small></span>
                                <MudIcon Icon="@(!_customAgent ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.ArrowForward)" />
                            </button>
                            <button type="button" class="chief-source-card @(_customAgent ? "selected" : null)" aria-pressed="@_customAgent" @onclick="SelectCustomAgent">
                                <span class="chief-source-mark custom"><MudIcon Icon="@Icons.Material.Filled.Code" /></span>
                                <span><strong>Another GitHub agent</strong><small>Use a public repository containing a valid C-Sweet agent manifest</small></span>
                                <MudIcon Icon="@(_customAgent ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.ArrowForward)" />
                            </button>
                        </div>

                        @if (_customAgent)
                        {
                            <div class="chief-source-form">
                                <MudTextField T="string" Label="Public GitHub repository URL" Value="_agentRepositoryUrl" ValueChanged="OnRepositoryChanged"
                                              Placeholder="https://github.com/organization/agent" Variant="Variant.Outlined" Disabled="@_saving" />
                                <MudTextField T="string" Label="Branch, tag, or commit (optional)" Value="_agentRef" ValueChanged="OnRefChanged"
                                              Placeholder="Uses the default branch" Variant="Variant.Outlined" Disabled="@_saving" />
                            </div>
                        }
                        else
                        {
                            <div class="recommended-agent-note">
                                <MudIcon Icon="@Icons.Material.Filled.Verified" />
                                <span>Recommended source: <code>@RecommendedChiefRepository</code>. C-Sweet resolves the current source to an immutable commit before approval.</span>
                            </div>
                        }

                        @if (_previewing)
                        {
                            <div class="chief-progress-message"><MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" /> Inspecting the agent manifest…</div>
                        }
                        else if (_agentPreview is null)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Policy"
                                       Disabled="@(_saving || !HasAgentSource)" OnClick="PreviewAgentAsync">Review this agent</MudButton>
                        }
                        else
                        {
                            <section class="agent-review">
                                <header class="agent-review-header">
                                    <span class="agent-avatar"><MudIcon Icon="@Icons.Material.Filled.SmartToy" /></span>
                                    <div><span class="business-kicker">Manifest verified</span><h4>@_agentPreview.AgentName</h4><p>@_agentPreview.AgentId · v@_agentPreview.AgentVersion</p></div>
                                    <span class="agent-publisher">@_agentPreview.PublisherName</span>
                                </header>

                                <div class="agent-review-facts">
                                    <div><span>Commit</span><strong>@ShortHash(_agentPreview.CommitSha)</strong><small>@_agentPreview.CommitSha</small></div>
                                    <div><span>Manifest</span><strong>SHA-256</strong><small>@_agentPreview.ManifestDigest</small></div>
                                    <div><span>Runtime</span><strong>@ActivationMode</strong><small>@_agentPreview.RuntimeType · @_agentPreview.TargetFramework</small></div>
                                    <div><span>Publisher</span><strong>@_agentPreview.PublisherName</strong><small>@_agentPreview.PublisherId</small></div>
                                </div>

                                <div class="agent-access-grid">
                                    @AccessGroup("Provides", _agentPreview.Capabilities)
                                    @AccessGroup("Platform access", _agentPreview.RequestedCapabilities)
                                    @AccessGroup("Subscribes to", _agentPreview.RequestedSubscriptions)
                                    @AccessGroup("Publishes", _agentPreview.RequestedPublications)
                                    @AccessGroup("Network access", _agentPreview.RequestedNetworkAccess)
                                    @AccessGroup("Legacy permissions", _agentPreview.RequestedPermissions)
                                </div>

                                @if (ChiefReadinessNotes.Count > 0)
                                {
                                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                                        <strong>Role compatibility:</strong> @string.Join(" ", ChiefReadinessNotes)
                                    </MudAlert>
                                }

                                @if (_agentPreview.Warnings.Count > 0)
                                {
                                    @foreach (var warning in _agentPreview.Warnings)
                                    {
                                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@warning.Message</MudAlert>
                                    }
                                }

                                @if (_agentPreview.ConfigurationFields.Count > 0 || _agentPreview.CredentialBindings.Count > 0)
                                {
                                    <div class="agent-config-heading"><h4>Agent configuration</h4><p>Choose the backing and values this employee will use in this business.</p></div>
                                    <div class="agent-config-grid">
                                        @foreach (var field in _agentPreview.ConfigurationFields.Where(x => !x.Secret))
                                        {
                                            @if (IsProviderField(field))
                                            {
                                                <MudSelect T="string" Label="@RequiredLabel(field.Label, field.Required)" Value="@ConfigurationValue(field.Key)"
                                                           ValueChanged="@(value => OnProviderConfigurationChanged(field.Key, value))" Variant="Variant.Outlined" Disabled="@_saving">
                                                    @foreach (var provider in _llmProviders)
                                                    {
                                                        <MudSelectItem T="string" Value="@provider.Id.ToString()">@provider.Name</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                            else
                                            {
                                                <MudTextField T="string" Label="@RequiredLabel(field.Label, field.Required)" Value="@ConfigurationValue(field.Key)"
                                                              ValueChanged="@(value => SetConfigurationValue(field.Key, value))" Variant="Variant.Outlined" Disabled="@_saving" />
                                            }
                                        }
                                        @foreach (var field in _agentPreview.ConfigurationFields.Where(x => x.Secret))
                                        {
                                            <MudTextField T="string" Label="@RequiredLabel(field.Label, field.Required)" Value="@SecretValue(field.Key)"
                                                          ValueChanged="@(value => SetSecretValue(field.Key, value))" Variant="Variant.Outlined" InputType="InputType.Password"
                                                          autocomplete="new-password" Disabled="@_saving" />
                                        }
                                        @foreach (var credential in _agentPreview.CredentialBindings)
                                        {
                                            <MudTextField T="string" Label="@($"{credential.Name} credential (required)")" Value="@SecretValue(credential.Name)"
                                                          ValueChanged="@(value => SetSecretValue(credential.Name, value))" Variant="Variant.Outlined" InputType="InputType.Password"
                                                          HelperText="Restricted to the origins declared by this manifest." autocomplete="new-password" Disabled="@_saving" />
                                        }
                                    </div>
                                }

                                <div class="agent-approval">
                                    <MudCheckBox T="bool" @bind-Value="_agentApproved" Color="Color.Primary"
                                                 Label="I approve this pinned agent, its requested capabilities, events, permissions, and network access." />
                                    @if (_agentPreview.WebAccess.Mode == PluginWebAccessMode.AllPublic)
                                    {
                                        <MudCheckBox T="bool" @bind-Value="_allPublicWebApproved" Color="Color.Warning"
                                                     Label="I understand that this agent requests access to any public internet host." />
                                    }
                                    @if (RuntimeApprovalRequired)
                                    {
                                        <MudCheckBox T="bool" @bind-Value="_runtimeApproved" Color="Color.Warning"
                                                     Label="Enable imported agent execution for this C-Sweet deployment. This agent will use its declared activation mode." />
                                    }
                                </div>
                            </section>
                        }
                    </section>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_formError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_formError</MudAlert>
            }

            <footer class="business-dialog-actions">
                @if (_editingOrg is not null)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Secondary" Disabled="@_saving" OnClick="HideForm">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_saving || !IsBasicInfoComplete)" OnClick="SaveEditAsync">
                        @(_saving ? "Saving…" : "Save changes")
                    </MudButton>
                }
                else if (_wizardStep == 0)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Secondary" Disabled="@_saving" OnClick="HideForm">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward"
                               Disabled="@(!IsBasicInfoComplete)" OnClick="ContinueToChiefAsync">Choose Chief of Staff</MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ArrowBack" Disabled="@_saving" OnClick="BackToProfile">Back</MudButton>
                    <div class="business-create-action">
                        <span>@(_agentPreview is null ? "Review an agent to continue" : CanCreateBusiness ? "Ready to create and activate" : "Complete the approval and required fields")</span>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddBusiness"
                                   Disabled="@(_saving || !CanCreateBusiness)" OnClick="CreateBusinessAsync">
                            @(_saving ? "Creating your business…" : "Create business")
                        </MudButton>
                    </div>
                }
            </footer>
        </section>
    </DialogContent>
</MudDialog>

@code {
    private const string RecommendedChiefRepository = "https://github.com/CrosswiredStudios/CSweet.Agent.ChiefOfStaff";
    private static readonly string[] ChiefCapabilities = ["assistant.converse.v1", "assistant.plan-work.v1", "management.check-in.v1"];
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
    private readonly Dictionary<string, string> _configurationValues = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _secretValues = new(StringComparer.Ordinal);

    [Parameter] public bool CreateRequested { get; set; }

    private IReadOnlyList<OrganizationResponse> _organizations = [];
    private IReadOnlyList<LlmProviderProfileResponse> _llmProviders = [];
    private AgentRuntimeSettingsResponse? _runtimeSettings;
    private AgentImportPreviewResponse? _agentPreview;
    private AgentInstallationResponse? _installedChief;
    private OrganizationResponse? _editingOrg;
    private bool _loading = true;
    private bool _showForm;
    private bool _saving;
    private bool _previewing;
    private bool _customAgent;
    private bool _agentApproved;
    private bool _allPublicWebApproved;
    private bool _runtimeApproved;
    private int _wizardStep;
    private string _formName = string.Empty;
    private string _formIndustry = string.Empty;
    private string _formMission = string.Empty;
    private string _agentRepositoryUrl = RecommendedChiefRepository;
    private string _agentRef = string.Empty;
    private string? _formError;

    private bool IsBasicInfoComplete => !string.IsNullOrWhiteSpace(_formName);
    private bool HasAgentSource => Uri.TryCreate(_agentRepositoryUrl.Trim(), UriKind.Absolute, out var uri)
        && uri.Scheme == Uri.UriSchemeHttps && string.Equals(uri.Host, "github.com", StringComparison.OrdinalIgnoreCase);
    private bool RuntimeApprovalRequired => _agentPreview is not null &&
        (_runtimeSettings?.EnableImportedAgents != true ||
         (string.Equals(ActivationMode, "AlwaysOn", StringComparison.OrdinalIgnoreCase) && _runtimeSettings?.AllowAlwaysOnCommunityAgents != true));
    private string ActivationMode => _agentPreview?.DefaultActivationMode ?? _runtimeSettings?.DefaultActivationMode ?? "Periodic";
    private bool CanCreateBusiness => _agentPreview is not null && _agentApproved &&
        (_agentPreview.WebAccess.Mode != PluginWebAccessMode.AllPublic || _allPublicWebApproved) &&
        (!RuntimeApprovalRequired || _runtimeApproved) &&
        _agentPreview.ConfigurationFields.Where(x => x.Required && !x.Secret).All(x => HasValue(_configurationValues, x.Key)) &&
        _agentPreview.ConfigurationFields.Where(x => x.Required && x.Secret).All(x => HasValue(_secretValues, x.Key)) &&
        _agentPreview.CredentialBindings.All(x => HasValue(_secretValues, x.Name));
    private IReadOnlyList<string> ChiefReadinessNotes => _agentPreview is null
        ? []
        : ChiefCapabilities.Where(x => !_agentPreview.Capabilities.Contains(x, StringComparer.OrdinalIgnoreCase))
            .Select(x => $"It does not advertise {x}; assignment is allowed, but that function may be limited.").ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        if (CreateRequested) ShowCreateForm();
    }

    protected override void OnParametersSet()
    {
        if (CreateRequested && !_showForm && !_loading) ShowCreateForm();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var organizationsTask = OrganizationApi.ListAsync();
            var providersTask = LlmProviderApi.ListAsync();
            var runtimeTask = AgentRuntimeSettingsApi.GetAsync();
            await Task.WhenAll(organizationsTask, providersTask, runtimeTask);
            _organizations = await organizationsTask;
            _llmProviders = (await providersTask).Where(x => x.IsEnabled).OrderBy(x => x.Name).ToList();
            _runtimeSettings = await runtimeTask;
        }
        catch (Exception exception)
        {
            _formError = $"Unable to load business onboarding: {exception.Message}";
        }
        finally { _loading = false; }
    }

    private void ShowCreateForm()
    {
        ResetForm();
        _editingOrg = null;
        _showForm = true;
    }

    private void ShowEditForm(OrganizationResponse organization)
    {
        ResetForm();
        _editingOrg = organization;
        _formName = organization.Name;
        _formIndustry = organization.Industry ?? string.Empty;
        _formMission = organization.Mission ?? string.Empty;
        _showForm = true;
    }

    private void ResetForm()
    {
        _wizardStep = 0; _formName = string.Empty; _formIndustry = string.Empty; _formMission = string.Empty;
        _agentRepositoryUrl = RecommendedChiefRepository; _agentRef = string.Empty; _customAgent = false;
        _agentPreview = null; _installedChief = null; _agentApproved = false; _allPublicWebApproved = false;
        _runtimeApproved = false; _formError = null; _configurationValues.Clear(); _secretValues.Clear();
    }

    private async Task ContinueToChiefAsync()
    {
        if (!IsBasicInfoComplete) return;
        _wizardStep = 1;
        if (_agentPreview is null) await PreviewAgentAsync();
    }

    private void BackToProfile() { if (!_saving) { _wizardStep = 0; _formError = null; } }

    private void SelectRecommendedAgent()
    {
        if (_saving) return;
        _customAgent = false;
        _agentRepositoryUrl = RecommendedChiefRepository;
        _agentRef = string.Empty;
        InvalidatePreview();
    }

    private void SelectCustomAgent()
    {
        if (_saving) return;
        _customAgent = true;
        _agentRepositoryUrl = string.Empty;
        _agentRef = string.Empty;
        InvalidatePreview();
    }

    private void OnRepositoryChanged(string value) { _agentRepositoryUrl = value; InvalidatePreview(); }
    private void OnRefChanged(string value) { _agentRef = value; InvalidatePreview(); }
    private void InvalidatePreview()
    {
        _agentPreview = null; _installedChief = null; _agentApproved = false; _allPublicWebApproved = false;
        _runtimeApproved = false; _formError = null; _configurationValues.Clear(); _secretValues.Clear();
    }

    private async Task PreviewAgentAsync()
    {
        if (!HasAgentSource) return;
        _previewing = true;
        _formError = null;
        InvalidatePreview();
        try
        {
            var preview = await AgentApi.PreviewImportAsync(new PreviewAgentImportRequest(
                _agentRepositoryUrl.Trim(), string.IsNullOrWhiteSpace(_agentRef) ? null : _agentRef.Trim()));
            if (!string.Equals(preview.PluginKind, "Agent", StringComparison.OrdinalIgnoreCase))
                throw new InvalidOperationException("The selected repository must contain an agent plugin.");
            _agentPreview = preview;
            InitializeConfiguration(preview);
        }
        catch (Exception exception) { _formError = exception.Message; }
        finally { _previewing = false; }
    }

    private void InitializeConfiguration(AgentImportPreviewResponse preview)
    {
        var provider = _llmProviders.FirstOrDefault();
        foreach (var field in preview.ConfigurationFields)
        {
            if (IsProviderField(field) && provider is not null)
                _configurationValues[field.Key] = provider.Id.ToString();
            else if (IsModelField(field) && provider is not null)
                _configurationValues[field.Key] = provider.DefaultChatModel;
        }
    }

    private void OnProviderConfigurationChanged(string key, string value)
    {
        _configurationValues[key] = value;
        var provider = _llmProviders.FirstOrDefault(x => x.Id.ToString() == value);
        if (provider is null || _agentPreview is null) return;
        foreach (var modelField in _agentPreview.ConfigurationFields.Where(IsModelField))
            _configurationValues[modelField.Key] = provider.DefaultChatModel;
    }

    private async Task CreateBusinessAsync()
    {
        if (_agentPreview is null || !CanCreateBusiness) return;
        _saving = true;
        _formError = null;
        try
        {
            if (RuntimeApprovalRequired)
            {
                var settingsResult = await AgentRuntimeSettingsApi.UpdateAsync(new UpdateAgentRuntimeSettingsRequest(
                    EnableImportedAgents: true,
                    AllowAlwaysOnCommunityAgents: string.Equals(ActivationMode, "AlwaysOn", StringComparison.OrdinalIgnoreCase) ? true : null));
                if (!settingsResult.Succeeded)
                    throw new InvalidOperationException(settingsResult.Message ?? "Imported agent execution could not be enabled.");
                _runtimeSettings = settingsResult.Settings ?? _runtimeSettings;
            }

            _installedChief ??= await AgentApi.InstallAsync(
                _agentPreview.ImportId,
                new InstallAgentRequest(
                    "default",
                    ActivationMode,
                    _runtimeSettings?.DefaultTickFrequencySeconds ?? 3600,
                    _runtimeSettings?.DefaultOverlapPolicy ?? "Skip",
                    _agentPreview.Capabilities,
                    _agentPreview.RequestedSubscriptions,
                    _agentPreview.RequestedPublications,
                    _agentPreview.RequestedPermissions,
                    _agentPreview.RequestedNetworkAccess,
                    _runtimeSettings?.DefaultMaxRuntimeSeconds ?? 600,
                    _runtimeSettings?.DefaultContainerMemoryMb ?? 512,
                    _runtimeSettings?.DefaultContainerCpuPercent ?? 50)
                {
                    GrantedRequestedCapabilities = _agentPreview.RequestedCapabilities,
                    AllPublicWebAccessAcknowledged = _allPublicWebApproved
                });

            var settings = _configurationValues.Where(x => !string.IsNullOrWhiteSpace(x.Value))
                .ToDictionary(x => x.Key, x => x.Value.Trim(), StringComparer.Ordinal);
            if (_agentPreview.ConfigurationFields.Any(x => !x.Secret))
                await PluginApi.SaveConfigurationAsync(_installedChief.Id, settings);
            foreach (var secret in _secretValues.Where(x => !string.IsNullOrWhiteSpace(x.Value)))
                await PluginApi.SetSecretAsync(_installedChief.Id, secret.Key, secret.Value.Trim());

            var onboarding = await BusinessOnboardingApi.CompleteAsync(new CompleteBusinessOnboardingRequest(
                _formName.Trim(), TrimOrNull(_formIndustry), TrimOrNull(_formMission), _installedChief.Id));

            _showForm = false;
            await LoadAsync();
            await BusinessContext.RefreshAsync();
            Navigation.NavigateTo(onboarding.NextRoute);
        }
        catch (Exception exception)
        {
            _formError = _installedChief is null
                ? exception.Message
                : $"The Chief agent was installed, but business creation did not finish. You can safely retry: {exception.Message}";
        }
        finally { _saving = false; }
    }

    private async Task SaveEditAsync()
    {
        if (_editingOrg is null || !IsBasicInfoComplete) return;
        _saving = true;
        _formError = null;
        try
        {
            await OrganizationApi.UpdateAsync(_editingOrg.Id, new UpdateOrganizationRequest(
                _formName.Trim(), TrimOrNull(_formIndustry), TrimOrNull(_formMission), null, null, null));
            HideForm();
            await LoadAsync();
            await BusinessContext.RefreshAsync();
        }
        catch (Exception exception) { _formError = exception.Message; }
        finally { _saving = false; }
    }

    private Task OnDialogVisibilityChanged(bool visible) { if (!visible && !_saving) HideForm(); return Task.CompletedTask; }
    private void HideForm()
    {
        if (_saving) return;
        _showForm = false;
        if (CreateRequested) Navigation.NavigateTo("/", replace: true);
    }

    private async Task ConfirmDelete(OrganizationResponse organization)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{organization.Name}'? This will also delete all associated business data.")) return;
        try
        {
            await OrganizationApi.DeleteAsync(organization.Id);
            await LoadAsync();
            await BusinessContext.RefreshAsync();
        }
        catch (Exception exception) { _formError = exception.Message; }
    }

    private void NavigateToCommandCenter(Guid organizationId) => Navigation.NavigateTo($"/organizations/{organizationId}/command-center");
    private string StepClass(int step) => _wizardStep == step ? "active" : _wizardStep > step ? "complete" : string.Empty;
    private string StepGlyph(int step) => _wizardStep > step ? "✓" : (step + 1).ToString();
    private string ConfigurationValue(string key) => _configurationValues.GetValueOrDefault(key, string.Empty);
    private string SecretValue(string key) => _secretValues.GetValueOrDefault(key, string.Empty);
    private void SetConfigurationValue(string key, string value) => _configurationValues[key] = value;
    private void SetSecretValue(string key, string value) => _secretValues[key] = value;
    private static bool HasValue(IReadOnlyDictionary<string, string> values, string key) => values.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value);
    private static bool IsProviderField(PluginConfigurationField field) => field.Type.Equals("provider", StringComparison.OrdinalIgnoreCase) || field.Type.Equals("llmProvider", StringComparison.OrdinalIgnoreCase);
    private static bool IsModelField(PluginConfigurationField field) => field.Type.Equals("model", StringComparison.OrdinalIgnoreCase) || field.Type.Equals("llmModel", StringComparison.OrdinalIgnoreCase);
    private static string RequiredLabel(string label, bool required) => required ? $"{label} (required)" : label;
    private static string ShortHash(string value) => value.Length <= 9 ? value : value[..9];
    private static string Format(IReadOnlyList<string> values) => values.Count == 0 ? "None" : string.Join(", ", values);
    private static RenderFragment AccessGroup(string label, IReadOnlyList<string> values) => @<div class="agent-access-group">
        <span>@label</span><p>@Format(values)</p>
    </div>;
    private static string? TrimOrNull(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    private static string Truncate(string value, int maxLength) => value.Length <= maxLength ? value : value[..maxLength] + "...";
}

@page "/organizations"
@using System.Text.Json
@using System.Text.Json.Nodes
@using CSweet.Contracts.Core
@using Microsoft.JSInterop
@inject IOrganizationApiClient OrganizationApi
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Businesses - C-Sweet</PageTitle>

<div class="setup-shell">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="page-header">
        <MudText Typo="Typo.h3">Businesses</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddBusiness" OnClick="ShowCreateForm">
            New Business
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudPaper Elevation="1" Class="surface-panel">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Color="Color.Secondary">Loading businesses...</MudText>
        </MudPaper>
    }
    else if (_organizations.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No businesses yet. Create your first business to get started.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var org in _organizations)
            {
                <MudItem xs="12" md="6" lg="4">
                    <MudCard Elevation="1" Class="organization-card">
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@org.Name</MudText>
                            @if (!string.IsNullOrEmpty(org.Industry))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Industry: @org.Industry</MudText>
                            }
                            @if (!string.IsNullOrEmpty(org.Stage))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@org.Stage</MudChip>
                            }
                            @if (!string.IsNullOrEmpty(org.PrimaryGoal))
                            {
                                <MudText Class="mt-2">@Truncate(org.PrimaryGoal, 150)</MudText>
                            }
                        </MudCardContent>
                        <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="() => NavigateToCommandCenter(org.Id)">
                                    Open
                                </MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="() => ShowEditForm(org)">
                                    Edit
                                </MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => ConfirmDelete(org)">
                                    Delete
                                </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</div>

<MudDialog @bind-Visible="_showForm" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingOrg != null ? "Edit Business" : "New Business")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStepper @bind-ActiveIndex="_wizardStep"
                    Vertical="true"
                    NonLinear="true"
                    ShowResetButton="false"
                    Class="business-wizard-stepper">
            <ChildContent>
                <MudStep Title="Basic Information" SecondaryText="Profile and first goal" Completed="@IsBasicInfoComplete">
                    <div class="business-wizard-panel">
                        <MudText Typo="Typo.h6">Basic information</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Set the business context C-Sweet should use as its operating baseline.</MudText>

                        <div class="setup-form-grid business-wizard-form">
                            <MudTextField Label="Name" @bind-Value="_formName" Required="true" Placeholder="Acme Corp" Variant="Variant.Outlined" Class="setup-form-wide" />
                            <MudTextField Label="Industry" @bind-Value="_formIndustry" Placeholder="Retail, SaaS, Manufacturing..." Variant="Variant.Outlined" />
                            <MudSelect T="string" Label="Stage" @bind-Value="_formStage" Variant="Variant.Outlined">
                                <MudSelectItem T="string" Value="@string.Empty">Select stage...</MudSelectItem>
                                @foreach (var stage in OrganizationStages)
                                {
                                    <MudSelectItem T="string" Value="@stage">@stage</MudSelectItem>
                                }
                            </MudSelect>
                            <MudTextField Label="Mission" @bind-Value="_formMission" Lines="3" Placeholder="What does this business do?" Variant="Variant.Outlined" Class="setup-form-wide" />
                            <MudTextField Label="Primary Goal" @bind-Value="_formPrimaryGoal" Lines="3" Placeholder="What should C-Sweet help this business accomplish first?" Variant="Variant.Outlined" Class="setup-form-wide" />
                        </div>
                    </div>
                </MudStep>
                <MudStep Title="Personal Assistant" SecondaryText="Avatar and demeanor" Completed="@IsAssistantComplete">
                    <div class="business-wizard-panel">
                        <MudText Typo="Typo.h6">Personal assistant</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Choose the assistant presence people will meet first in this business workspace.</MudText>

                        <div class="assistant-selection-section">
                            <MudText Typo="Typo.subtitle2">Assistant avatar</MudText>
                            <MudRadioGroup T="string" @bind-Value="_assistantAvatar" Class="assistant-option-grid">
                                @foreach (var avatar in AssistantAvatars)
                                {
                                    <MudRadio T="string" Value="@avatar.Value" Color="Color.Primary" Class="assistant-option-card">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudAvatar Color="@avatar.Color" Variant="Variant.Filled" Size="Size.Large">
                                                <MudIcon Icon="@avatar.Icon" />
                                            </MudAvatar>
                                            <div>
                                                <MudText Typo="Typo.subtitle2">@avatar.Name</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@avatar.Description</MudText>
                                            </div>
                                        </MudStack>
                                    </MudRadio>
                                }
                            </MudRadioGroup>
                        </div>

                        <div class="assistant-selection-section">
                            <MudText Typo="Typo.subtitle2">Behavioral demeanor</MudText>
                            <MudRadioGroup T="string" @bind-Value="_assistantDemeanor" Class="assistant-option-grid assistant-demeanor-grid">
                                @foreach (var demeanor in AssistantDemeanors)
                                {
                                    <MudRadio T="string" Value="@demeanor.Value" Color="Color.Primary" Class="assistant-option-card">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@demeanor.Icon" Color="@demeanor.Color" />
                                            <div>
                                                <MudText Typo="Typo.subtitle2">@demeanor.Name</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@demeanor.Description</MudText>
                                            </div>
                                        </MudStack>
                                    </MudRadio>
                                }
                            </MudRadioGroup>
                        </div>
                    </div>
                </MudStep>
            </ChildContent>
            <ActionContent></ActionContent>
        </MudStepper>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="HideForm">Cancel</MudButton>
        @if (_wizardStep > 0)
        {
            <MudButton Variant="Variant.Text" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="PreviousWizardStep">Back</MudButton>
        }
        @if (_wizardStep == 0)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" OnClick="NextWizardStep" Disabled="@(!IsBasicInfoComplete)">
                Continue
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@(_saving || !IsBasicInfoComplete || !IsAssistantComplete)">
            @(_saving ? "Saving..." : "Save")
        </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    private IReadOnlyList<OrganizationResponse> _organizations = Array.Empty<OrganizationResponse>();
    private bool _loading = true;
    private bool _showForm = false;
    private bool _saving = false;
    private int _wizardStep;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Large, FullWidth = true };
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web);

    private static readonly string[] OrganizationStages =
    [
        "Idea",
        "Pre-seed",
        "Seed",
        "Early-stage",
        "Growth",
        "Mature"
    ];

    private static readonly AssistantAvatarOption[] AssistantAvatars =
    [
        new("strategist", "Strategist", "Calm planning partner for prioritization and tradeoffs.", Icons.Material.Filled.Psychology, Color.Primary),
        new("operator", "Operator", "Execution-minded assistant for cadence, owners, and follow-through.", Icons.Material.Filled.AccountTree, Color.Secondary),
        new("builder", "Builder", "Hands-on partner for shaping offers, workflows, and deliverables.", Icons.Material.Filled.Construction, Color.Tertiary),
        new("advisor", "Advisor", "Direct counsel for decisions, risks, and leadership judgment.", Icons.Material.Filled.RecordVoiceOver, Color.Info)
    ];

    private static readonly AssistantDemeanorOption[] AssistantDemeanors =
    [
        new("Careful and precise", "Careful and precise", "Deliberate, evidence-oriented, and slow to overreach.", Icons.Material.Filled.FactCheck, Color.Success),
        new("Balanced and practical", "Balanced and practical", "Plainspoken, pragmatic, and comfortable making tradeoffs.", Icons.Material.Filled.Balance, Color.Primary),
        new("Bold and direct", "Bold and direct", "Concise, decisive, and biased toward visible momentum.", Icons.Material.Filled.Bolt, Color.Warning),
        new("Creative and experimental", "Creative and experimental", "Exploratory, option-rich, and willing to test unusual angles.", Icons.Material.Filled.AutoAwesome, Color.Secondary)
    ];

    private OrganizationResponse? _editingOrg;
    private string _formName = string.Empty;
    private string _formIndustry = string.Empty;
    private string _formMission = string.Empty;
    private string _formStage = string.Empty;
    private string _formPrimaryGoal = string.Empty;
    private string _formConstraintsJson = string.Empty;
    private string _assistantAvatar = AssistantAvatars[0].Value;
    private string _assistantDemeanor = AssistantDemeanors[1].Value;

    private bool IsBasicInfoComplete => !string.IsNullOrWhiteSpace(_formName);

    private bool IsAssistantComplete =>
        !string.IsNullOrWhiteSpace(_assistantAvatar) &&
        !string.IsNullOrWhiteSpace(_assistantDemeanor);

    protected override async Task OnInitializedAsync()
    {
        await LoadOrganizations();
    }

    async Task LoadOrganizations()
    {
        _loading = true;
        try
        {
            _organizations = await OrganizationApi.ListAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to load organizations: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    void ShowCreateForm()
    {
        _editingOrg = null;
        _wizardStep = 0;
        _formName = string.Empty;
        _formIndustry = string.Empty;
        _formMission = string.Empty;
        _formStage = string.Empty;
        _formPrimaryGoal = string.Empty;
        _formConstraintsJson = string.Empty;
        _assistantAvatar = AssistantAvatars[0].Value;
        _assistantDemeanor = AssistantDemeanors[1].Value;
        _showForm = true;
    }

    void ShowEditForm(OrganizationResponse org)
    {
        _editingOrg = org;
        _wizardStep = 0;
        _formName = org.Name;
        _formIndustry = org.Industry ?? string.Empty;
        _formMission = org.Mission ?? string.Empty;
        _formStage = org.Stage ?? string.Empty;
        _formPrimaryGoal = org.PrimaryGoal ?? string.Empty;
        _formConstraintsJson = org.ConstraintsJson ?? string.Empty;
        LoadAssistantSelection(_formConstraintsJson);
        _showForm = true;
    }

    void HideForm() => _showForm = false;

    void NextWizardStep()
    {
        if (IsBasicInfoComplete)
        {
            _wizardStep = Math.Min(_wizardStep + 1, 1);
        }
    }

    void PreviousWizardStep()
    {
        _wizardStep = Math.Max(_wizardStep - 1, 0);
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_formName)) return;

        _saving = true;
        try
        {
            if (_editingOrg is null)
            {
                var request = new CreateOrganizationRequest(
                    _formName,
                    _formIndustry,
                    _formMission,
                    _formStage,
                    _formPrimaryGoal,
                    BuildAssistantContextJson());
                await OrganizationApi.CreateAsync(request);
            }
            else
            {
                var request = new UpdateOrganizationRequest(
                    _formName,
                    _formIndustry,
                    _formMission,
                    _formStage,
                    _formPrimaryGoal,
                    BuildAssistantContextJson());
                await OrganizationApi.UpdateAsync(_editingOrg.Id, request);
            }

            HideForm();
            await LoadOrganizations();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to save organization: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    async Task ConfirmDelete(OrganizationResponse org)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{org.Name}'? This will also delete all associated business data."))
        {
            try
            {
                await OrganizationApi.DeleteAsync(org.Id);
                await LoadOrganizations();
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Failed to delete organization: {ex.Message}");
            }
        }
    }

    void NavigateToCommandCenter(Guid orgId) => Navigation.NavigateTo($"/organizations/{orgId}/command-center");

    private void LoadAssistantSelection(string? constraintsJson)
    {
        _assistantAvatar = AssistantAvatars[0].Value;
        _assistantDemeanor = AssistantDemeanors[1].Value;

        if (string.IsNullOrWhiteSpace(constraintsJson))
        {
            return;
        }

        try
        {
            if (JsonNode.Parse(constraintsJson) is not JsonObject context)
            {
                return;
            }

            SetAssistantDemeanor(context["preferredOperatingStyle"]?.GetValue<string>());

            if (context["personalAssistant"] is JsonObject assistant)
            {
                SetAssistantAvatar(assistant["avatar"]?.GetValue<string>());
                SetAssistantDemeanor(assistant["demeanor"]?.GetValue<string>());
            }
        }
        catch (JsonException)
        {
            // Older rows may contain plain text. Keep defaults and preserve the original value on save.
        }
    }

    private string? BuildAssistantContextJson()
    {
        var assistantProfile = new PersonalAssistantSelection(_assistantAvatar, _assistantDemeanor);

        if (string.IsNullOrWhiteSpace(_formConstraintsJson))
        {
            return JsonSerializer.Serialize(new { personalAssistant = assistantProfile }, JsonOptions);
        }

        try
        {
            if (JsonNode.Parse(_formConstraintsJson) is JsonObject context)
            {
                context["personalAssistant"] = JsonSerializer.SerializeToNode(assistantProfile, JsonOptions);
                return context.ToJsonString(JsonOptions);
            }
        }
        catch (JsonException)
        {
            return _formConstraintsJson;
        }

        return _formConstraintsJson;
    }

    private void SetAssistantAvatar(string? value)
    {
        if (!string.IsNullOrWhiteSpace(value) && AssistantAvatars.Any(x => string.Equals(x.Value, value, StringComparison.OrdinalIgnoreCase)))
        {
            _assistantAvatar = value;
        }
    }

    private void SetAssistantDemeanor(string? value)
    {
        if (!string.IsNullOrWhiteSpace(value) && AssistantDemeanors.Any(x => string.Equals(x.Value, value, StringComparison.OrdinalIgnoreCase)))
        {
            _assistantDemeanor = value;
        }
    }

    static string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        return value.Length <= maxLength ? value : value[..maxLength] + "...";
    }

    private sealed record AssistantAvatarOption(string Value, string Name, string Description, string Icon, Color Color);

    private sealed record AssistantDemeanorOption(string Value, string Name, string Description, string Icon, Color Color);

    private sealed record PersonalAssistantSelection(string Avatar, string Demeanor);
}

{
  "manifestVersion": "1.0",
  "id": "com.csweet.personal-assistant",
  "name": "C-Sweet Personal Assistant",
  "version": "0.1.0",
  "publisher": {
    "id": "com.csweet",
    "name": "C-Sweet"
  },
  "runtime": {
    "type": "executable",
    "entrypoints": {
      "win-x64": "bin/win-x64/CSweet.Agents.PersonalAssistant.exe",
      "linux-x64": "bin/linux-x64/CSweet.Agents.PersonalAssistant",
      "linux-arm64": "bin/linux-arm64/CSweet.Agents.PersonalAssistant",
      "osx-arm64": "bin/osx-arm64/CSweet.Agents.PersonalAssistant"
    },
    "supportsMultipleInstallations": true,
    "maximumConcurrentJobs": 20
  },
  "protocol": {
    "minimumVersion": "1.0",
    "maximumVersion": "1.x"
  },
  "capabilities": [
    "assistant.converse.v1",
    "assistant.summarize-activity.v1",
    "assistant.plan-work.v1"
  ],
  "requestedSubscriptions": [
    "com.csweet.user.message.received.v1",
    "com.csweet.action.completed.v1",
    "com.csweet.action.rejected.v1",
    "com.csweet.approval.completed.v1"
  ],
  "requestedPublications": [
    "com.csweet.assistant.response.created.v1",
    "com.csweet.assistant.progress.updated.v1",
    "com.csweet.action.proposed.v1"
  ],
  "requestedPermissions": [
    "conversation.read",
    "conversation.respond",
    "capability.request",
    "action.propose"
  ],
  "requestedNetworkAccess": []
}

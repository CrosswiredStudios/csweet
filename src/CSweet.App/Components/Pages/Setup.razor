@page "/setup"
@using System.Net.Http.Json
@using CSweet.Contracts.Setup
@inject HttpClient Http

<PageTitle>C-Sweet Setup</PageTitle>

<div class="container mt-5">
    <h1>C-Sweet Setup</h1>
    @if (_status is null)
    {
        <p class="lead">@(_errorMessage ?? "Loading setup status...")</p>
    }
    else
    {
        <p class="lead">@(_status.IsFirstRunComplete ? "Setup is complete." : "Setup is waiting for the required first-run steps.")</p>

        <div class="list-group mt-4">
            @foreach (var step in _status.Steps)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <span>@step.DisplayName</span>
                    <span class="badge @(step.IsComplete ? "bg-success" : "bg-secondary")">
                        @(step.IsComplete ? "Complete" : "Pending")
                    </span>
                </div>
            }
        </div>
    }
</div>

@code {
    private SetupStatusResponse? _status;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/setup/status");

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = $"Setup status request failed with {(int)response.StatusCode}.";
                return;
            }

            _status = await response.Content.ReadFromJsonAsync<SetupStatusResponse>();
        }
        catch
        {
            _errorMessage = "Unable to load setup status from the API.";
        }
    }
}

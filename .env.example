# ============================================================
# C-Sweet Environment Configuration
# Copy this file to .env and adjust values for your environment.
# ============================================================

# Public URL users open in the browser
CSWEET_PUBLIC_URL=http://localhost:8080

# Database configuration
POSTGRES_DB=csweet
POSTGRES_USER=csweet
POSTGRES_PASSWORD=change-me-in-production

# Connection string used by API, WorkerHost, and migration job
# Format: Host=<service>;Port=5432;Database=<db>;Username=<user>;Password=<pass>
CSWEET_CONNECTIONSTRINGS__POSTGRES=Host=postgres;Port=5432;Database=csweet;Username=csweet;Password=change-me-in-production

# First-run setup flag (set to false after initial setup if desired)
CSWEET_SETUP__ALLOW_FIRST_RUN=true

# Optional email-delivery defaults. These are not required for registration.
# You can instead configure and test SMTP from the protected setup wizard later.
CSWEET_SMTP__HOST=
CSWEET_SMTP__PORT=587
CSWEET_SMTP__ENABLESSL=true
CSWEET_SMTP__USERNAME=
CSWEET_SMTP__PASSWORD=
CSWEET_SMTP__FROMADDRESS=
CSWEET_SMTP__FROMNAME=C-Sweet
CSWEET_SMTP__PUBLICAPPURL=http://localhost:8080

# Default local LLM provider preset
# When running in Docker, LM Studio on the host is reachable via host.docker.internal
# For direct local development (dotnet run), use http://localhost:1234/v1 instead
CSWEET_LLM__DEFAULT_PROVIDER_TYPE=LMStudio
CSWEET_LLM__DEFAULT_BASE_URL=http://host.docker.internal:1234/v1
CSWEET_LLM__DEFAULT_API_KEY=lm-studio
CSWEET_LLM__DEFAULT_CHAT_MODEL=

# Runtime environment settings
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production

# Port configuration (override if needed)
APP_PORT=8080

# Linux group ID that owns /var/run/docker.sock. The worker uses the socket only
# to create locked-down builder containers; imported build containers never receive it.
DOCKER_GID=0
